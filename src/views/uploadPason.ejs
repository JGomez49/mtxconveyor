        buildSpecialCurves(datasets, getAllProcessedSeriesROP(), 'ROP');
      }
      else if(plot.id==='mse'){
        const nM=state.mseSeries.length; state.mseSeries.forEach((s,idx)=>{ if(!(s.raw?.length && isSeriesEnabled('mse', `mse:${s.name}`))) return; const col=s.color||colorByIndex(idx,nM); datasets.push(makeDatasetFor('mse', `${s.name} — MSE (ksi) vs MD`, prepareForPlot(s.raw), col)); });
        buildSpecialCurves(datasets, getAllProcessedSeriesMSE(), 'MSE');
      }
      else if(plot.id==='flow'){
        const nF=state.flowSeries.length; state.flowSeries.forEach((s,idx)=>{ if(!(s.raw?.length && isSeriesEnabled('flow', `flow:${s.name}`))) return; const col=s.color||colorByIndex(idx,nF); datasets.push(makeDatasetFor('flow', `${s.name} — Flow (m³/min) vs MD`, prepareForPlot(s.raw), col)); });
        buildSpecialCurves(datasets, getAllProcessedSeriesFLOW(), 'Flow');
      }
      else if(plot.id==='td'){
        const nTD=state.timeDepthSeries.length; state.timeDepthSeries.forEach((s,idx)=>{ if(!(s.raw?.length && isSeriesEnabled('td', `td:${s.name}`))) return; const col=s.color||colorByIndex(idx,nTD); datasets.push(makeDatasetFor('td', `${s.name} — Depth vs Time`, prepareForPlot(s.raw), col)); });
        const tdSeries=getAllProcessedSeriesTD(); const tdStep=computeAdaptiveStepTD(tdSeries);
        buildSpecialCurves(datasets, tdSeries, 'Depth', { stepOverride: tdStep, minSeriesOverride: 1 });
      }

      const axesSelected = plot.id==='hl'?state.axesHL: plot.id==='tq'?state.axesTQ: plot.id==='wob'?state.axesWOB: plot.id==='rop'?state.axesROP: plot.id==='mse'?state.axesMSE: plot.id==='flow'?state.axesFLOW: state.axesTD;

      let autoYMin, autoYMax;
      if (plot.id !== 'td' && (axesSelected.yMin==null && axesSelected.yMax==null)) {
        let yMaxCur = (lastCurvesSpecial.max && lastCurvesSpecial.max.length)
          ? Math.max(...lastCurvesSpecial.max.map(p=>p.y).filter(Number.isFinite))
          : null;
        if (!Number.isFinite(yMaxCur)) {
          const allY=[]; datasets.forEach(d=>{ if(!/glow/i.test(String(d.label||''))) d.data.forEach(pt=>Number.isFinite(pt?.y)&&allY.push(pt.y)); });
          if (allY.length) yMaxCur = Math.max(...allY);
        }
        if (Number.isFinite(yMaxCur)) { autoYMin=0; autoYMax=yMaxCur*1.10; }
      }

      const tooltipLabel=(ctx)=>{ const y=ctx.parsed.y, x=ctx.parsed.x; const name=ctx.dataset.label||'Series'; const xf=Number.isFinite(x)?x.toFixed(2):'—'; const yf=Number.isFinite(y)?y.toFixed(2):'—'; if(plot.id==='hl') return `${name}: ${yf} kDaN @ ${xf} m`; if(plot.id==='tq') return `${name}: ${yf} kN·m @ ${xf} m`; if(plot.id==='wob') return `${name}: ${yf} kDaN @ ${xf} m`; if(plot.id==='rop') return `${name}: ${yf} m/h @ ${xf} m`; if(plot.id==='mse') return `${name}: ${yf} ksi @ ${xf} m`; if(plot.id==='flow') return `${name}: ${yf} m³/min @ ${xf} m`; return `${name}: ${yf} m @ ${xf} days`; };

      chartMain=new Chart(ctx,{ type:'line', data:{datasets}, options:{ responsive:true, plugins:{ legend:{ display:showLegend, labels:{ color:'#e9ecef', filter:(item)=>!String(item.text||'').toLowerCase().includes('glow') } }, tooltip:{ mode:'nearest', intersect:false, filter:(item)=>!((item.dataset.label||'').toLowerCase().includes('glow')), callbacks:{label: tooltipLabel} }, zoom: enableZoom?{ pan:{enabled:true,mode:'xy'}, zoom:{ wheel:{enabled:true, modifierKey:'ctrl'}, pinch:{enabled:true}, mode:'xy' } }: undefined }, scales:{ x:{ type:'linear', title:{display:true,text:plot.xTitle,color:'#e9ecef'}, ticks:{color:'#adb5bd'}, grid:{color:'rgba(173,181,189,0.2)'}, min: Number.isFinite(axesSelected.xMin)?axesSelected.xMin: undefined, max: Number.isFinite(axesSelected.xMax)?axesSelected.xMax: undefined }, y:{ type:'linear', reverse: !!plot.reversedY, title:{display:true,text:plot.yTitle,color:'#e9ecef'}, ticks:{ color:'#adb5bd', callback:(v)=>Number.isFinite(v)?Number(v).toFixed(2):v }, grid:{color:'rgba(173,181,189,0.2)'}, min: Number.isFinite(axesSelected.yMin)?axesSelected.yMin : (autoYMin), max: Number.isFinite(axesSelected.yMax)?axesSelected.yMax : (autoYMax) } } } });

      buildSeriesToggleMenu();
    }

    function buildSpecialCurves(datasets, seriesForGrid, labelPrefix, opts){ const showAvg=document.getElementById('showAverage').checked; const showMax=document.getElementById('showMax').checked; const showMin=document.getElementById('showMin').checked; const userStep=parseFloat(document.getElementById('avgStep').value)||5; const step=(opts && Number.isFinite(opts.stepOverride))?opts.stepOverride:Math.max(0.0001, userStep); const userMinSeries=parseInt(document.getElementById('avgMinSeries').value,10)||2; const minSeries=(opts && Number.isFinite(opts.minSeriesOverride))?opts.minSeriesOverride:Math.max(1,userMinSeries); const smoothOn=document.getElementById('applySmoothing').checked; const win=parseInt(document.getElementById('smoothWindow').value,10)||1; const maxPctVal=Math.min(100,Math.max(50, parseFloat(document.getElementById('maxPct').value)||90))/100; const minPctVal=Math.min(50,Math.max(0,  parseFloat(document.getElementById('minPct').value)||10))/100; lastCurvesSpecial={avg:[],max:[],min:[]}; if(showMin){ const pts=buildPercentileSeries(seriesForGrid, step, minSeries, minPctVal, win); lastCurvesSpecial.min=pts; if(pts.length){ datasets.push({ label:`Min ${labelPrefix} (glow)`, data:pts, borderColor:'rgba(255,0,0,0.20)', backgroundColor:'rgba(255,0,0,0.20)', showLine:true, borderDash:[], borderWidth:10, pointRadius:0, fill:false, tension:0.25, order:993 }); datasets.push({ label:`Min ${labelPrefix}`, data:pts, borderColor:'#ff0000', backgroundColor:'#ff0000', showLine:true, borderDash:[], borderWidth:3, pointRadius:0, fill:false, tension:0.25, order:994 }); } } if(showMax){ const pts=buildPercentileSeries(seriesForGrid, step, minSeries, maxPctVal, win); lastCurvesSpecial.max=pts; if(pts.length){ datasets.push({ label:`Max ${labelPrefix} (glow)`, data:pts, borderColor:'rgba(0,255,0,0.20)', backgroundColor:'rgba(0,255,0,0.20)', showLine:true, borderDash:[], borderWidth:10, pointRadius:0, fill:false, tension:0.25, order:995 }); datasets.push({ label:`Max ${labelPrefix}`, data:pts, borderColor:'#00ff00', backgroundColor:'#00ff00', showLine:true, borderDash:[], borderWidth:3, pointRadius:0, fill:false, tension:0.25, order:996 }); } } if(showAvg){ const pts=buildAverageSeries(seriesForGrid, step, minSeries, smoothOn, win); lastCurvesSpecial.avg=pts; if(pts.length){ datasets.push({ label:`Average ${labelPrefix} (glow)`, data:pts, borderColor:'rgba(0,229,255,0.20)', backgroundColor:'rgba(0,229,255,0.20)', showLine:true, borderDash:[], borderWidth:10, pointRadius:0, fill:false, tension:0.25, order:997 }); datasets.push({ label:`Average ${labelPrefix}`, data:pts, borderColor:'#00e5ff', backgroundColor:'#00e5ff', showLine:true, borderDash:[], borderWidth:3, pointRadius:0, fill:false, tension:0.25, order:998 }); } } }

    async function processFile1(file, hasHeader){ const buf=await file.arrayBuffer(); const wb=XLSX.read(buf,{type:'array'}); if(!wb.SheetNames.length) throw new Error('No sheets'); const sheet=wb.Sheets[wb.SheetNames[0]]; const rows=XLSX.utils.sheet_to_json(sheet,{header:1,defval:null}); if(!rows.length) throw new Error('Empty sheet'); const start=hasHeader?1:0; const A=[],B=[],C=[]; for(let r=start;r<rows.length;r++){ const row=rows[r]||[]; A.push(row[0]); B.push(row[1]); C.push(row[2]); } const {pts:rawB,replaced:replacedB}=cleanAndBuildXY(A,B); const {pts:rawC,replaced:replacedC}=cleanAndBuildXY(A,C); state.file1={name:file.name, rawB, rawC, rows:rows.length-start, replacedB, replacedC}; }

    async function parsePasonCsvFile(file,hasHeader,manualMseCol1Based){ const text=await file.text(); const parsed=Papa.parse(text,{ delimiter:"", newline:"", quoteChar:'"', escapeChar:'"', header:false, skipEmptyLines:true }); const rows=parsed.data||[]; if(!rows.length) return null; let headerRow=null; let start=0; if(hasHeader && rows.length){ headerRow=rows[0]; start=1; } let mseIdx=null; const manualIdx=parseInt(manualMseCol1Based,10); if(Number.isFinite(manualIdx)&&manualIdx>=1){ mseIdx=manualIdx-1; } else if(headerRow){ for(let i=0;i<headerRow.length;i++){ const h=String(headerRow[i]??'').toLowerCase(); if(!h) continue; if((h.includes('mechanical specific energy')||h.includes('mse')) && (h.includes('ksi') || !h.includes('kpa'))){ mseIdx=i; break; } } }
      const Xmd=[], Ywob=[], Yhl=[], Ytq=[], Yflow=[], Yrop=[], Ymse=[]; const tsArr=[], mdArr=[];
      for(let r=start;r<rows.length;r++){ const row=rows[r]||[]; Xmd.push(row[2]); Yrop.push(row[4]); Ywob.push(row[5]); Yhl.push(row[8]); Ytq.push(row[10]); Yflow.push(row[11]); if(mseIdx!==null && row.length>mseIdx){ Ymse.push(row[mseIdx]); } else { Ymse.push(null); } const d=row[0], t=row[1]; const ts=parseDateTimeUTC(d,t); const md=toNumber(row[2]); tsArr.push(Number.isFinite(ts)?ts:NaN); mdArr.push(Number.isFinite(md)?md:NaN); }
      const XmdNum=Xmd.map(v=>v); const YropFiltered=Yrop.map(v=>toNumber(v)).map(v=>(Number.isFinite(v)&&v>=0)?v:null); const {pts:rawROP}=cleanAndBuildXY(XmdNum,YropFiltered); const {pts:rawWOB}=cleanAndBuildXY(Xmd,Ywob); const {pts:rawHL,replaced:replHL}=cleanAndBuildXY(Xmd,Yhl); const {pts:rawTQ,replaced:replTQ}=cleanAndBuildXY(Xmd,Ytq); const {pts:rawFLOW}=cleanAndBuildXY(Xmd,Yflow); let rawMSE=[]; if(mseIdx!==null){ const {pts}=cleanAndBuildXY(Xmd,Ymse); rawMSE=pts; }
      let tdPts=[]; const firstIdx=tsArr.findIndex(v=>Number.isFinite(v)); if(firstIdx!==-1){ const t0=tsArr[firstIdx]; const days=tsArr.map(v=>Number.isFinite(v)?((v-t0)/86400000):NaN); const {pts}=cleanAndBuildXY(days, mdArr); tdPts=pts; }
      const baseName=(file.webkitRelativePath||file.name).replace(/\.[^.]+$/, '');
      return { name:baseName, wob:{raw:rawWOB,rows:rawWOB.length}, hl:{raw:rawHL,rows:rows.length-start,replaced:replHL}, tq:{raw:rawTQ,rows:rows.length-start,replaced:replTQ}, rop:{raw:rawROP,rows:rawROP.length}, mse:{raw:rawMSE,rows:rawMSE.length,mseCol:mseIdx}, flow:{raw:rawFLOW,rows:rawFLOW.length}, td:{raw:tdPts,rows:rows.length-start} };
    }

    async function processPasonFolder(fileList,hasHeader){ const csvFiles=Array.from(fileList).filter(f=>f.name.toLowerCase().endsWith('.csv')); csvFiles.sort((a,b)=>(a.webkitRelativePath||a.name).localeCompare(b.webkitRelativePath||b.name)); const manualMseCol1Based=document.getElementById('mseColInput').value; const seriesHL=[],seriesTQ=[],seriesWOB=[],seriesROP=[],seriesMSE=[],seriesFLOW=[],seriesTD=[]; for(const f of csvFiles){ try{ const s=await parsePasonCsvFile(f,hasHeader,manualMseCol1Based); if(!s) continue; if(s.wob.raw.length) seriesWOB.push({name:s.name,raw:s.wob.raw,rows:s.wob.rows}); if(s.hl.raw.length) seriesHL.push({name:s.name,raw:s.hl.raw,rows:s.hl.rows,replaced:s.hl.replaced}); if(s.tq.raw.length) seriesTQ.push({name:s.name,raw:s.tq.raw,rows:s.tq.rows,replaced:s.tq.replaced}); if(s.rop.raw.length) seriesROP.push({name:s.name,raw:s.rop.raw,rows:s.rop.rows}); if(s.mse.raw.length) seriesMSE.push({name:s.name,raw:s.mse.raw,rows:s.mse.rows,mseCol:s.mse.mseCol}); if(s.flow.raw.length) seriesFLOW.push({name:s.name,raw:s.flow.raw,rows:s.flow.rows}); if(s.td.raw.length) seriesTD.push({name:s.name,raw:s.td.raw,rows:s.td.rows}); } catch(err){ console.warn('Failed to parse CSV:', f.name, err); } }
      const totalWOB=seriesWOB.length; seriesWOB.forEach((s,i)=>s.color=colorByIndex(i,totalWOB)); const totalHL=seriesHL.length; seriesHL.forEach((s,i)=>s.color=colorByIndex(i,totalHL)); const totalTQ=seriesTQ.length; seriesTQ.forEach((s,i)=>s.color=colorByIndex(i,totalTQ)); const totalROP=seriesROP.length; seriesROP.forEach((s,i)=>s.color=colorByIndex(i,totalROP)); const totalMSE=seriesMSE.length; seriesMSE.forEach((s,i)=>s.color=colorByIndex(i,totalMSE)); const totalFLOW=seriesFLOW.length; seriesFLOW.forEach((s,i)=>s.color=colorByIndex(i,totalFLOW)); const totalTD=seriesTD.length; seriesTD.forEach((s,i)=>s.color=colorByIndex(i,totalTD));
      state.wobSeries=seriesWOB; state.pasonSeries=seriesHL; state.torqueSeries=seriesTQ; state.ropSeries=seriesROP; state.mseSeries=seriesMSE; state.flowSeries=seriesFLOW; state.timeDepthSeries=seriesTD;
      buildSeriesToggleMenu();
    }

    function downloadCsv(points,filename){ if(!points||!points.length){ alert('No curve data available to export.'); return; } const p=currentPlotDef(); const xHeader=(p.id==='td')?'Days':'MeasuredDepth_m'; const yHeader= p.id==='hl'?'HookLoad_kDaN': p.id==='tq'?'Torque_kN_m': p.id==='wob'?'WOB_kDaN': p.id==='rop'?'ROP_m_per_h': p.id==='mse'?'MSE_ksi': p.id==='flow'?'Flow_m3_per_min': 'HoleDepth_m'; const header=`${xHeader},${yHeader}\n`; const rows=points.map(pt=>`${pt.x.toFixed(4)},${pt.y.toFixed(4)}`).join('\n'); const blob=new Blob([header+rows],{type:'text/csv;charset=utf-8;'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download=filename; a.click(); setTimeout(()=>URL.revokeObjectURL(url),1000); }

    const file1El=document.getElementById('file1'); const pasonFolderEl=document.getElementById('pasonFolder'); const file1HeadersEl=document.getElementById('file1Headers'); const pasonHeadersEl=document.getElementById('pasonHeaders'); const mseColInputEl=document.getElementById('mseColInput'); const plotSelectEl=document.getElementById('plotSelect'); const applySmoothingEl=document.getElementById('applySmoothing'); const smoothWindowEl=document.getElementById('smoothWindow'); const smoothValueEl=document.getElementById('smoothValue'); const rejectSpikesEl=document.getElementById('rejectSpikes'); const spikeThresholdEl=document.getElementById('spikeThreshold'); const useIqrRejectEl=document.getElementById('useIqrReject'); const lineStyleEl=document.getElementById('lineStyle'); const paletteModeEl=document.getElementById('paletteMode'); const dotStyleEl=document.getElementById('dotStyle'); const showPointsEl=document.getElementById('showPoints'); const showLegendEl=document.getElementById('showLegend'); const showAverageEl=document.getElementById('showAverage'); const avgStepEl=document.getElementById('avgStep'); const avgMinSeriesEl=document.getElementById('avgMinSeries'); const showMaxEl=document.getElementById('showMax'); const showMinEl=document.getElementById('showMin'); const maxPctEl=document.getElementById('maxPct'); const minPctEl=document.getElementById('minPct'); const xMinEl=document.getElementById('xMin'); const xMaxEl=document.getElementById('xMax'); const yMinEl=document.getElementById('yMin'); const yMaxEl=document.getElementById('yMax'); const applyAxesBtn=document.getElementById('applyAxes'); const autoAxesBtn=document.getElementById('autoAxes'); const enableZoomEl=document.getElementById('enableZoom'); const resetZoomBtn=document.getElementById('resetZoom'); const exportAvgCsvBtn=document.getElementById('exportAvgCsv'); const exportMaxCsvBtn=document.getElementById('exportMaxCsv'); const exportMinCsvBtn=document.getElementById('exportMinCsv'); const exportPngBtn=document.getElementById('exportPng'); const exportVisibleCsvBtn=document.getElementById('exportVisibleCsv');

    file1El.addEventListener('change', async (e)=>{ const file=e.target.files?.[0]; if(!file) return; document.getElementById('status1').textContent='Reading Excel…'; try{ await processFile1(file, file1HeadersEl.checked); renderMain(); } catch(err){ console.error(err); document.getElementById('status1').textContent='Failed to read File 1.'; } });
    pasonFolderEl.addEventListener('change', async (e)=>{ const files=e.target.files; if(!files||!files.length) return; document.getElementById('status2').textContent='Reading CSVs…'; try{ await processPasonFolder(files, pasonHeadersEl.checked); renderMain(); } catch(err){ console.error(err); document.getElementById('status2').textContent='Failed to read Pason CSV folder.'; } });
    file1HeadersEl.addEventListener('change', async ()=>{ const f=file1El.files?.[0]; if(!f) return; document.getElementById('status1').textContent='Re-reading Excel…'; try{ await processFile1(f, file1HeadersEl.checked); renderMain(); } catch(err){ console.error(err); document.getElementById('status1').textContent='Failed to read File 1.'; } });
    pasonHeadersEl.addEventListener('change', async ()=>{ const files=pasonFolderEl.files; if(!files||!files.length) return; document.getElementById('status2').textContent='Re-reading CSVs…'; try{ await processPasonFolder(files, pasonHeadersEl.checked); renderMain(); } catch(err){ console.error(err); document.getElementById('status2').textContent='Failed to read Pason CSV folder.'; } });
    mseColInputEl.addEventListener('change', async ()=>{ const files=pasonFolderEl.files; if(!files||!files.length) return; document.getElementById('status2').textContent='Re-reading CSVs (MSE col)…'; try{ await processPasonFolder(files, pasonHeadersEl.checked); renderMain(); } catch(err){ console.error(err); document.getElementById('status2').textContent='Failed to read Pason CSV folder.'; } });

    plotSelectEl.addEventListener('change', ()=>{ updateSpecialControlsVisibility(); updateAxesLabels(); xMinEl.value=''; xMaxEl.value=''; yMinEl.value=''; yMaxEl.value=''; renderMain(); });

    applySmoothingEl.addEventListener('change', renderMain); smoothWindowEl.addEventListener('input', ()=>{ smoothValueEl.textContent=smoothWindowEl.value; renderMain(); }); rejectSpikesEl.addEventListener('change', renderMain); useIqrRejectEl.addEventListener('change', renderMain); spikeThresholdEl.addEventListener('input', renderMain); lineStyleEl.addEventListener('change', renderMain); paletteModeEl.addEventListener('change', renderMain); dotStyleEl.addEventListener('input', renderMain); showPointsEl.addEventListener('change', renderMain); showLegendEl.addEventListener('change', renderMain);

    showAverageEl.addEventListener('change', renderMain); avgStepEl.addEventListener('input', renderMain); avgMinSeriesEl.addEventListener('input', renderMain); showMaxEl.addEventListener('change', renderMain); showMinEl.addEventListener('change', renderMain); maxPctEl.addEventListener('input', renderMain); minPctEl.addEventListener('input', renderMain);

    function selectedAxes(){ const p=currentPlotDef(); return p.id==='hl'?state.axesHL: p.id==='tq'?state.axesTQ: p.id==='wob'?state.axesWOB: p.id==='rop'?state.axesROP: p.id==='mse'?state.axesMSE: p.id==='flow'?state.axesFLOW: state.axesTD; }
    function setSelectedAxes(ax){ const p=currentPlotDef(); if(p.id==='hl') state.axesHL=ax; else if(p.id==='tq') state.axesTQ=ax; else if(p.id==='wob') state.axesWOB=ax; else if(p.id==='rop') state.axesROP=ax; else if(p.id==='mse') state.axesMSE=ax; else if(p.id==='flow') state.axesFLOW=ax; else state.axesTD=ax; }

    document.getElementById('applyAxes').addEventListener('click', ()=>{ const xMin=parseFloat(xMinEl.value); const xMax=parseFloat(xMaxEl.value); const yMin=parseFloat(yMinEl.value); const yMax=parseFloat(yMaxEl.value); setSelectedAxes({ xMin:Number.isFinite(xMin)?xMin:null, xMax:Number.isFinite(xMax)?xMax:null, yMin:Number.isFinite(yMin)?yMin:null, yMax:Number.isFinite(yMax)?yMax:null }); renderMain(); });
    document.getElementById('autoAxes').addEventListener('click', ()=>{ setSelectedAxes({xMin:null,xMax:null,yMin:null,yMax:null}); xMinEl.value=''; xMaxEl.value=''; yMinEl.value=''; yMaxEl.value=''; renderMain(); });

    enableZoomEl.addEventListener('change', renderMain); resetZoomBtn.addEventListener('click', ()=>{ if(chartMain?.resetZoom) chartMain.resetZoom(); });

    document.getElementById('exportAvgCsv').addEventListener('click', ()=>{ const p=currentPlotDef(); if(!p.supportsSpecial) return alert('No Average for this plot.'); downloadCsv(lastCurvesSpecial.avg, `${p.id.toUpperCase()}_AverageCurve.csv`); });
    document.getElementById('exportMaxCsv').addEventListener('click', ()=>{ const p=currentPlotDef(); if(!p.supportsSpecial) return alert('No Max for this plot.'); downloadCsv(lastCurvesSpecial.max, `${p.id.toUpperCase()}_MaxCurve.csv`); });
    document.getElementById('exportMinCsv').addEventListener('click', ()=>{ const p=currentPlotDef(); if(!p.supportsSpecial) return alert('No Min for this plot.'); downloadCsv(lastCurvesSpecial.min, `${p.id.toUpperCase()}_MinCurve.csv`); });

    document.getElementById('exportVisibleCsv').addEventListener('click', ()=>{ if(!chartMain) return; const ds=chartMain.data.datasets.filter(d=>!d.hidden && d.data && d.data.length); if(!ds.length) return alert('No visible data to export.'); const lines=['Series,X,Y']; ds.forEach(d=>{ d.data.forEach(pt=>lines.push(`${d.label},${pt.x},${pt.y}`)); }); const blob=new Blob([lines.join('\n')],{type:'text/csv;charset=utf-8;'}); const url=URL.createObjectURL(blob); const a=document.createElement('a'); const p=currentPlotDef(); a.href=url; a.download=`${p.id}_visible.csv`; a.click(); setTimeout(()=>URL.revokeObjectURL(url),1000); });

    function updateStatus(){ const f1txt=state.file1 ? `Loaded \"${state.file1.name}\" • Rows: ${state.file1.rows} • Replaced: B=${state.file1.replacedB}, C=${state.file1.replacedC}` : ''; document.getElementById('status1').textContent=f1txt; const pasonCount=state.pasonSeries.length; const totalRows=state.pasonSeries.reduce((acc,s)=>acc+(s.rows||0),0); const totalRepl=state.pasonSeries.reduce((acc,s)=>acc+(s.replaced||0),0); const f2txt=pasonCount?`Loaded HL series: ${pasonCount} • Total rows: ${totalRows} • Replaced: ${totalRepl}`:''; document.getElementById('status2').textContent=f2txt; }

    const _renderMain=renderMain; renderMain=function(){ _renderMain(); updateStatus(); }

    buildPlotDropdownUI();
    renderMain();
  </script>
</body>
</html>