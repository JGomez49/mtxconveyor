        const nW=state.wobSeries.length; state.wobSeries.forEach((s,idx)=>{ if(!(s.raw?.length && isSeriesEnabled('wob', `wob:${s.name}`))) return; const col=s.color||colorByIndex(idx,nW); datasets.push(makeDatasetFor('wob', `${s.name} — WOB (kDaN) vs MD`, prepareForPlot(s.raw), col)); });
