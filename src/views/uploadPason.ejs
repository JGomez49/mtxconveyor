
<!doctype html>

<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>Drilling Plots</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" sizes="32x64"
    href="https://res.cloudinary.com/metacortexjohn/image/upload/v1658373747/Icono_Metacortex_ahblhc.png">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5/dist/slate/bootstrap.min.css">
  <style>
    body { padding: 2rem 0; }
    .chart-wrap { background: #1b1e21; border-radius: .5rem; padding: 1rem; }
    .small-note { font-size: 0.95rem; opacity: 0.9; }
    input[type="file"] { color-scheme: dark; }
    canvas { max-height: 70vh; }
    .file-title { font-weight: 600; }
    .form-range { width: 220px; }
    .num-input { width: 120px; }
    .num-input-wide { width: 180px; }
    .num-input-axis { width: 120px; }
    .controls-block { gap: .75rem; }
    hr.subtle { border-top: 1px solid rgba(255,255,255,0.08); }
    .vis-hidden { display: none !important; }
    .flex-gap { gap: .5rem; }
    .dropdown-menu-checklist { max-height: 40vh; overflow: auto; min-width: 260px; }
  </style>
</head>

<body>
  <div class="container">

    <header class="mb-3">
      <img src="https://res.cloudinary.com/metacortexjohn/image/upload/v1711167914/Canadian_Natural_logo_ygbbox.png"
        alt="Canadian Natural Resources Logo" width="250" height="100">
      <h1 class="h4 mb-1">Pason Plots</h1>
    </header>

    <div class="d-grid gap-2">
      <a href="/notes" class="btn btn-primary btn-block my-2">Back</a>
    </div>

    <div class="card mb-4">
      <div class="card-body">
        <div class="row g-4">
          <div class="col-lg-6">
            <div class="file-title mb-2">File 1 (Generic Excel): B & C vs A</div>
            <label for="file1" class="form-label">Excel file (.xlsx or .xls)</label>
            <input id="file1" class="form-control" type="file" accept=".xlsx,.xls" />
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="file1Headers" checked />
              <label class="form-check-label" for="file1Headers">First row contains headers</label>
            </div>
            <div id="status1" class="form-text mt-2"></div>
          </div>
          <div class="col-lg-6">
            <div class="file-title mb-2">Pason CSVs Folder</div>
            <label for="pasonFolder" class="form-label">Select folder with Pason CSV files</label>
            <input id="pasonFolder" class="form-control" type="file" accept=".csv" webkitdirectory multiple />
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="pasonHeaders" checked />
              <label class="form-check-label" for="pasonHeaders">First row contains headers (applies to all CSVs)</label>
            </div>
            <div class="input-group input-group-sm mt-2" style="max-width: 360px;">
              <span class="input-group-text">MSE column (1‑based)</span>
              <input type="number" class="form-control" id="mseColInput" min="1" step="1" placeholder="Leave blank to auto-detect" />
            </div>
            <div id="status2" class="form-text mt-2"></div>
          </div>
        </div>

        <hr class="my-4 subtle"/>

        <div class="row g-3 align-items-center mb-2">
          <div class="col-xxl-4 d-flex align-items-center flex-gap">
            <label for="plotSelect" class="form-label mb-0">Plot:</label>
            <select id="plotSelect" class="form-select form-select-sm" style="max-width: 520px;"></select>
          </div>
          <div class="col-xxl-8 d-flex flex-wrap controls-block justify-content-xxl-end align-items-center">
            <div class="input-group input-group-sm" style="width: 200px;">
              <label class="input-group-text" for="paletteMode">Palette</label>
              <select class="form-select" id="paletteMode">
                <option value="colors">Colors</option>
                <option value="gray">Gray</option>
              </select>
            </div>
            <div class="input-group input-group-sm" style="width: 260px;">
              <label class="input-group-text" for="lineStyle">Line style</label>
              <select class="form-select" id="lineStyle">
                <option value="solid">Solid line</option>
                <option value="dotted">Dotted line</option>
                <option value="points" selected>Points only</option>
                <option value="hide">Hide regular curves</option>
              </select>
            </div>
            <!-- Points toggle (default hidden) -->
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="showPoints" />
              <label class="form-check-label" for="showPoints">Show points</label>
            </div>
            <div class="d-flex align-items-center gap-2">
              <label for="dotStyle" class="form-label mb-0">Dots size & opacity</label>
              <input type="range" id="dotStyle" class="form-range" min="0" max="100" step="1" value="10" />
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="rejectSpikes" />
              <label class="form-check-label" for="rejectSpikes">Reject spikes</label>
            </div>
            <div class="input-group input-group-sm num-input">
              <span class="input-group-text">Δ ></span>
              <input type="number" class="form-control" id="spikeThreshold" value="5" step="0.1" min="0" />
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="useIqrReject" checked />
              <label class="form-check-label" for="useIqrReject">Robust spike filter (IQR)</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="applySmoothing" checked />
              <label class="form-check-label" for="applySmoothing">Smooth</label>
            </div>
            <div class="d-flex align-items-center gap-2">
              <label for="smoothWindow" class="form-label mb-0">Window</label>
              <input type="range" id="smoothWindow" class="form-range" min="1" max="25" step="2" value="5" />
              <span id="smoothValue" class="small-note">5</span>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="showLegend" />
              <label class="form-check-label" for="showLegend">Show legend</label>
            </div>
            <!-- Series toggle dropdown -->
            <div class="dropdown">
              <button class="btn btn-outline-light btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                Series (current plot)
              </button>
              <div class="dropdown-menu dropdown-menu-checklist p-2" id="seriesToggleMenu"></div>
            </div>
          </div>
        </div>

        <div id="specialControls" class="row g-3 align-items-center mb-2">
          <div class="col-xxl-12 d-flex flex-wrap controls-block justify-content-xxl-end align-items-center">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="showAverage" checked />
              <label class="form-check-label" for="showAverage">Average</label>
            </div>
            <div class="input-group input-group-sm num-input-wide">
              <span class="input-group-text">Step</span>
              <input type="number" class="form-control" id="avgStep" value="5" step="1" min="0.0001" />
              <span class="input-group-text">m / days</span>
            </div>
            <div class="input-group input-group-sm num-input">
              <span class="input-group-text">Min series</span>
              <input type="number" class="form-control" id="avgMinSeries" value="2" step="1" min="1" />
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="showMax" checked />
              <label class="form-check-label" for="showMax">Max (percentile)</label>
            </div>
            <div class="input-group input-group-sm num-input">
              <span class="input-group-text">Max %</span>
              <input type="number" class="form-control" id="maxPct" value="90" step="1" min="50" max="100" />
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="showMin" checked />
              <label class="form-check-label" for="showMin">Min (percentile)</label>
            </div>
            <div class="input-group input-group-sm num-input">
              <span class="input-group-text">Min %</span>
              <input type="number" class="form-control" id="minPct" value="10" step="1" min="0" max="50" />
            </div>
            <div class="btn-group btn-group-sm" role="group" aria-label="CSV Exports">
              <button id="exportAvgCsv" class="btn btn-outline-success">Export Average CSV</button>
              <button id="exportMaxCsv" class="btn btn-outline-success">Export Max CSV</button>
              <button id="exportMinCsv" class="btn btn-outline-success">Export Min CSV</button>
            </div>
          </div>
        </div>

        <div class="row g-2 align-items-center mb-2">
          <div class="col-xxl-12 d-flex flex-wrap align-items-center gap-2">
            <span class="small-note me-2">Axes (<span id="axesPlotName">Hook Load vs Measured Depth</span>):</span>
            <div class="input-group input-group-sm num-input-axis">
              <span class="input-group-text">X min</span>
              <input type="number" class="form-control" id="xMin" />
            </div>
            <div class="input-group input-group-sm num-input-axis">
              <span class="input-group-text">X max</span>
              <input type="number" class="form-control" id="xMax" />
            </div>
            <div class="input-group input-group-sm num-input-axis">
              <span class="input-group-text">Y min</span>
              <input type="number" class="form-control" id="yMin" />
            </div>
            <div class="input-group input-group-sm num-input-axis">
              <span class="input-group-text">Y max</span>
              <input type="number" class="form-control" id="yMax" />
            </div>
            <button id="applyAxes" class="btn btn-outline-light btn-sm">Apply</button>
            <button id="autoAxes" class="btn btn-outline-light btn-sm">Auto</button>
            <div class="form-check ms-3">
              <input class="form-check-input" type="checkbox" id="enableZoom" />
              <label class="form-check-label" for="enableZoom">Enable zoom/pan</label>
            </div>
            <button id="resetZoom" class="btn btn-outline-warning btn-sm">Reset Zoom</button>
            <button id="exportPng" class="btn btn-outline-info btn-sm ms-auto">Download PNG</button>
            <button id="exportVisibleCsv" class="btn btn-outline-info btn-sm">Export visible CSV</button>
          </div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-body">
        <div class="chart-wrap">
          <canvas id="chartMain"></canvas>
        </div>
      </div>
    </div>

    <div class="text-muted small-note mt-3">
      <p class="mb-1"><strong>Data rules</strong></p>
      <ul class="mb-2">
        <li>Excel (File 1): A = Measured Depth (m), B & C = numeric series for HL plot.</li>
        <li>Pason CSVs:
          <ul>
            <li><strong>Date</strong> = column 1 (day, month, year), <strong>Time</strong> = column 2 (HH:MM:SS)</li>
            <li><strong>MD / Hole Depth</strong> = column 3 (m)</li>
            <li><strong>WOB</strong> = column 6 “Weight on Bit (kDaN)”</li>
            <li><strong>Hook Load</strong> = column 9 (kDaN)</li>
            <li><strong>Torque</strong> = column 11 (kN·m)</li>
            <li><strong>Flow</strong> = column 12 “Total Pump Output (m³/min)”</li>
            <li><strong>ROP</strong> = column 5 (m/h). <em>Negative values are discarded.</em></li>
            <li><strong>MSE</strong> = “Mechanical Specific Energy (ksi)” column (auto‑detect header or manual index)</li>
          </ul>
        </li>
        <li>Time axis uses <em>days from series start</em> (Day 0 at each file’s first valid timestamp). Depth axis is <strong>inverted</strong> on the Time–Depth plot.</li>
      </ul>
    </div>
  </div>

  <!-- Libraries -->
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (function() { const zp = window['chartjs-plugin-zoom']; if (zp && window.Chart) { Chart.register(zp); }})();

    const plotRegistry = [
      { id: 'hl',  name: 'Hook Load vs Measured Depth',   xTitle: 'Measured Depth (m)', yTitle: 'Hook Load (kDaN)', supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'tq',  name: 'Torque vs Measured Depth',      xTitle: 'Measured Depth (m)', yTitle: 'Torque (kN·m)',     supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'wob', name: 'WOB vs Measured Depth',         xTitle: 'Measured Depth (m)', yTitle: 'WOB (kDaN)',        supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'rop', name: 'ROP vs Measured Depth',         xTitle: 'Measured Depth (m)', yTitle: 'ROP (m/h)',         supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'mse', name: 'MSE vs Measured Depth',         xTitle: 'Measured Depth (m)', yTitle: 'MSE (ksi)',         supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'flow',name: 'Flow vs Measured Depth',        xTitle: 'Measured Depth (m)', yTitle: 'Flow (m³/min)',     supportsSpecial: true,  reversedY: false, defaultSolid: false },
      { id: 'td',  name: 'Hole Depth vs Time (days)',     xTitle: 'Time (days from start)', yTitle: 'Hole Depth (m)', supportsSpecial: true,  reversedY: true,  defaultSolid: true }
    ];

    function buildPlotDropdownUI() {
      const sel = document.getElementById('plotSelect'); sel.innerHTML = '';
      plotRegistry.forEach(p => { const opt = document.createElement('option'); opt.value = p.id; opt.textContent = p.name; sel.appendChild(opt); });
      sel.value = 'hl'; updateSpecialControlsVisibility(); updateAxesLabels();
    }
    function currentPlotDef() { const id = document.getElementById('plotSelect').value; return plotRegistry.find(p => p.id === id) || plotRegistry[0]; }
    function updateSpecialControlsVisibility(){ const p = currentPlotDef(); document.getElementById('specialControls').classList.toggle('vis-hidden', !p.supportsSpecial); }
    function updateAxesLabels(){ const p = currentPlotDef(); document.getElementById('axesPlotName').textContent = p.name; document.getElementById('xMin').placeholder = p.xTitle+' min'; document.getElementById('xMax').placeholder = p.xTitle+' max'; document.getElementById('yMin').placeholder = p.yTitle+' min'; document.getElementById('yMax').placeholder = p.yTitle+' max'; }

    function toNumber(v){ if (typeof v==='number') return Number.isFinite(v)?v:NaN; if(v==null) return NaN; const s=String(v).trim(); if(!s) return NaN; const normalized=s.replace(/\s/g,'').replace(/,/g,''); const n=Number(normalized); return Number.isFinite(n)?n:NaN; }

    function cleanAndBuildXY(xArr,yArr){ const xs=[],ys=[]; let runSum=0,runCount=0,replaced=0; for(let i=0;i<Math.min(xArr.length,yArr.length);i++){ const x=toNumber(xArr[i]); let y=toNumber(yArr[i]); if(!Number.isFinite(x)) continue; if(Number.isFinite(y)){ if(y===-999.25){ y=(runCount>0)?(runSum/runCount):null; replaced++; } } else { y=(runCount>0)?(runSum/runCount):null; replaced++; } xs.push(x); ys.push(y); if(y!==null && Number.isFinite(y)){ runSum+=y; runCount+=1; } } const firstIdx=ys.findIndex(v=>v!==null && Number.isFinite(v)); if(firstIdx>0){ const firstVal=ys[firstIdx]; for(let i=0;i<firstIdx;i++) ys[i]=firstVal; } const pts=[]; for(let i=0;i<xs.length;i++){ const y=ys[i]; if(y!==null && Number.isFinite(y)) pts.push({x:xs[i], y}); } pts.sort((a,b)=>a.x-b.x); return {pts, replaced}; }

    function rejectSpikes(points,threshold){ if(!Array.isArray(points)||points.length===0||threshold<=0) return points; const out=[]; let prevY=null; for(const p of points){ if(prevY===null){ out.push(p); prevY=p.y; continue; } const dy=Math.abs(p.y-prevY); if(dy<=threshold){ out.push(p); prevY=p.y; } } return out; }

    function percentileOfSorted(sorted,q){ const n=sorted.length; if(!n) return null; if(q<=0) return sorted[0]; if(q>=1) return sorted[n-1]; const pos=(n-1)*q; const lo=Math.floor(pos); const hi=Math.ceil(pos); const frac=pos-lo; if(hi===lo) return sorted[lo]; return sorted[lo]*(1-frac)+sorted[hi]*frac; }
    function rejectSpikesIqr(points,win=51,k=3.0){ if(!Array.isArray(points)||points.length===0) return points; const w=Math.max(3,win|0); const half=Math.floor(w/2); const ys=points.map(p=>p.y); const out=[]; for(let i=0;i<ys.length;i++){ const s=Math.max(0,i-half), e=Math.min(ys.length-1,i+half); const slice=ys.slice(s,e+1).filter(Number.isFinite).sort((a,b)=>a-b); if(slice.length<5){ out.push(points[i]); continue; } const q1=percentileOfSorted(slice,0.25); const q3=percentileOfSorted(slice,0.75); const iqr=q3-q1; const lo=q1-k*iqr; const hi=q3+k*iqr; const y=ys[i]; if(y>=lo && y<=hi) out.push(points[i]); } return out; }

    function smoothSeries(points,window){ if(!points||points.length===0||window<=1) return points; const w=Math.max(1,window|0); const half=Math.floor(w/2); const out=new Array(points.length); const pref=new Array(points.length+1).fill(0); for(let i=0;i<points.length;i++) pref[i+1]=pref[i]+points[i].y; for(let i=0;i<points.length;i++){ const start=Math.max(0,i-half); const end=Math.min(points.length-1,i+half); const count=end-start+1; const sum=pref[end+1]-pref[start]; out[i]={x:points[i].x,y:sum/count}; } return out; }

    function interpAt(points,x){ const n=points.length; if(n===0) return null; if(x<points[0].x || x>points[n-1].x) return null; if(x===points[0].x) return points[0].y; if(x===points[n-1].x) return points[n-1].y; for(let i=1;i<n;i++){ const p0=points[i-1], p1=points[i]; if(x>=p0.x && x<=p1.x){ const dx=p1.x-p0.x; if(dx===0) return p0.y; const t=(x-p0.x)/dx; return p0.y + t*(p1.y-p0.y); } } return null; }
    function collectSeriesValuesAtX(seriesList,x){ const ys=[]; for(const arr of seriesList){ const y=interpAt(arr,x); if(Number.isFinite(y)) ys.push(y); } return ys; }

    function xRange(seriesList){ let minX=Infinity,maxX=-Infinity; for(const arr of seriesList){ if(!arr.length) continue; if(arr[0].x<minX) minX=arr[0].x; if(arr[arr.length-1].x>maxX) maxX=arr[arr.length-1].x; } return {minX,maxX}; }

    function buildAverageSeries(seriesList, step, minSeries, alsoSmooth, smoothWindow){ const valid=seriesList.filter(a=>Array.isArray(a)&&a.length>0); if(!valid.length) return []; const {minX,maxX}=xRange(valid); if(!(Number.isFinite(minX)&&Number.isFinite(maxX)&&maxX>minX)) return []; const s=Math.max(0.0001, step); const out=[]; for(let x=minX; x<=maxX+1e-9; x+=s){ const ys=collectSeriesValuesAtX(valid,x); if(ys.length>=minSeries){ const avg=ys.reduce((a,b)=>a+b,0)/ys.length; out.push({x,y:avg}); } } return alsoSmooth ? smoothSeries(out, smoothWindow) : out; }
    function buildPercentileSeries(seriesList, step, minSeries, pct, smoothWindow){ const valid=seriesList.filter(a=>Array.isArray(a)&&a.length>0); if(!valid.length) return []; const {minX,maxX}=xRange(valid); if(!(Number.isFinite(minX)&&Number.isFinite(maxX)&&maxX>minX)) return []; const s=Math.max(0.0001, step); const out=[]; for(let x=minX; x<=maxX+1e-9; x+=s){ const ys=collectSeriesValuesAtX(valid,x); if(ys.length>=minSeries){ ys.sort((a,b)=>a-b); const val=percentileOfSorted(ys,pct); if(Number.isFinite(val)) out.push({x,y:val}); } } return smoothSeries(out, smoothWindow); }

    function parseDateTimeUTC(dStr,tStr){ const d=(dStr==null)?'':String(dStr).trim(); const t=(tStr==null)?'':String(tStr).trim(); if(!d) return NaN; let year,month,day; const split=(s)=>s.split(/[\/\-.]/).map(x=>x.trim()); if(/-/.test(d)||/\./.test(d)||/\//.test(d)){ const parts=split(d); if(parts.length===3){ if(parts[0].length===4){ year=+parts[0]; month=+parts[1]; day=+parts[2]; } else { day=+parts[0]; month=+parts[1]; year=+parts[2]; if(year<100) year+=2000; } } } if(!Number.isFinite(year)||!Number.isFinite(month)||!Number.isFinite(day)){ const parsed=Date.parse(d+(t?(' '+t):'')); return isNaN(parsed)?NaN:parsed; } let hh=0,mm=0,ss=0; if(t){ const tp=t.split(':').map(n=>parseInt(n,10)); hh=tp[0]||0; mm=tp[1]||0; ss=tp[2]||0; } return Date.UTC(year,month-1,day,hh,mm,ss); }

    function hslToRgb(h,s,l){ s/=100; l/=100; const k=n=>(n+h/30)%12; const a=s*Math.min(l,1-l); const f=n=>l - a*Math.max(-1, Math.min(k(n)-3, Math.min(9-k(n),1))); return [Math.round(255*f(0)), Math.round(255*f(8)), Math.round(255*f(4))]; }
    function colorToRgba(color,alpha=1){ color=String(color).trim().toLowerCase(); if(color.startsWith('#')){ const hex=color.replace('#',''); const bigint=parseInt(hex.length===3?hex.split('').map(c=>c+c).join(''):hex,16); const r=(bigint>>16)&255, g=(bigint>>8)&255, b=bigint&255; return `rgba(${r},${g},${b},${alpha})`; } if(color.startsWith('rgb(')){ const nums=color.replace(/[^\d,.-]/g,'').split(',').map(Number); const [r,g,b]=nums; return `rgba(${r||0},${g||0},${b||0},${alpha})`; } if(color.startsWith('hsl(')){ const nums=color.replace(/[^\d,.-]/g, ' ').trim().split(/\s+/).map(parseFloat); const [h,s,l]=nums; const [r,g,b]=hslToRgb(h, s, l); return `rgba(${r},${g},${b},${alpha})`; } return `rgba(176,176,176,${alpha})`; }
    function colorByIndex(i,total){ const h=Math.round((360*i)/Math.max(1,total)); return `hsl(${h} 70% 55%)`; }

    // ---------------- State ----------------
    let state={ file1:null, pasonSeries:[], axesHL:{xMin:null,xMax:null,yMin:null,yMax:null}, torqueSeries:[], axesTQ:{xMin:null,xMax:null,yMin:null,yMax:null}, wobSeries:[], axesWOB:{xMin:null,xMax:null,yMin:null,yMax:null}, ropSeries:[], axesROP:{xMin:null,xMax:null,yMin:null,yMax:null}, mseSeries:[], axesMSE:{xMin:null,xMax:null,yMin:null,yMax:null}, flowSeries:[], axesFLOW:{xMin:null,xMax:null,yMin:null,yMax:null}, timeDepthSeries:[], axesTD:{xMin:null,xMax:null,yMin:null,yMax:null} };
    const seriesEnableState = { hl:{}, tq:{}, wob:{}, rop:{}, mse:{}, flow:{}, td:{} };
    let lastCurvesSpecial={avg:[],max:[],min:[]};
    let chartMain=null;

    function getStyleOptionsGlobal(){ const mode=document.getElementById('lineStyle').value; if(mode==='points') return {showLine:false,borderDash:[],borderWidth:0, hide:false}; if(mode==='dotted') return {showLine:true,borderDash:[6,4],borderWidth:2, hide:false}; if(mode==='hide') return {showLine:false,borderDash:[],borderWidth:0, hide:true}; return {showLine:true,borderDash:[],borderWidth:2, hide:false}; }
    function getStyleOptionsFor(plotId){ const global=getStyleOptionsGlobal(); if(plotId==='td' && document.getElementById('lineStyle').value==='points'){ return {showLine:true,borderDash:[],borderWidth:2, hide:false}; } return global; }
    function dotParams(){ const v=parseInt(document.getElementById('dotStyle').value,10)||0; const radius=0.5+(v/100)*4.5; const alpha=0.15+(v/100)*0.85; return {radius,alpha}; }

    function isSeriesEnabled(plotId,key){ const st=seriesEnableState[plotId]||{}; return (key in st) ? !!st[key] : true; }
    function setSeriesEnabled(plotId,key,val){ if(!seriesEnableState[plotId]) seriesEnableState[plotId]={}; seriesEnableState[plotId][key]=!!val; }

    function getSeriesListForPlot(plotId){ const list=[]; if(plotId==='hl'){ if(state.file1?.rawB?.length){ list.push({key:'file1:B', label: `${state.file1.name} — B`}); } if(state.file1?.rawC?.length){ list.push({key:'file1:C', label: `${state.file1.name} — C`}); } state.pasonSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`hl:${s.name}`, label:s.name}); }); } else if(plotId==='tq'){ state.torqueSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`tq:${s.name}`, label:s.name}); }); } else if(plotId==='wob'){ state.wobSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`wob:${s.name}`, label:s.name}); }); } else if(plotId==='rop'){ state.ropSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`rop:${s.name}`, label:s.name}); }); } else if(plotId==='mse'){ state.mseSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`mse:${s.name}`, label:s.name}); }); } else if(plotId==='flow'){ state.flowSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`flow:${s.name}`, label:s.name}); }); } else if(plotId==='td'){ state.timeDepthSeries.forEach(s=>{ if(s.raw?.length) list.push({key:`td:${s.name}`, label:s.name}); }); } return list; }

    function buildSeriesToggleMenu(){ const p=currentPlotDef(); const menu=document.getElementById('seriesToggleMenu'); menu.innerHTML=''; const items=getSeriesListForPlot(p.id); if(!items.length){ const em=document.createElement('div'); em.className='text-muted small'; em.textContent='No series loaded'; menu.appendChild(em); return; }
      items.forEach(({key,label})=>{ const id='chk_'+btoa(p.id+'|'+key).replace(/=/g,''); const wrap=document.createElement('div'); wrap.className='form-check'; const inp=document.createElement('input'); inp.className='form-check-input'; inp.type='checkbox'; inp.id=id; inp.checked=isSeriesEnabled(p.id, key); const lab=document.createElement('label'); lab.className='form-check-label'; lab.htmlFor=id; lab.textContent=label; wrap.appendChild(inp); wrap.appendChild(lab); menu.appendChild(wrap); inp.addEventListener('change', ()=>{ setSeriesEnabled(p.id, key, inp.checked); renderMain(); }); });
    }

    function prepareForPlot(points){ const reject=document.getElementById('rejectSpikes').checked; const thresh=parseFloat(document.getElementById('spikeThreshold').value)||0; const useIqr=document.getElementById('useIqrReject').checked; const smoothOn=document.getElementById('applySmoothing').checked; const win=parseInt(document.getElementById('smoothWindow').value,10)||1; let out=points; if(reject){ out=useIqr?rejectSpikesIqr(out,51,3.0):rejectSpikes(out,thresh); } if(smoothOn) out=smoothSeries(out,win); return out; }

    function makeDatasetFor(plotId,label,data,baseColor){ const grayMode=document.getElementById('paletteMode').value==='gray'; const style=getStyleOptionsFor(plotId); const {radius:dotRadius,alpha:dotAlpha}=dotParams(); const showPts=document.getElementById('showPoints').checked; const lineColor=grayMode?'#b0b0b0':baseColor; const pointColor=colorToRgba(lineColor,dotAlpha); return { label, data, borderColor:lineColor, backgroundColor:lineColor, showLine:style.showLine, borderDash:style.borderDash, borderWidth:style.borderWidth, fill:false, tension:0.2, pointRadius: showPts?dotRadius:0, pointBackgroundColor:pointColor, pointBorderColor:pointColor, order:10, hidden: !!style.hide }; }

    function getAllProcessedSeriesHL(){ const out=[]; if(state.file1?.rawB?.length && isSeriesEnabled('hl','file1:B')) out.push(prepareForPlot(state.file1.rawB)); if(state.file1?.rawC?.length && isSeriesEnabled('hl','file1:C')) out.push(prepareForPlot(state.file1.rawC)); state.pasonSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('hl', `hl:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesTQ(){ const out=[]; state.torqueSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('tq', `tq:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesWOB(){ const out=[]; state.wobSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('wob', `wob:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesROP(){ const out=[]; state.ropSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('rop', `rop:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesMSE(){ const out=[]; state.mseSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('mse', `mse:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesFLOW(){ const out=[]; state.flowSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('flow', `flow:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }
    function getAllProcessedSeriesTD(){ const out=[]; state.timeDepthSeries.forEach(s=>{ if(s.raw?.length && isSeriesEnabled('td', `td:${s.name}`)) out.push(prepareForPlot(s.raw)); }); return out; }

    function computeAdaptiveStepTD(seriesList){ const {minX,maxX}=xRange(seriesList); if(!(Number.isFinite(minX)&&Number.isFinite(maxX)&&maxX>minX)) return 0.05; const range=maxX-minX; const target=800; let step=range/target; step=Math.max(0.001, Math.min(step, Math.max(0.5, range/50)) ); return step; }

    function renderMain(){ const plot=currentPlotDef(); const ctx=document.getElementById('chartMain').getContext('2d'); if(chartMain){ chartMain.destroy(); chartMain=null; }
      const enableZoom=document.getElementById('enableZoom').checked; const showLegend=document.getElementById('showLegend').checked; const datasets=[]; lastCurvesSpecial={avg:[],max:[],min:[]};

      if(plot.id==='hl'){
        const pal={b:'#4cc9f0', c:'#fca311'};
        if(state.file1?.rawB?.length && isSeriesEnabled('hl','file1:B')) datasets.push(makeDatasetFor('hl', `${state.file1.name} — B vs A`, prepareForPlot(state.file1.rawB), pal.b));
        if(state.file1?.rawC?.length && isSeriesEnabled('hl','file1:C')) datasets.push(makeDatasetFor('hl', `${state.file1.name} — C vs A`, prepareForPlot(state.file1.rawC), pal.c));
        const nP=state.pasonSeries.length; state.pasonSeries.forEach((s,idx)=>{ if(!(s.raw?.length && isSeriesEnabled('hl', `hl:${s.name}`))) return; const col=s.color||colorByIndex(idx,nP); datasets.push(makeDatasetFor('hl', `${s.name} — HL (col9 vs col3)`, prepareForPlot(s.raw), col)); });
