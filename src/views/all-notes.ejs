        const totalHdr = isLightMode
            ? 'style="text-align:center;font-size:0.75rem;font-weight:bold;padding:4px 6px;background:#e9ecef;color:#212529;"'
            : 'style="text-align:center;font-size:0.75rem;font-weight:bold;padding:4px 6px;"';

        const summaryTable = document.createElement("table");
        summaryTable.className = "table table-dark table-sm table-bordered table-hover mt-2";
        summaryTable.id = "summaryTable";
        summaryTable.innerHTML = `
        <thead>
            <tr>
                <th ${thStyle("transparent","white")}>TIME RANGE</th>
                <th ${thStyle("#4caf50","#020202")}>FINAL</th>
                <th ${thStyle("#B11FDF","#ffffff")}>HANDED OVER</th>
                <th ${thStyle("#0084c7","#020202")}>DP-YES</th>
                <th ${thStyle("#ffff00","#020202")}>IN PROGRESS</th>
                <th ${thStyle("#ff4c4c","#ffffff")}>IN QUEUE</th>
                <th ${thStyle("#37474f","#ffffff")}>NEED INFO</th>
                <th ${thStyle("#C0C0C0","#020202")}>NOT REQUESTED</th>
                <th ${thStyle("#c0392b","#ffffff")}>ERRORS</th>
                <th ${totalHdr}>TOTAL</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td ${tdStyle}>This Year</td>
                <td ${tdStyle}>${colorCounts.greenThisYear}</td>
                <td ${tdStyle}>${colorCounts.purpleThisYear}</td>
                <td ${tdStyle}>${colorCounts.blueThisYear}</td>
                <td ${tdStyle}>${colorCounts.yellowThisYear}</td>
                <td ${tdStyle}>${colorCounts.redThisYear}</td>
                <td ${tdStyle}>${colorCounts.blackThisYear}</td>
                <td ${tdStyle}>${colorCounts.silverThisYear}</td>
                <td ${tdStyle}>${colorCounts.whiteThisYear}</td>
                <td ${tdStyle}><b>${totalBarsThisYearCalc}</b></td>
            </tr>
            <tr>
                <td ${tdStyle}>Next Year (Budget)</td>
                <td ${tdStyle}>${colorCounts.greenNextYear}</td>
                <td ${tdStyle}>${colorCounts.purpleNextYear}</td>
                <td ${tdStyle}>${colorCounts.blueNextYear}</td>
                <td ${tdStyle}>${colorCounts.yellowNextYear}</td>
                <td ${tdStyle}>${colorCounts.redNextYear}</td>
                <td ${tdStyle}>${colorCounts.blackNextYear}</td>
                <td ${tdStyle}>${colorCounts.silverNextYear}</td>
                <td ${tdStyle}>${colorCounts.whiteNextYear}</td>
                <td ${tdStyle}><b>${totalBarsNextYear}</b></td>
            </tr>
        </tbody>`;
        chartDiv.appendChild(summaryTable);

        // Pie charts
        const pieRow = document.createElement("div");
        pieRow.className = "pie-row";

        const pieCanvas = document.createElement("canvas");
        pieCanvas.className = "pie-chart";
        const pieCanvas3 = document.createElement("canvas");
        pieCanvas3.className = "pie-chart";
        pieRow.appendChild(pieCanvas);
        pieRow.appendChild(pieCanvas3);
        chartDiv.appendChild(pieRow);

        new Chart(pieCanvas.getContext("2d"), {
            type: "pie",
            data: {
                labels: ["FINAL","EXEC","DP-YES","IN-PROGRESS","IN-QUEUE","PRELIM-IR","NOT-REQ","OTHER"],
                datasets: [{ data: [
                    colorCounts.greenThisYear, colorCounts.purpleThisYear,
                    colorCounts.blueThisYear,  colorCounts.yellowThisYear,
                    colorCounts.redThisYear,   colorCounts.blackThisYear,
                    colorCounts.silverThisYear, colorCounts.whiteThisYear,
                ], backgroundColor: ["#4caf50","#B11FDF","#0084c7","#ffff00","#ff4c4c","#555555","#C0C0C0","#FFFFFF"],
                   borderColor: "#333", borderWidth: 1 }]
            },
            plugins: [ChartDataLabels],
            options: { layout: { padding: 0 }, plugins: {
                title: { display:true, text:`This Year: ${totalBarsThisYearCalc} Wells`, color: anChartColor(), font:{size:14,weight:"normal"} },
                legend: { position:"left", labels:{ color: anChartColor(), font:{ size:9 }, boxWidth:12, padding:6 } },
                datalabels: {
                    color: (ctx) => {
                        const bg = ctx.dataset.backgroundColor[ctx.dataIndex] || "#000";
                        const lightBgs = ["#ffff00","#C0C0C0","#FFFFFF","#ffffff"];
                        return lightBgs.some(col => bg.toLowerCase() === col.toLowerCase()) ? "#000" : "#fff";
                    },
                    font:{weight:"bold",size:10},
                    formatter:(v,ctx)=>{ const t=ctx.chart.data.datasets[0].data.reduce((a,b)=>a+b,0); return (v&&t)?Math.round(v/t*100)+"%":""; }
                }
            }}
        });

        new Chart(pieCanvas3.getContext("2d"), {
            type: "pie",
            data: {
                labels: ["FINAL","EXEC","DP-YES","IN-PROGRESS","IN-QUEUE","PRELIM-IR","NOT-REQ","OTHER"],
                datasets: [{ data: [
                    colorCounts.greenNextYear, colorCounts.purpleNextYear,
                    colorCounts.blueNextYear,  colorCounts.yellowNextYear,
