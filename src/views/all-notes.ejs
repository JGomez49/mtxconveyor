    //// window.addEventListener("DOMContentLoaded", renderChartsFromTable);

    // ── Compiled Summary Table ──────────────────────────────────────────────
    // Renders one row per VP+group plus a TOTAL row into #compiledSummaryDiv.
    function renderCompiledSummary(rows) {
        const container = document.getElementById('compiledSummaryDiv');
        if (!container || rows.length === 0) return;

        const cols = [
            { key: 'greenThisYear',  label: 'FINAL',            bg: '#4caf50', fg: '#020202' },
            { key: 'purpleThisYear', label: 'HANDED OVER',      bg: '#B11FDF', fg: '#ffffff' },
            { key: 'blueThisYear',   label: 'DP-YES',           bg: '#0084c7', fg: '#020202' },
            { key: 'yellowThisYear', label: 'IN PROGRESS',      bg: '#ffff00', fg: '#020202' },
            { key: 'redThisYear',    label: 'IN QUEUE',         bg: '#ff4c4c', fg: '#ffffff' },
            { key: 'blackThisYear',  label: 'NEED INFO',        bg: '#37474f', fg: '#ffffff' },
            { key: 'silverThisYear', label: 'NOT REQUESTED',    bg: '#C0C0C0', fg: '#020202' },
            { key: 'whiteThisYear',  label: 'ERRORS',           bg: '#c0392b', fg: '#ffffff' },
        ];
        const colsNY = cols.map(c => ({ ...c, key: c.key.replace('ThisYear','NextYear') }));

        // Grand totals
        const totTY = { blueThisYear:0, greenThisYear:0, blackThisYear:0, yellowThisYear:0,
                         purpleThisYear:0, redThisYear:0, whiteThisYear:0, silverThisYear:0, totalThisYear:0 };
        const totNY = { blueNextYear:0, greenNextYear:0, blackNextYear:0, yellowNextYear:0,
                         purpleNextYear:0, redNextYear:0, whiteNextYear:0, silverNextYear:0, totalNextYear:0 };
        rows.forEach(r => {
            Object.keys(totTY).forEach(k => totTY[k] += (r[k] || 0));
            Object.keys(totNY).forEach(k => totNY[k] += (r[k] || 0));
        });

        // Build header — colours adapt to current theme
        const isLightMode = document.body.classList.contains('light-mode');
        const thStyle = (bg, fg) => {
            // In light mode: keep coloured bg but ensure text is always readable
            // For very dark backgrounds (#000, #1a1a...) switch to a lighter tint
            let useBg = bg, useFg = fg;
            if(isLightMode){
                if(bg === '#000000' || bg === '#1a1a2e') { useBg = '#37474f'; useFg = '#fff'; }
                // fg that is very dark on already-dark bg: keep white
                // fg that is near-black on a light bg: keep dark
            }
            return `style="text-align:center;background-color:${useBg};color:${useFg};font-size:0.75rem;padding:4px 6px;"`;
        };

        const grpBg    = isLightMode ? '#2c3e50'  : '#1a1a2e';
        const grpTYFg  = isLightMode ? '#58a6ff'  : '#58a6ff';
        const grpNYFg  = isLightMode ? '#c084fc'  : '#c084fc';
        const vhStyle  = isLightMode
            ? 'vertical-align:middle;text-align:center;font-size:0.8rem;background:#e9ecef;color:#212529;'
            : 'vertical-align:middle;text-align:center;font-size:0.8rem;';
        const totalHdr = isLightMode
            ? 'style="text-align:center;font-size:0.75rem;font-weight:bold;padding:4px 6px;background:#e9ecef;color:#212529;"'
            : 'style="text-align:center;font-size:0.75rem;font-weight:bold;padding:4px 6px;"';

        let thead = `
            <thead>
                <tr>
                    <th rowspan="2" style="${vhStyle}">VP</th>
                    <th rowspan="2" style="${vhStyle}">GROUP</th>
                    <th colspan="${cols.length + 1}" style="text-align:center;background:${grpBg};color:${grpTYFg};font-size:0.75rem;">
                        THIS YEAR (${new Date().getFullYear()})
                    </th>
                    <th colspan="${colsNY.length + 1}" style="text-align:center;background:${grpBg};color:${grpNYFg};font-size:0.75rem;">
                        NEXT YEAR (${new Date().getFullYear() + 1} — BUDGET)
                    </th>
                </tr>
                <tr>
                    ${cols.map(c => `<th ${thStyle(c.bg, c.fg)}>${c.label}</th>`).join('')}
                    <th ${totalHdr}>TOTAL</th>
                    ${colsNY.map(c => `<th ${thStyle(c.bg, c.fg)}>${c.label}</th>`).join('')}
                    <th ${totalHdr}>TOTAL</th>
                </tr>
            </thead>`;

        // Build rows
        const tdStyle = isLightMode
            ? 'style="text-align:center;font-size:0.8rem;padding:3px 6px;color:#212529;"'
            : 'style="text-align:center;font-size:0.8rem;padding:3px 6px;"';
        const grandTotalStyle = isLightMode
            ? 'style="border-top:2px solid #0056b3;font-weight:bold;background:#dde3ea;"'
            : 'style="border-top:2px solid #58a6ff;font-weight:bold;background:#111827;"';
        let tbody = '<tbody>';
        rows.forEach(r => {
            tbody += `<tr>
                <td ${tdStyle}>${r.vp || '—'}</td>
                <td ${tdStyle}>${r.group || '—'}</td>
                ${cols.map(c => `<td ${tdStyle}>${r[c.key] || 0}</td>`).join('')}
                <td ${tdStyle}><b>${r.totalThisYear || 0}</b></td>
                ${colsNY.map(c => `<td ${tdStyle}>${r[c.key] || 0}</td>`).join('')}
                <td ${tdStyle}><b>${r.totalNextYear || 0}</b></td>
            </tr>`;
        });

        // Grand total row
        tbody += `<tr ${grandTotalStyle}>
            <td ${tdStyle} colspan="2">GRAND TOTAL</td>
            ${cols.map(c => `<td ${tdStyle}>${totTY[c.key] || 0}</td>`).join('')}
            <td ${tdStyle}><b>${totTY.totalThisYear}</b></td>
            ${colsNY.map(c => `<td ${tdStyle}>${totNY[c.key] || 0}</td>`).join('')}
            <td ${tdStyle}><b>${totNY.totalNextYear}</b></td>
        </tr>`;
        tbody += '</tbody>';

        container.innerHTML = `
            <h4 style="color:#58a6ff;margin:24px 0 8px;letter-spacing:1px;">
                📊 COMPILED JOB STATUS SUMMARY — ALL VPs
            </h4>
            <div style="overflow-x:auto;">
                <table class="table table-dark table-sm table-bordered table-hover"
                       style="min-width:900px;font-size:0.8rem;">
                    ${thead}
                    ${tbody}
                </table>
            </div>`;
    }


</script>




