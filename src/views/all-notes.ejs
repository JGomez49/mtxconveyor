<script>
    // Column indices in #DPStatsTable (0-based), matching the <thead> order
    const DPTS_COL = {
        version:      0,
        days:         1,
        afeYear:      9,
        playType:     10,
        wellbores:    12,
        receivedDate: 15,
        requestDate:  16,
        dpType:       18,
        dpCompany:    19,
        currentPlan:  20,
    };

    // Filters whose checked state defaults to a specific set of values
    const DPTS_DEFAULT_CHECKED = {
        dptsDpType:    ['PRELIM'],
        dptsDpCompany: ['CNRL'],
    };

    let dptsAllRows = [];     // cached full row data, built once per table render
    let dptsFiltersBuilt = false;

    function dptsExtractYear(dateStr){
        if(!dateStr) return '';
        const m = String(dateStr).match(/^(\d{4})/);
        return m ? m[1] : '';
    }

    function dptsReadTableRows(){
        const rows = [];
        document.querySelectorAll("#DPStatsTable tbody tr").forEach(row => {
            const cells = row.cells;
            if(!cells || cells.length < 21) return;
            rows.push({
                version:      cells[DPTS_COL.version].innerText.trim(),
                days:         Number(cells[DPTS_COL.days].innerText.trim()) || 0,
                afeYear:      cells[DPTS_COL.afeYear].innerText.trim(),
                playType:     cells[DPTS_COL.playType].innerText.trim(),
                wellbores:    Number(cells[DPTS_COL.wellbores].innerText.trim()) || 0,
                receivedDateFull: cells[DPTS_COL.receivedDate].innerText.trim(),
                requestDateFull:  cells[DPTS_COL.requestDate].innerText.trim(),
                receivedYear: dptsExtractYear(cells[DPTS_COL.receivedDate].innerText.trim()),
                requestYear:  dptsExtractYear(cells[DPTS_COL.requestDate].innerText.trim()),
                dpType:       cells[DPTS_COL.dpType].innerText.trim(),
                dpCompany:    cells[DPTS_COL.dpCompany].innerText.trim(),
                currentPlan:  cells[DPTS_COL.currentPlan].innerText.trim(),
            });
        });
        return rows;
    }

    // Build one filter group's checkboxes from unique values present in dptsAllRows
    function dptsBuildFilterGroup(containerId, fieldKey, defaultChecked){
        const container = document.getElementById(containerId);
        if(!container) return;
        container.innerHTML = '';

        const values = [...new Set(dptsAllRows.map(r => r[fieldKey]).filter(v => v !== ''))];
        values.sort();

        if(values.length === 0){
            container.innerHTML = '<div style="color:var(--an-text-dim,#5a7080);font-size:9.5px;">No data</div>';
            return;
        }

        values.forEach(v => {
            const label = document.createElement('label');
            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.value = v;
            cb.dataset.field = fieldKey;
            cb.checked = defaultChecked ? defaultChecked.includes(v) : true;
            cb.addEventListener('change', dptsApplyFiltersAndRender);
            label.appendChild(cb);
            label.appendChild(document.createTextNode(v));
            container.appendChild(label);
        });
    }

    function dptsBuildAllFilters(){
        dptsBuildFilterGroup('dptsAfeYear',       'afeYear',      null);
        dptsBuildFilterGroup('dptsPlayType',      'playType',     null);
        dptsBuildFilterGroup('dptsReceivedYear',  'receivedYear', null);
        dptsBuildFilterGroup('dptsRequestedYear', 'requestYear',  null);
        dptsBuildFilterGroup('dptsDpType',        'dpType',       DPTS_DEFAULT_CHECKED.dptsDpType);
        dptsBuildFilterGroup('dptsDpCompany',     'dpCompany',    DPTS_DEFAULT_CHECKED.dptsDpCompany);
        dptsBuildFilterGroup('dptsCurrentPlan',   'currentPlan',  null);
        dptsFiltersBuilt = true;

        const resetBtn = document.getElementById('dptsResetBtn');
        if(resetBtn && !resetBtn.dataset.wired){
            resetBtn.dataset.wired = '1';
            resetBtn.addEventListener('click', () => {
                dptsBuildAllFilters();   // rebuild = restores defaults (PRELIM/CNRL checked, rest checked)
                dptsApplyFiltersAndRender();
            });
        }
    }

    // Returns the set of checked values for a given field across the sidebar
    function dptsGetCheckedValues(fieldKey){
        const checked = [];
        document.querySelectorAll(`#dptsSidebar input[type=checkbox][data-field="${fieldKey}"]:checked`).forEach(cb => {
            checked.push(cb.value);
        });
        return checked;
    }

    function dptsApplyFiltersAndRender(){
        const fAfeYear      = dptsGetCheckedValues('afeYear');
        const fPlayType     = dptsGetCheckedValues('playType');
        const fReceivedYear = dptsGetCheckedValues('receivedYear');
        const fRequestYear  = dptsGetCheckedValues('requestYear');
        const fDpType       = dptsGetCheckedValues('dpType');
        const fDpCompany    = dptsGetCheckedValues('dpCompany');
        const fCurrentPlan  = dptsGetCheckedValues('currentPlan');

        const filtered = dptsAllRows.filter(r =>
            fAfeYear.includes(r.afeYear) &&
            fPlayType.includes(r.playType) &&
            fReceivedYear.includes(r.receivedYear) &&
            fRequestYear.includes(r.requestYear) &&
            fDpType.includes(r.dpType) &&
            fDpCompany.includes(r.dpCompany) &&
            fCurrentPlan.includes(r.currentPlan)
        );

        dptsRenderPlot(filtered);
        dptsRenderMonthlyPlot(filtered);
        dptsRenderBacklogPlot(filtered);
        dptsRenderWellboresMonthlyPlot(filtered);
        dptsRenderWellboresBacklogPlot(filtered);
    }

    function dptsRenderPlot(rows){
        // Sort by numeric suffix of version label (P0 < P1 < P2 ...)
        const sorted = [...rows].sort((a, b) => {
            const na = parseInt(a.version.replace(/\D/g, ''), 10);
            const nb = parseInt(b.version.replace(/\D/g, ''), 10);
            return (isNaN(na) ? 999 : na) - (isNaN(nb) ? 999 : nb);
        });
        const sortedVersions = sorted.map(r => r.version);
        const sortedDays     = sorted.map(r => r.days);

        const isLight = document.body.classList.contains('light-mode');
        const fontColor  = isLight ? '#1a2535' : '#c8d8e8';
        const axisColor  = isLight ? '#2c3e50' : '#5a7080';
        const gridColor  = isLight ? '#aabbcc' : '#1e2d3d';

        Plotly.newPlot("dpBoxPlot", [{
            y: sortedDays,
            x: sortedVersions,
            type: "box",
            boxpoints: "outliers",
            marker: { color: "#0084c7" }
        }], {
            title: { text: `DP Timing Statistics (${rows.length} records)`, font: { color: fontColor, size: 14 } },
            yaxis: {
                title: { text: "Days", font: { color: axisColor } },
                range: [0, 60],
                fixedrange: false,
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                zerolinecolor: gridColor,
            },
            xaxis: {
                title: { text: "Version", font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                categoryorder: 'array',
                categoryarray: sortedVersions,
            },
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor:  'rgba(0,0,0,0)',
            font: { color: fontColor },
        });
    }

    // ── Monthly Requested vs Received counts ──────────────────────────────
    const DPTS_MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

    function dptsMonthKey(dateStr){
        // dateStr format: YYYY-MM-DD -> returns {key:'2025-02', label:'Feb 2025', sortKey:202502}
        if(!dateStr) return null;
        const m = String(dateStr).match(/^(\d{4})-(\d{2})/);
        if(!m) return null;
        const year = parseInt(m[1], 10);
        const month = parseInt(m[2], 10); // 1-12
        return {
            key: `${m[1]}-${m[2]}`,
            label: `${DPTS_MONTH_NAMES[month-1]} ${year}`,
            sortKey: year * 100 + month,
        };
    }

    // Shared helper: bucket rows into {labels, reqVals, recVals} aligned by month, sorted chronologically
    function dptsBucketByMonth(rows){
        const requestedCounts = {};
        const receivedCounts  = {};

        rows.forEach(r => {
            const reqK = dptsMonthKey(r.requestDateFull);
            if(reqK){
                if(!requestedCounts[reqK.key]) requestedCounts[reqK.key] = { label: reqK.label, sortKey: reqK.sortKey, count: 0 };
                requestedCounts[reqK.key].count++;
            }
            const recK = dptsMonthKey(r.receivedDateFull);
            if(recK){
                if(!receivedCounts[recK.key]) receivedCounts[recK.key] = { label: recK.label, sortKey: recK.sortKey, count: 0 };
                receivedCounts[recK.key].count++;
            }
        });

        const allKeys = [...new Set([...Object.keys(requestedCounts), ...Object.keys(receivedCounts)])];
        allKeys.sort((a, b) => {
            const sa = requestedCounts[a]?.sortKey ?? receivedCounts[a]?.sortKey;
            const sb = requestedCounts[b]?.sortKey ?? receivedCounts[b]?.sortKey;
            return sa - sb;
        });

        const labels  = allKeys.map(k => (requestedCounts[k] || receivedCounts[k]).label);
        const reqVals = allKeys.map(k => requestedCounts[k] ? requestedCounts[k].count : 0);
        const recVals = allKeys.map(k => receivedCounts[k]  ? receivedCounts[k].count  : 0);

        return { labels, reqVals, recVals };
    }

    function dptsRenderMonthlyPlot(rows){
        const { labels, reqVals, recVals } = dptsBucketByMonth(rows);

        const isLight = document.body.classList.contains('light-mode');
        const fontColor = isLight ? '#1a2535' : '#c8d8e8';
        const axisColor = isLight ? '#2c3e50' : '#5a7080';
        const gridColor = isLight ? '#aabbcc' : '#1e2d3d';

        const el = document.getElementById('dpMonthlyPlot');
        if(!el) return;

        Plotly.newPlot('dpMonthlyPlot', [
            {
                x: labels, y: reqVals, type: 'bar', name: 'DP Requested',
                marker: { color: '#ff6b35' },
            },
            {
                x: labels, y: recVals, type: 'bar', name: 'DP Received',
                marker: { color: '#0084c7' },
            },
        ], {
            title: { text: `DP Requests vs Received by Month (${rows.length} records)`, font: { color: fontColor, size: 14 } },
            barmode: 'group',
            yaxis: {
                title: { text: 'Count', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                zerolinecolor: gridColor,
                rangemode: 'tozero',
            },
            xaxis: {
                title: { text: 'Month', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor, size: 10 },
                gridcolor: gridColor,
                categoryorder: 'array',
                categoryarray: labels,
                tickangle: -45,
            },
            legend: {
                font: { color: fontColor },
                orientation: 'h',
                y: 1.12,
            },
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor:  'rgba(0,0,0,0)',
            font: { color: fontColor },
            margin: { b: 90 },
        });
    }

    // ── DP Backlog per month (Received − Requested) ────────────────────────
    // Shows both:
    //  - Monthly delta (received - requested in that month alone) as a bar
    //  - Cumulative running backlog (sum of all deltas up to that month) as a
    //    filled area, green where the cumulative value is >= 0, red where < 0.
    function dptsRenderBacklogPlot(rows){
        const { labels, reqVals, recVals } = dptsBucketByMonth(rows);

        const monthlyDelta = labels.map((_, i) => recVals[i] - reqVals[i]);

        // Running cumulative backlog
        let running = 0;
        const cumulative = monthlyDelta.map(d => { running += d; return running; });

        // Split cumulative into positive-only and negative-only series so each
        // can be filled with a different color. Where the segment doesn't apply,
        // the value is null so Plotly breaks the fill there. To get a clean
        // crossing at zero, each series carries 0 at the points adjacent to a
        // sign change (so the fill visually touches the zero line).
        const posSeries = new Array(cumulative.length).fill(null);
        const negSeries = new Array(cumulative.length).fill(null);

        for(let i = 0; i < cumulative.length; i++){
            const v = cumulative[i];
            if(v >= 0){
                posSeries[i] = v;
                // bring neighbouring negative series down to 0 for a clean crossing
                if(i > 0 && cumulative[i-1] < 0) negSeries[i] = 0;
            } else {
                negSeries[i] = v;
                if(i > 0 && cumulative[i-1] >= 0) posSeries[i] = 0;
            }
        }

        const isLight = document.body.classList.contains('light-mode');
        const fontColor = isLight ? '#1a2535' : '#c8d8e8';
        const axisColor = isLight ? '#2c3e50' : '#5a7080';
        const gridColor = isLight ? '#aabbcc' : '#1e2d3d';

        const el = document.getElementById('dpBacklogPlot');
        if(!el) return;

        Plotly.newPlot('dpBacklogPlot', [
            {
                x: labels, y: monthlyDelta, type: 'bar', name: 'Monthly Δ (Received − Requested)',
                marker: {
                    color: monthlyDelta.map(d => d >= 0 ? 'rgba(57,255,20,0.55)' : 'rgba(255,64,96,0.55)')
                },
                opacity: 0.7,
            },
            {
                x: labels, y: posSeries, type: 'scatter', mode: 'lines', name: 'Cumulative Backlog (+)',
                line: { color: '#39ff14', width: 2 },
                fill: 'tozeroy',
                fillcolor: 'rgba(57,255,20,0.25)',
                connectgaps: false,
            },
            {
                x: labels, y: negSeries, type: 'scatter', mode: 'lines', name: 'Cumulative Backlog (−)',
                line: { color: '#ff4060', width: 2 },
                fill: 'tozeroy',
                fillcolor: 'rgba(255,64,96,0.25)',
                connectgaps: false,
            },
        ], {
            title: { text: `DP Backlog by Month — Cumulative (Received − Requested)`, font: { color: fontColor, size: 14 } },
            yaxis: {
                title: { text: 'Backlog (count)', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                zerolinecolor: gridColor,
                zerolinewidth: 2,
            },
            xaxis: {
                title: { text: 'Month', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor, size: 10 },
                gridcolor: gridColor,
                categoryorder: 'array',
                categoryarray: labels,
                tickangle: -45,
            },
            legend: {
                font: { color: fontColor },
                orientation: 'h',
                y: 1.12,
            },
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor:  'rgba(0,0,0,0)',
            font: { color: fontColor },
            margin: { b: 90 },
        });
    }

    // ── Shared helper: bucket WELLBORE COUNTS (not row counts) by month ───
    // For each row, its `wellbores` value (DP Proposed # of Wellbores (All
    // Plans)) is added to both its request-month bucket and its
    // received-month bucket, using the same column for both sides.
    function dptsBucketWellboresByMonth(rows){
        const requestedSums = {};
        const receivedSums  = {};

        rows.forEach(r => {
            const wb = r.wellbores || 0;
            const reqK = dptsMonthKey(r.requestDateFull);
            if(reqK){
                if(!requestedSums[reqK.key]) requestedSums[reqK.key] = { label: reqK.label, sortKey: reqK.sortKey, sum: 0 };
                requestedSums[reqK.key].sum += wb;
            }
            const recK = dptsMonthKey(r.receivedDateFull);
            if(recK){
                if(!receivedSums[recK.key]) receivedSums[recK.key] = { label: recK.label, sortKey: recK.sortKey, sum: 0 };
                receivedSums[recK.key].sum += wb;
            }
        });

        const allKeys = [...new Set([...Object.keys(requestedSums), ...Object.keys(receivedSums)])];
        allKeys.sort((a, b) => {
            const sa = requestedSums[a]?.sortKey ?? receivedSums[a]?.sortKey;
            const sb = requestedSums[b]?.sortKey ?? receivedSums[b]?.sortKey;
            return sa - sb;
        });

        const labels  = allKeys.map(k => (requestedSums[k] || receivedSums[k]).label);
        const reqVals = allKeys.map(k => requestedSums[k] ? requestedSums[k].sum : 0);
        const recVals = allKeys.map(k => receivedSums[k]  ? receivedSums[k].sum  : 0);

        return { labels, reqVals, recVals };
    }

    function dptsRenderWellboresMonthlyPlot(rows){
        const { labels, reqVals, recVals } = dptsBucketWellboresByMonth(rows);

        const totalWellbores = rows.reduce((s, r) => s + (r.wellbores || 0), 0);

        const isLight = document.body.classList.contains('light-mode');
        const fontColor = isLight ? '#1a2535' : '#c8d8e8';
        const axisColor = isLight ? '#2c3e50' : '#5a7080';
        const gridColor = isLight ? '#aabbcc' : '#1e2d3d';

        const el = document.getElementById('dpWellboresMonthlyPlot');
        if(!el) return;

        Plotly.newPlot('dpWellboresMonthlyPlot', [
            {
                x: labels, y: reqVals, type: 'bar', name: 'Wellbores Requested',
                marker: { color: '#ff6b35' },
            },
            {
                x: labels, y: recVals, type: 'bar', name: 'Wellbores Received',
                marker: { color: '#0084c7' },
            },
        ], {
            title: { text: `DP Wellbores Requested vs Received by Month (${totalWellbores} total wellbores)`, font: { color: fontColor, size: 14 } },
            barmode: 'group',
            yaxis: {
                title: { text: 'Wellbores', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                zerolinecolor: gridColor,
                rangemode: 'tozero',
            },
            xaxis: {
                title: { text: 'Month', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor, size: 10 },
                gridcolor: gridColor,
                categoryorder: 'array',
                categoryarray: labels,
                tickangle: -45,
            },
            legend: {
                font: { color: fontColor },
                orientation: 'h',
                y: 1.12,
            },
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor:  'rgba(0,0,0,0)',
            font: { color: fontColor },
            margin: { b: 90 },
        });
    }

    // ── DP Wellbore Backlog per month (Wellbores Received − Wellbores Requested) ──
    function dptsRenderWellboresBacklogPlot(rows){
        const { labels, reqVals, recVals } = dptsBucketWellboresByMonth(rows);

        const monthlyDelta = labels.map((_, i) => recVals[i] - reqVals[i]);

        let running = 0;
        const cumulative = monthlyDelta.map(d => { running += d; return running; });

        const posSeries = new Array(cumulative.length).fill(null);
        const negSeries = new Array(cumulative.length).fill(null);

        for(let i = 0; i < cumulative.length; i++){
            const v = cumulative[i];
            if(v >= 0){
                posSeries[i] = v;
                if(i > 0 && cumulative[i-1] < 0) negSeries[i] = 0;
            } else {
                negSeries[i] = v;
                if(i > 0 && cumulative[i-1] >= 0) posSeries[i] = 0;
            }
        }

        const isLight = document.body.classList.contains('light-mode');
        const fontColor = isLight ? '#1a2535' : '#c8d8e8';
        const axisColor = isLight ? '#2c3e50' : '#5a7080';
        const gridColor = isLight ? '#aabbcc' : '#1e2d3d';

        const el = document.getElementById('dpWellboresBacklogPlot');
        if(!el) return;

        Plotly.newPlot('dpWellboresBacklogPlot', [
            {
                x: labels, y: monthlyDelta, type: 'bar', name: 'Monthly Δ (Received − Requested)',
                marker: {
                    color: monthlyDelta.map(d => d >= 0 ? 'rgba(57,255,20,0.55)' : 'rgba(255,64,96,0.55)')
                },
                opacity: 0.7,
            },
            {
                x: labels, y: posSeries, type: 'scatter', mode: 'lines', name: 'Cumulative Wellbore Backlog (+)',
                line: { color: '#39ff14', width: 2 },
                fill: 'tozeroy',
                fillcolor: 'rgba(57,255,20,0.25)',
                connectgaps: false,
            },
            {
                x: labels, y: negSeries, type: 'scatter', mode: 'lines', name: 'Cumulative Wellbore Backlog (−)',
                line: { color: '#ff4060', width: 2 },
                fill: 'tozeroy',
                fillcolor: 'rgba(255,64,96,0.25)',
                connectgaps: false,
            },
        ], {
            title: { text: `DP Wellbore Backlog by Month — Cumulative (Received − Requested)`, font: { color: fontColor, size: 14 } },
            yaxis: {
                title: { text: 'Backlog (wellbores)', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor },
                gridcolor: gridColor,
                zerolinecolor: gridColor,
                zerolinewidth: 2,
            },
            xaxis: {
                title: { text: 'Month', font: { color: axisColor } },
                color: fontColor,
                tickfont: { color: fontColor, size: 10 },
                gridcolor: gridColor,
                categoryorder: 'array',
                categoryarray: labels,
                tickangle: -45,
            },
            legend: {
                font: { color: fontColor },
                orientation: 'h',
                y: 1.12,
            },
            paper_bgcolor: 'rgba(0,0,0,0)',
            plot_bgcolor:  'rgba(0,0,0,0)',
            font: { color: fontColor },
            margin: { b: 90 },
        });
    }


    function renderDPStatsBoxPlot() {
        dptsAllRows = dptsReadTableRows();
        if(!dptsFiltersBuilt){
            dptsBuildAllFilters();
        }
        dptsApplyFiltersAndRender();
    }
</script>







