                    }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: (ctx) => {
                                const d = ctx.raw.details;
                                return [
                                    `Site: ${d.Site}`, `Well: ${d.Well}`, `ETS: ${d.ETS}`,
                                    `Start: ${d.Start}`, `Type: ${d.type}`,
                                    `D.E: ${d.DE || '—'}`,
                                    `DrillOK: ${d.drillok}`, `GeoOK: ${d.geook}`,
                                    `DP Company: ${d.dpCompany}`,
                                    `Dp Requested: ${d.dpReq}`, `DP Received: ${d.DP}`,
                                    `Duration: ${d.Duration} days`,
