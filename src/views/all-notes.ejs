<script>
(function(){
    const LS_KEY = 'mtxThemePreference';
    const sw     = document.getElementById('anThemeSwitch');

    function applyTheme(light){
        document.body.classList.toggle('light-mode', light);
        sw.checked = light;
    }

    // Apply saved preference immediately (before paint to avoid flash)
    applyTheme(localStorage.getItem(LS_KEY) === 'light');

    sw.addEventListener('change', function(){
        localStorage.setItem(LS_KEY, sw.checked ? 'light' : 'dark');
        applyTheme(sw.checked);
    });
})();
</script>

