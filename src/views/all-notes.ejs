                            ),
                        }
                    },
                    zoom: {
                        pan: {
                            enabled: true,
                            mode: "x",
                        },
                        zoom: {
                            wheel: { enabled: true },
                            pinch: { enabled: true },
                            mode: "x",
                        },
                        limits: {
                            x: {
                                min: minDate.getTime(),
                                max: absoluteMax.getTime(),
                                minRange: 7 * 24 * 60 * 60 * 1000,
                            },
                        },
                    }
                },
            },
            plugins: [ChartDataLabels, {
                id: "anChartBgPlugin",
                beforeDraw: (chart) => {
                    if(!anIsLight()) return;
                    const ctx2 = chart.canvas.getContext("2d");
                    ctx2.save();
                    ctx2.globalCompositeOperation = "destination-over";
                    ctx2.fillStyle = "#ffffff";
                    ctx2.fillRect(0, 0, chart.width, chart.height);
                    ctx2.restore();
                }
            }, {
                id: "anCornerTrianglePlugin",
                afterDatasetsDraw: (chart) => {
                    const meta = chart.getDatasetMeta(0);
                    if(!meta || !meta.data) return;
                    const ctx2 = chart.ctx;
                    const TRI = 12;
                    meta.data.forEach((bar, i) => {
                        if(!glowFlags[i]) return;
                        const { x, y, base, height } = bar.getProps(["x","y","base","height"], true);
                        const barRight = Math.max(x, base);
                        const barTop   = y - (height || 16) / 2;
                        ctx2.save();
                        ctx2.beginPath();
                        ctx2.moveTo(barRight, barTop);
                        ctx2.lineTo(barRight - TRI, barTop);
                        ctx2.lineTo(barRight, barTop + TRI);
                        ctx2.closePath();
                        ctx2.fillStyle = "#39ff14";
                        ctx2.fill();
                        ctx2.restore();
                    });
                }
            }]
        });

        chartInstances.push(chart);


        // ── Summary table + pie charts below the Gantt ───────────────────────
        const totalBarsThisYear = Object.values(colorCounts)
            .filter((_, i) => Object.keys(colorCounts).indexOf(Object.keys(colorCounts)[i]) >= 8 && Object.keys(colorCounts).indexOf(Object.keys(colorCounts)[i]) < 16)
