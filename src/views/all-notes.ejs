<%- include ('partials/header.ejs') %>

<!-- Techy CSS layer — overrides Bootstrap/Bootswatch visuals, keeps Bootstrap JS -->
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<style>
/* ════════════════════════════════════════════════════════
   CSS CUSTOM PROPERTIES — dark (default) & light themes
   ════════════════════════════════════════════════════════ */
:root {
    --an-bg:           #0a0e14;
    --an-panel:        #111820;
    --an-panel2:       #161e28;
    --an-border:       #1e2d3d;
    --an-accent:       #00c8ff;
    --an-accent2:      #ff6b35;
    --an-text:         #c8d8e8;
    --an-text-dim:     #5a7080;
    --an-text-bright:  #e8f4ff;
    --an-mono:         'Share Tech Mono', monospace;
    --an-sans:         'Barlow', sans-serif;
    --an-cond:         'Barlow Condensed', sans-serif;
    /* status colours (same in both themes) */
    --an-red:    #ff4060;
    --an-yellow: #ffd060;
    --an-green:  #39ff14;
    --an-purple: #c084fc;
}
body.light-mode {
    --an-bg:          #f0f4f8;
    --an-panel:       #ffffff;
    --an-panel2:      #e8edf2;
    --an-border:      #c8d4de;
    --an-accent:      #0077a8;
    --an-accent2:     #c04010;
    --an-text:        #2c3e50;
    --an-text-dim:    #607080;
    --an-text-bright: #111820;
}

/* ════════════════════════════════════════════════════════
   GLOBAL RESET / BASE
   ════════════════════════════════════════════════════════ */
*, *::before, *::after { box-sizing: border-box; }

body {
    background: var(--an-bg) !important;
    color: var(--an-text) !important;
    font-family: var(--an-sans) !important;
    font-size: 13px;
    min-height: 100vh;
    overflow-x: hidden;
    transition: background .25s, color .25s;
}

/* scanline grid — dark only */
body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
        linear-gradient(rgba(0,200,255,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,200,255,.025) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
    opacity: 1;
    transition: opacity .25s;
}
body.light-mode::before { opacity: 0; }

/* everything above the grid */
body > *, #navbar, .container_, .row, .accordion { position: relative; z-index: 1; }
/* Navbar must sit above all page content so dropdowns are never obscured */
#navbar { z-index: 1050 !important; }
.navbar { z-index: 1050 !important; }
.navbar .dropdown-menu { z-index: 1060 !important; }

/* ════════════════════════════════════════════════════════
   NAVBAR  (Bootstrap nav — keep structure, restyle)
   ════════════════════════════════════════════════════════ */
.navbar, .navbar.bg-dark, nav.navbar {
    background: var(--an-panel) !important;
    border-bottom: 1px solid var(--an-border) !important;
    padding: 6px 16px !important;
    font-family: var(--an-cond) !important;
}
.navbar-brand, .nav-link {
    color: var(--an-text) !important;
    font-family: var(--an-cond) !important;
    font-size: 12px !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
}
.nav-link:hover, .nav-link:focus {
    color: var(--an-accent) !important;
}
.navbar-toggler {
    border-color: var(--an-border) !important;
}
.navbar-toggler-icon {
    filter: invert(.7);
}

/* ════════════════════════════════════════════════════════
   PAGE HEADING AREA
   ════════════════════════════════════════════════════════ */
#greeting {
    font-family: var(--an-cond) !important;
    font-size: 22px !important;
    font-weight: 700 !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    color: var(--an-text-bright) !important;
    margin: 10px 0 2px !important;
}
#greeting ~ p {
    font-family: var(--an-mono) !important;
    font-size: 10px !important;
    color: var(--an-accent) !important;
    letter-spacing: 1px !important;
    margin: 0 0 10px !important;
}

/* canvas override (header.ejs sets background-color:#1e1e1e) */
canvas {
    background-color: transparent !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin-bottom: 0 !important;
    border-radius: 0 !important;
}

/* ════════════════════════════════════════════════════════
   BUTTONS
   ════════════════════════════════════════════════════════ */
.btn {
    font-family: var(--an-cond) !important;
    font-size: 11px !important;
    font-weight: 700 !important;
    letter-spacing: 1.5px !important;
    text-transform: uppercase !important;
    border-radius: 3px !important;
    padding: 6px 14px !important;
    transition: all .15s !important;
}
.btn-warning {
    background: transparent !important;
    border: 1px solid var(--an-accent) !important;
    color: var(--an-accent) !important;
}
.btn-warning:hover {
    background: var(--an-accent) !important;
    color: var(--an-bg) !important;
}
.btn-info {
    background: transparent !important;
    border: 1px solid var(--an-accent2) !important;
    color: var(--an-accent2) !important;
}
.btn-info:hover {
    background: var(--an-accent2) !important;
    color: #fff !important;
}
.btn-primary {
    background: transparent !important;
    border: 1px solid #79c0ff !important;
    color: #79c0ff !important;
}
.btn-primary:hover {
    background: #79c0ff !important;
    color: var(--an-bg) !important;
}
.btn-danger {
    background: transparent !important;
    border: 1px solid var(--an-red) !important;
    color: var(--an-red) !important;
}
.btn-danger:hover {
    background: var(--an-red) !important;
    color: #fff !important;
}

/* ════════════════════════════════════════════════════════
   ACCORDION
   ════════════════════════════════════════════════════════ */
.accordion-item,
.accordion-item.bg-dark {
    background: var(--an-panel) !important;
    border: 1px solid var(--an-border) !important;
    border-radius: 4px !important;
    margin-bottom: 6px !important;
    overflow: hidden;
}
.accordion-header,
.accordion-header.bg-dark {
    background: transparent !important;
}
.accordion-button,
.accordion-button.bg-dark,
.accordion-button.bg-dark_ {
    background: var(--an-panel) !important;
    color: var(--an-text-bright) !important;
    border: none !important;
    font-family: var(--an-cond) !important;
    font-size: 13px !important;
    letter-spacing: 1px !important;
    padding: 10px 14px !important;
    transition: background .15s !important;
    box-shadow: none !important;
}
/* override the inline black bg on Execution */
#execAccordionBtn {
    background: #0d0a1a !important;
    border-left: 3px solid var(--an-red) !important;
}
.accordion-button:not(.collapsed),
.accordion-button:not(.collapsed).bg-dark {
    background: var(--an-panel2) !important;
    color: var(--an-accent) !important;
    box-shadow: none !important;
}
.accordion-button::after {
    filter: invert(.5) sepia(1) saturate(3) hue-rotate(165deg);
}
.accordion-body,
.accordion-body.bg-dark {
    background: var(--an-bg) !important;
    border-top: 1px solid var(--an-border) !important;
    padding: 12px 14px !important;
}
/* section number badge on accordion buttons */
.accordion-button .an-num {
    font-family: var(--an-mono);
    font-size: 8px;
    color: var(--an-accent);
    background: rgba(0,200,255,.1);
    border: 1px solid rgba(0,200,255,.3);
    padding: 2px 5px;
    border-radius: 2px;
    margin-right: 8px;
}

/* h4 titles inside accordion buttons */
.accordion-button h4 {
    font-family: var(--an-cond) !important;
    font-size: 14px !important;
    font-weight: 700 !important;
    letter-spacing: 1.5px !important;
    text-transform: uppercase !important;
    margin: 0 !important;
    line-height: 1.2 !important;
}
/* keep the existing inline h4 colors but make them glow subtly */
.accordion-button h4[style*="color:aqua"],
.accordion-button h4[style*="color: aqua"]  { text-shadow: 0 0 8px #00c8ff88; }
.accordion-button h4[style*="color:chartreuse"],
.accordion-button h4[style*="color: chartreuse"] { text-shadow: 0 0 8px #39ff1488; }
.accordion-button h4[style*="color: orange"],
.accordion-button h4[style*="color:orange"]  { text-shadow: 0 0 8px #ff6b3588; }
.accordion-button h4[style*="color:red"],
.accordion-button h4[style*="color: red"]    { text-shadow: 0 0 8px #ff406088; }
.accordion-button h4[style*="color: white"],
.accordion-button h4[style*="color:white"]   { text-shadow: 0 0 8px #ffffff44; }

/* ════════════════════════════════════════════════════════
   TABLES
   ════════════════════════════════════════════════════════ */
.table, .table-dark {
    --bs-table-bg:          var(--an-panel) !important;
    --bs-table-striped-bg:  var(--an-panel2) !important;
    --bs-table-hover-bg:    rgba(0,200,255,.06) !important;
    --bs-table-color:       var(--an-text) !important;
    --bs-table-border-color:var(--an-border) !important;
    color: var(--an-text) !important;
    border-color: var(--an-border) !important;
    font-family: var(--an-mono) !important;
    font-size: 11px !important;
}
.table th {
    font-family: var(--an-cond) !important;
    font-size: 10px !important;
    font-weight: 700 !important;
    letter-spacing: 1px !important;
    text-transform: uppercase !important;
    color: var(--an-text-dim) !important;
    border-color: var(--an-border) !important;
    padding: 6px 8px !important;
}
/* Default panel background only for th WITHOUT an inline background-color */
.table th:not([style*="background"]) {
    background: var(--an-panel2) !important;
}
.table td {
    border-color: var(--an-border) !important;
    padding: 5px 8px !important;
    vertical-align: middle !important;
}
/* Status header th: let inline background-color show, just fix font */
.table th[style*="background-color"] {
    font-family: var(--an-cond) !important;
    font-size: 9px !important;
    letter-spacing: 1px !important;
    background-color: unset;   /* allow inline to win */
}
/* Force each status background-color through — inline styles need !important to beat Bootstrap */
.table th[style*="background-color:#4caf50"] { background-color:#4caf50 !important; color:#020202 !important; }
.table th[style*="background-color:#B11FDF"] { background-color:#B11FDF !important; color:#ffffff !important; }
.table th[style*="background-color:#0084c7"] { background-color:#0084c7 !important; color:#020202 !important; }
.table th[style*="background-color:#ffff00"] { background-color:#ffff00 !important; color:#020202 !important; }
.table th[style*="background-color:#ff4c4c"] { background-color:#ff4c4c !important; color:#ffffff !important; }
.table th[style*="background-color:#37474f"] { background-color:#37474f !important; color:#ffffff !important; }
.table th[style*="background-color:#C0C0C0"],
.table th[style*="background-color:#c0C0C0"] { background-color:#C0C0C0 !important; color:#020202 !important; }
.table th[style*="background-color:#c0392b"] { background-color:#c0392b !important; color:#ffffff !important; }
/* Need Info - also handle old #000000 just in case */
.table th[style*="background-color:#000000"],
.table th[style*="background-color: #000000"] { background-color:#37474f !important; color:#ffffff !important; }
/* table rows with inline white color */
tr[style*="color: white"],
tr[style*="color:white"] { color: var(--an-text) !important; }

/* ════════════════════════════════════════════════════════
   CHART DIV & GANTT AREA
   ════════════════════════════════════════════════════════ */
#chartDiv {
    background: var(--an-bg) !important;
    border: 1px solid var(--an-border);
    border-radius: 4px;
    padding: 12px;
    margin-top: 8px;
}

/* ════════════════════════════════════════════════════════
   PIE CHARTS
   ════════════════════════════════════════════════════════ */
.pie-row {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 16px;
}
.pie-chart {
    max-width: 300px;
    max-height: 300px;
    background: var(--an-panel);
    border-radius: 8px;
    border: 1px solid var(--an-border);
}

/* ════════════════════════════════════════════════════════
   COMPILED SUMMARY — title
   ════════════════════════════════════════════════════════ */
#compiledSummaryDiv h4 {
    font-family: var(--an-cond) !important;
    letter-spacing: 2px !important;
    text-transform: uppercase !important;
    color: var(--an-accent) !important;
}

/* ════════════════════════════════════════════════════════
   THEME TOGGLE SWITCH
   ════════════════════════════════════════════════════════ */
.an-theme-wrap {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: 12px;
    vertical-align: middle;
    background: var(--an-panel);
    border: 1px solid var(--an-border);
    border-radius: 20px;
    padding: 3px 10px;
    transition: background .25s, border-color .25s;
}
.an-theme-wrap .bi-moon-stars-fill { color: var(--an-accent); }
.an-theme-wrap .bi-sun-fill        { color: var(--an-accent2); }
/* Bootstrap switch colours */
.form-check-input:checked {
    background-color: var(--an-accent) !important;
    border-color:     var(--an-accent) !important;
}

/* ════════════════════════════════════════════════════════
   LIGHT MODE OVERRIDES
   (anything Bootstrap hardcodes that can't use variables)
   ════════════════════════════════════════════════════════ */
body.light-mode canvas { background-color: transparent !important; }
body.light-mode .accordion-button::after {
    filter: invert(1) grayscale(1) brightness(0.3);
}
body.light-mode #execAccordionBtn {
    background: #1a2535 !important;
    border-left: 3px solid #e74c3c !important;
}
body.light-mode .accordion-button h4[style*="color: white"],
body.light-mode .accordion-button h4[style*="color:white"] { color: var(--an-text) !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color:aqua"],
body.light-mode .accordion-button h4[style*="color: aqua"] { color: #0077a8 !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color:chartreuse"],
body.light-mode .accordion-button h4[style*="color: chartreuse"] { color: #2e7d32 !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color: grey"],
body.light-mode .accordion-button h4[style*="color:grey"]  { color: #546e7a !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color: orange"],
body.light-mode .accordion-button h4[style*="color:orange"] { color: #e65100 !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color: blue"],
body.light-mode .accordion-button h4[style*="color:blue"]  { color: #1565c0 !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color: black"],
body.light-mode .accordion-button h4[style*="color:black"] { color: #212529 !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color: blueviolet"],
body.light-mode .accordion-button h4[style*="color:blueviolet"] { color: #6a1b9a !important; text-shadow:none !important; }
body.light-mode .accordion-button h4[style*="color:red"],
body.light-mode .accordion-button h4[style*="color: red"] { color: #c62828 !important; text-shadow:none !important; }
body.light-mode [style*="color:chartreuse"],
body.light-mode [style*="color: chartreuse"] { color: #2e7d32 !important; }
body.light-mode h4[style*="color: blue"],
body.light-mode h4[style*="color:blue"]     { color: #1565c0 !important; }
body.light-mode h4[style*="color: blueviolet"],
body.light-mode h4[style*="color:blueviolet"] { color: #6a1b9a !important; }
body.light-mode h4[style*="color:#58a6ff"]  { color: #0056b3 !important; }
body.light-mode h4[style*="color: grey"],
body.light-mode h4[style*="color:grey"]     { color: #546e7a !important; }
body.light-mode tr[style*="color: white"],
body.light-mode tr[style*="color:white"]    { color: var(--an-text) !important; }
body.light-mode tr[style*="background-color: #1a1a1a"],
body.light-mode tr[style*="background-color:#1a1a1a"] { background-color: #2c3e50 !important; }
body.light-mode th[style*="background-color:#000000"],
body.light-mode th[style*="background-color: #000000"] { background-color: #37474f !important; color:#fff !important; }
body.light-mode th[style*="background:#1a1a2e"] { background: #2c3e50 !important; }
body.light-mode th[style*="background-color:#transparent"],
body.light-mode th[style*="background-color: #transparent"] { color: var(--an-text) !important; }
body.light-mode .text-white,
body.light-mode [style*="color: white"],
body.light-mode [style*="color:white"] { color: var(--an-text) !important; }
</style>



<div id="navbar" class="p-2">


    <% if (user.name != 'Guest') { %>

        <% if (user.role == 'admin') { %>
            <%- include ('partials/navigation_Admin.ejs') %>
        <% } %>

        <% if (user.role == 'leader' || user.role == 'user') { %>
            <%- include ('partials/navigation_Leader.ejs') %>
        <% } %>

        <% if (user.role == 'viewer') { %>
            <%- include ('partials/navigation_Leader.ejs') %>
        <% } %>

    <% } %>
</div>


<!-- <pre><%= notes[2].poc %></pre> -->


<div class="container_ p-4">

    <%- include ('avatar.ejs') %>

    <h3 id="greeting"><%= user.name %></h3>
    <!-- <p style="color: black;"> ID: <%= user.id %></p> -->
      <p style="color: gray;"><%= user.role %></p>
    <!-- <p style="color: gray;"> Role: <%= user.role %> <br> Rank: <%= user.rank %> <br><%= user.list %></p> -->
    <!-- <p style="color: gray;"> <%= user.rank %> <br><%= user.list %></p> -->

    <!-- <h1 style="color: whitesmoke;">Jobs</h1> -->

    <% if (user.role == 'admin' || user.role == 'leader' || user.role == 'user') { %>
        <a class="btn btn-warning my-2" href="/notes/add">+ New Job</a>
        &nbsp;
        <span class="an-theme-wrap" id="anThemeWrap">
            <i class="bi bi-moon-stars-fill" style="font-size:13px;color:#aaa;"></i>
            <div class="form-check form-switch m-0" style="min-height:unset;">
                <input class="form-check-input" type="checkbox" role="switch" id="anThemeSwitch" style="cursor:pointer;">
            </div>
            <i class="bi bi-sun-fill" style="font-size:13px;color:#aaa;"></i>
        </span>
        &nbsp;
        <%- include('partials/fontSwitcher.ejs') %>
        <!-- <pre><%= notes %></pre> -->
         
    <% } %>


    <div class="row">

        <div class="accordion accordion-flush my-4 small" id="accordionExample">





            
            <% if (user.role == 'admin' || user.role == 'leader' || user.role == 'user' || user.role == 'viewer') { %>
                <div class="accordion-item">
                    <h2 class="accordion-header bg-dark">
                        <button class="accordion-button collapsed bg-dark" 
                                type="button" 
                                data-bs-toggle="collapse" 
                                data-bs-target="#collapseOne" 
                                aria-expanded="true" 
                                aria-controls="collapseOne">
                            <h4 style="color: white;">Not Started</h4>
                        </button>
                    </h2>
                    <div id="collapseOne" class="accordion-collapse collapse show_" data-bs-parent="#accordionExample">
                        <div class="accordion-body bg-dark">

                            <h4>BlackOps Queue</h4>

                            <table class="table table-hover _table-striped table-dark table-sm" _style="color: red;" id="InBlackOpsQueueTable">
                                <thead>
                                    <tr>
                                        <th scope="col">ID</th>
                                        <th scope="col">Q</th>
                                        <th scope="col">Task</th>
                                        <th scope="col">Vers.</th>
                                        <th scope="col">Project</th>
                                        <th scope="col">Area</th>
                                        <th scope="col">Wells</th>
                                        <!-- <th scope="col">Budget</th> -->
                                        <th scope="col">D.E</th>
                                        <th scope="col">Geo</th>
                                        <th scope="col">Rig</th>
                                        <!-- <th scope="col">Resp.</th> -->
                                        <!-- <th scope="col">Created</th> -->
                                        <th scope="col">Due</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% notes.forEach(note => { %>

                                        <% if (user.role == 'admin' || user.role == 'leader' || user.name == note.responsible || user.list == note.customer) { %> 

                                            <% if (note.status == 'Not Started' && note.title == "BlackOps") { %>

                                                <tr onclick="window.location.href='/notes/job/<%= note._id %>';">

                                                    <% if (note.title == "Execution") { %>
                                                        <tr style="color: green;" onclick="window.location.href='/notes/job/<%= note._id %>';">
                                                    <% } %>  
                                                    <% if (note.responsible == "Orphan") { %>
                                                        <tr style="color: white;" onclick="window.location.href='/notes/job/<%= note._id %>';">
                                                    <% } %>   
                                                    <% if (user.name == note.responsible) { %>
                                                        <tr style="color: red;" onclick="window.location.href='/notes/job/<%= note._id %>';">
                                                    <% } %>

                                                    <th scope="row">
                                                        <% if (user.role == 'admin') { %>
                                                            <% if (note.responsible == "Camilo") { %>
                                                                <span class="dotCamilo"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Isabel") { %>
                                                                <span class="dotIsabel"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Johanna") { %>
                                                                <span class="dotJohanna"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Daniel") { %>
                                                                <span class="dotDaniel"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Pablo") { %>
                                                                <span class="dotPablo"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Sammy") { %>
                                                                <span class="dotSammy"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Polita") { %>
                                                                <span class="dotPolita"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "John") { %>
                                                                <span class="dotJohn"></span>
                                                            <% } %>
                                                            <% if (note.responsible == "Orphan") { %>
                                                                <span class="dotOrphan"></span>
                                                            <% } %>
                                                        <% } %> 

