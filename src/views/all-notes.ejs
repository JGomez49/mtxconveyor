        const tyKeys = ["greenThisYear","purpleThisYear","blueThisYear","yellowThisYear","redThisYear","blackThisYear","silverThisYear","whiteThisYear"];
        const nyKeys = ["greenNextYear","purpleNextYear","blueNextYear","yellowNextYear","redNextYear","blackNextYear","silverNextYear","whiteNextYear"];
