<!-- ganttNotesMap data: stored in a non-executable script tag so special
     characters in project names cannot break the surrounding JS -->
<script type="application/json" id="ganttNotesMapData"><%- JSON.stringify(notes.reduce((m,n)=>{ if(n.project){ m[n.project.slice(0,14)]={ id:String(n._id), de:String(n.poc||'') }; } return m; },{})) %></script>

<!-- Script to generate the Charts -->

<script>
    // Build project→noteId lookup — data comes from a hidden DOM element
    // to avoid any risk of special characters breaking the script block.
    const ganttNotesMap = JSON.parse(
        document.getElementById('ganttNotesMapData').textContent
    );

    document.addEventListener("DOMContentLoaded", function() {
        renderDPStatsBoxPlot();
        renderChartsFromTable();
    });
</script>



<script>

    let chartInstances = [];
    let compiledRows   = []; // accumulates one entry per VP+group for the compiled summary table

    // Site-key Sets — populated each time renderChartsFromTable runs,
    // used by ganttRenderChart to override bar colours.
    let inProgressSites     = new Set();
    let inSetupQueueSites   = new Set();
    let inDesignQueueSites  = new Set();
    let inBlackOpsQueueSites = new Set();

    function parseDate(value) {
        const parsed = Date.parse(value);
        if (!isNaN(parsed)) return new Date(parsed);
        return null;
    }

    // Theme-aware color helpers for Chart.js (pie charts)
    function anIsLight(){ return document.body.classList.contains('light-mode'); }
    function anChartColor(){ return anIsLight() ? '#333' : '#fff'; }
    function anChartBg(){   return anIsLight() ? '#f8f9fa' : 'transparent'; }
    function anGridColor(){  return anIsLight() ? '#ccc' : '#333'; }

    // ── Gantt filter state ────────────────────────────────────────────────
    let ganttAllBars   = [];   // flat array of all bar objects parsed from csvTable
    let ganttFiltersBuilt = false;

    // Default selections (everything on except VP and Group which have specific defaults)
    const GANTT_DEFAULTS = {
        gfVP:        ['Gillian Lefebure'],
        gfGroup:     ['BV'],
    };

    function ganttBuildFilterGroup(containerId, fieldKey, values, defaultFn){
        const el = document.getElementById(containerId);
        if(!el) return;
        el.innerHTML = '';

        // ── All / None toggle ──────────────────────────────────────────────
        const toggleWrap = document.createElement('div');
        toggleWrap.style.cssText = 'display:flex;gap:6px;margin-bottom:4px;';

        const makeToggle = (label, selectAll) => {
            const btn = document.createElement('span');
            btn.textContent = label;
            btn.style.cssText = 'font-size:9px;cursor:pointer;color:var(--an-accent,#00c8ff);letter-spacing:.5px;text-transform:uppercase;';
            btn.addEventListener('click', () => {
                el.querySelectorAll('input[type=checkbox]').forEach(cb => { cb.checked = selectAll; });
                ganttApplyAndRender();
            });
            return btn;
        };
        toggleWrap.appendChild(makeToggle('All', true));
        const sep = document.createElement('span');
        sep.textContent = '·';
        sep.style.cssText = 'font-size:9px;color:var(--an-text-dim,#5a7080);';
        toggleWrap.appendChild(sep);
        toggleWrap.appendChild(makeToggle('None', false));
        el.appendChild(toggleWrap);
        // ──────────────────────────────────────────────────────────────────

        [...values].sort().forEach(v => {
            const lbl = document.createElement('label');
            const cb  = document.createElement('input');
            cb.type = 'checkbox';
            cb.value = v;
            cb.dataset.gfield = fieldKey;
            cb.checked = defaultFn(v);
            cb.addEventListener('change', ganttApplyAndRender);
            lbl.appendChild(cb);
            lbl.appendChild(document.createTextNode(v));
            el.appendChild(lbl);
        });
    }

    function ganttBuildAllFilters(){
        // uniqWithBlank: like uniq() but also adds a "Blank" sentinel if any bar
        // has an empty/null/undefined value for that field. This ensures bars with
        // no value are always represented in the filter and included by default.
        const uniqWithBlank = f => {
            const vals = new Set(ganttAllBars.map(b => b[f]).filter(Boolean));
            if(ganttAllBars.some(b => !b[f] || String(b[f]).trim() === "")) vals.add("Blank");
            return [...vals];
        };

        const defaultAll  = () => true;
        const defaultVP   = v => GANTT_DEFAULTS.gfVP.includes(v);
        const defaultGrp  = v => GANTT_DEFAULTS.gfGroup.includes(v);

        ganttBuildFilterGroup('gfVP',        'vp',        uniqWithBlank('vp'),        defaultVP);
        ganttBuildFilterGroup('gfGroup',     'group',     uniqWithBlank('group'),     defaultGrp);
        ganttBuildFilterGroup('gfType',      'type',      uniqWithBlank('type'),      defaultAll);
        ganttBuildFilterGroup('gfDpCompany', 'dpCompany', uniqWithBlank('dpCompany'), defaultAll);
        ganttBuildFilterGroup('gfDrillOK',   'drillok',   uniqWithBlank('drillok'),   defaultAll);
        ganttBuildFilterGroup('gfGeoOK',     'geook',     uniqWithBlank('geook'),     defaultAll);
        ganttBuildFilterGroup('gfRig',       'rig',       uniqWithBlank('rig'),       defaultAll);
        ganttBuildFilterGroup('gfDE',        'de',        uniqWithBlank('de'),        defaultAll);

        ganttFiltersBuilt = true;

        const resetBtn = document.getElementById('ganttResetBtn');
        if(resetBtn && !resetBtn.dataset.wired){
            resetBtn.dataset.wired = '1';
            resetBtn.addEventListener('click', () => {
                ganttBuildAllFilters();
                ganttApplyAndRender();
            });
        }
    }

    function ganttGetChecked(fieldKey){
        return [...document.querySelectorAll(
            `#ganttSidebar input[type=checkbox][data-gfield="${fieldKey}"]:checked`
        )].map(cb => cb.value);
    }

    function ganttApplyAndRender(){
        const fVP        = ganttGetChecked('vp');
        const fGroup     = ganttGetChecked('group');
        const fType      = ganttGetChecked('type');
        const fDpCompany = ganttGetChecked('dpCompany');
        const fDrillOK   = ganttGetChecked('drillok');
        const fGeoOK     = ganttGetChecked('geook');
        const fRig       = ganttGetChecked('rig');
        const fDE        = ganttGetChecked('de');

        // Map empty values to "Blank" sentinel so bars with missing fields
        // are correctly matched against the "Blank" checkbox when checked.
        const blanked = f => v => !v || String(v).trim() === '' ? 'Blank' : v;
        const filtered = ganttAllBars.filter(b =>
            fVP.includes(blanked()(b.vp)) &&
            fGroup.includes(blanked()(b.group)) &&
            fType.includes(blanked()(b.type)) &&
            fDpCompany.includes(blanked()(b.dpCompany)) &&
            fDrillOK.includes(blanked()(b.drillok)) &&
            fGeoOK.includes(blanked()(b.geook)) &&
            fRig.includes(blanked()(b.rig)) &&
            fDE.includes(blanked()(b.de))
        );

        ganttRenderChart(filtered);
    }

    function renderChartsFromTable() {
        const table = document.getElementById("csvTable");
        if(!table) return;
        const rows = Array.from(table.querySelectorAll("tbody tr"));

        // ── Build site-key Sets from the status queue tables ─────────────────
        // These are used by ganttRenderChart to override bar colours based on
        // which accordion table (In Progress, Setup Queue, etc.) a site appears in.
        function buildSiteSet(tableId){
            const t = document.getElementById(tableId);
            if(!t) return new Set();
            const s = new Set();
            t.querySelectorAll("tbody tr").forEach(r => {
                const projCell = r.cells[4]; // "Project" column = index 4 (ID,Q,Task,Vers.,Project)
                if(projCell) s.add(projCell.innerText.trim().slice(0, 14));
            });
            return s;
        }
        inProgressSites    = buildSiteSet("InProgressTable");
        inSetupQueueSites  = new Set([
            ...buildSiteSet("InSetupQueueTable"),
            ...buildSiteSet("InSetupQueueNoGroupTable")
        ]);
        inDesignQueueSites = new Set([
            ...buildSiteSet("InDesignQueueTable"),
            ...buildSiteSet("InDesignQueueNoGroupTable")
        ]);
        inBlackOpsQueueSites = buildSiteSet("InBlackOpsQueueTable");

        // ── Parse all rows into flat array ──────────────────────────────────
        compiledRows = [];
        ganttAllBars = [];

        rows.forEach(row => {
            const cells = row.querySelectorAll("td");
            const rig       = cells[0]?.innerText.trim();
            const drillok   = cells[1]?.innerText.trim();
            const geook     = cells[2]?.innerText.trim();
            const dp        = cells[3]?.innerText.trim();
            const type      = cells[4]?.innerText.trim();
            const duration  = Number(cells[5]?.innerText.trim() || 0);
            const vp        = cells[6]?.innerText.trim();
            const start     = parseDate(cells[7]?.innerText.trim());
            const site      = cells[8]?.innerText.trim();
            const well      = cells[9]?.innerText.trim();
            const dpCompany = cells[10]?.innerText.trim();
            const ETS       = cells[11]?.innerText.trim();
            const group     = cells[12]?.innerText.trim().substring(0, 2);
            const dpReq     = cells[13]?.innerText.trim();
            const geo       = cells[14]?.innerText.trim();
            const version   = cells[15]?.innerText.trim();

            if(!rig) return;

            ganttAllBars.push({ rig, drillok, geook, dp, type, duration,
                vp, start, site, well, dpCompany, ETS, group, dpReq, geo, version,
                de: (ganttNotesMap[site.slice(0,14)] || {}).de || '' });
        });

        // Build filters once
        if(!ganttFiltersBuilt) ganttBuildAllFilters();

        // Render chart with current filter state
        ganttApplyAndRender();
    }

    function ganttRenderChart(bars){
        const chartDiv = document.getElementById("chartDiv");
        if(!chartDiv) return;
        chartDiv.innerHTML = "";

        // Clear previous Chart.js instances
        chartInstances.forEach(ch => { try{ ch.destroy(); }catch(e){} });
        chartInstances = [];

        if(!bars.length){
            chartDiv.innerHTML = '<p style="color:var(--an-text-dim,#5a7080);padding:20px;">No data matches the selected filters.</p>';
            return;
        }

        const today = new Date();
        const sevenMonthsLater  = new Date(today.getFullYear(), today.getMonth() + 7,  today.getDate());
        const threeMonthsLater  = new Date(today.getFullYear(), today.getMonth() + 3,  today.getDate());
        const fiveMonthsLater   = new Date(today.getFullYear(), today.getMonth() + 5,  today.getDate());
        const oneYearLater      = new Date(today.getFullYear() + 1, today.getMonth(), today.getDate());
        const FixedEndOfLastYear= new Date("2025-12-31");
        const FixedEndOfThisYear= new Date("2026-12-31");
        const FixedEndOfNextYear= new Date("2027-12-31");
        const TargetDate        = new Date("2026-08-31");

        // Collect unique rigs from filtered bars, alphabetical
        const rigSet = [...new Set(bars.filter(b => b.start).map(b => b.rig))].sort();

        const datasets   = [];
        const colors     = [];
        const glowFlags  = [];
        const colorOfBorder = "#000000";
        const colorCounts = {
            blue:0, red:0, green:0, yellow:0, purple:0, white:0, black:0, silver:0,
            blueThisYear:0, redThisYear:0, greenThisYear:0, yellowThisYear:0,
            purpleThisYear:0, whiteThisYear:0, blackThisYear:0, silverThisYear:0,
            blueNextYear:0, redNextYear:0, greenNextYear:0, yellowNextYear:0,
            purpleNextYear:0, whiteNextYear:0, blackNextYear:0, silverNextYear:0,
        };

        bars.forEach(siteObj => {
            if(!siteObj.start || isNaN(siteObj.start)) return;
            const start   = new Date(siteObj.start);
            const end     = new Date(siteObj.start.getTime() + siteObj.duration * 86400000);
            const dpValue = siteObj.dp || "";
            const type    = siteObj.type;
            const drillok = siteObj.drillok;
            const geook   = siteObj.geook;
            const rig     = siteObj.rig;
            const dpReq   = siteObj.dpReq;

            const siteKey = siteObj.site.slice(0, 14);
            const isInProgressTable    = inProgressSites.has(siteKey);
            const isInSetupQueueTable  = inSetupQueueSites.has(siteKey);
            const isInDesignQueueTable = inDesignQueueSites.has(siteKey);
            const isInBlackOpsQueueTable = inBlackOpsQueueSites.has(siteKey);

            datasets.push({
                y: rig,
                x: [siteObj.start, end],
                site: siteObj.site.substring(0, 5),
                details: {
                    Rig: rig, drillok, geook, VP: siteObj.vp,
                    Start: siteObj.start.toLocaleDateString(),
                    Duration: siteObj.duration, DP: dpValue,
                    Site: siteObj.site, Well: siteObj.well,
                    dpCompany: siteObj.dpCompany, ETS: siteObj.ETS,
                    type, group: siteObj.group, dpReq, geo: siteObj.geo,
                    version: siteObj.version,
                    DE: (ganttNotesMap[siteObj.site.slice(0,14)] || {}).de || '',
                }
            });

            const rigToAvoid = ["PRECISION 183","PRECISION183","PD183","PD 183"];
            const dpNo  = !dpValue || dpValue === "NO" || dpValue === "NO-DP" || dpValue === "";
            const dpYes = dpValue === "YES" || dpValue === "YES-DP" || dpValue !== "";

            const countable          = start >= today && start <= oneYearLater;
            const countableForThisYear = start > FixedEndOfLastYear && start <= FixedEndOfThisYear;
            const countableForNextYear = start > FixedEndOfThisYear && start <= FixedEndOfNextYear;

            const isForcedInProgress    = isInProgressTable === true;
            const isForcedInSetupQueue  = isInSetupQueueTable === true;
            const isForcedInDesignQueue = isInDesignQueueTable === true;
            const isForcedInBlackOpsQueue = isInBlackOpsQueueTable === true;

            // Build compiledRows for the VP summary table
            const vpKey = siteObj.vp + '|' + siteObj.group;

            switch(true){
                case type === "FINAL":
                    colors.push("#4caf50");
                    if(countable) colorCounts.green++;
                    if(countableForThisYear) colorCounts.greenThisYear++;
                    if(countableForNextYear) colorCounts.greenNextYear++;
                    break;
                case isForcedInProgress:
                    colors.push("#ffff00");
                    if(countable) colorCounts.yellow++;
                    if(countableForThisYear) colorCounts.yellowThisYear++;
                    if(countableForNextYear) colorCounts.yellowNextYear++;
                    break;
                case isForcedInSetupQueue:
                case isForcedInDesignQueue:
                case isForcedInBlackOpsQueue:
                    colors.push("#ff4c4c");
                    if(countable) colorCounts.red++;
                    if(countableForThisYear) colorCounts.redThisYear++;
                    if(countableForNextYear) colorCounts.redNextYear++;
                    break;
                case type === "PRELIM - IR":
                    colors.push("#000000");
                    if(countable) colorCounts.black++;
                    if(countableForThisYear) colorCounts.blackThisYear++;
                    if(countableForNextYear) colorCounts.blackNextYear++;
                    break;
                case (dpNo && !rigToAvoid.includes(rig) && dpReq !== ""):
                    colors.push("#ff4c4c");
                    if(countable) colorCounts.red++;
                    if(countableForThisYear) colorCounts.redThisYear++;
                    if(countableForNextYear) colorCounts.redNextYear++;
                    break;
                case type === "EXEC":
                    colors.push("#B11FDF");
                    if(countable) colorCounts.purple++;
                    if(countableForThisYear) colorCounts.purpleThisYear++;
                    if(countableForNextYear) colorCounts.purpleNextYear++;
                    break;
                case dpYes:
                    colors.push("#0084c7");
                    if(countable) colorCounts.blue++;
                    if(countableForThisYear) colorCounts.blueThisYear++;
                    if(countableForNextYear) colorCounts.blueNextYear++;
                    break;
                case dpReq === "" || dpReq === " ":
                    colors.push("#C0C0C0");
                    if(countable) colorCounts.silver++;
                    if(countableForThisYear) colorCounts.silverThisYear++;
                    if(countableForNextYear) colorCounts.silverNextYear++;
                    break;
                default:
                    colors.push("#FFFFFF");
                    if(countable) colorCounts.white++;
                    if(countableForThisYear) colorCounts.whiteThisYear++;
                    if(countableForNextYear) colorCounts.whiteNextYear++;
                    break;
            }

            const isFullyApproved =
                String(drillok).trim().toUpperCase() === "YES-DRILL" &&
                String(geook).trim().toUpperCase() === "YES-GEO";
            glowFlags.push(isFullyApproved);
        });

        // ── Gantt chart ──────────────────────────────────────────────────────
        const minDate     = new Date(today.getFullYear(), today.getMonth(), today.getDate() - 7);
        const defaultMax  = new Date(today.getFullYear(), today.getMonth() + 5, today.getDate()); // default visible window
        const absoluteMax = new Date(today.getFullYear() + 2, today.getMonth(), today.getDate()); // full range for zoom/pan

        const canvasH = Math.max(200, rigSet.length * 40);
        const canvasW = chartDiv.parentElement
            ? Math.max(600, chartDiv.parentElement.clientWidth - 20)
            : 1200;

        // Wrap in a fixed-size div so responsive:false + zoom don't cause
        // an infinite resize loop
        const canvasWrap = document.createElement("div");
        canvasWrap.style.cssText = `width:${canvasW}px;height:${canvasH}px;position:relative;overflow:hidden;`;
        chartDiv.appendChild(canvasWrap);

        const canvas = document.createElement("canvas");
        canvas.width  = canvasW;
        canvas.height = canvasH;
        canvasWrap.appendChild(canvas);

        const ctx = canvas.getContext("2d");
        const chart = new Chart(ctx, {
            type: "bar",
            data: {
                datasets: [{
                    label: "Schedule",
                    data: datasets,
                    backgroundColor: colors,
                    borderRadius: 6,
                    borderSkipped: false,
                    borderColor: colorOfBorder,
                    borderWidth: 1,
                    parsing: { xAxisKey: "x", yAxisKey: "y" },
