                            }
                        }
                    },
                    datalabels: {
                        color: (ctx) => {
                            const bg = ctx.dataset.backgroundColor[ctx.dataIndex] || "#000";
                            const lightBgs = ["#ffff00","#C0C0C0","#FFFFFF","#ffffff","#c0c0c0"];
                            return lightBgs.some(c => bg.toLowerCase() === c.toLowerCase()) ? "#000000" : "#ffffff";
                        },
                        font: { size: 10, weight: "bold" },
                        formatter: (value) => value.site || "",
                        anchor: "start", align: "end", clip: true,
                    },
                    annotation: {
                        annotations: {
                            redBand: {
                                type: "box", xMin: today, xMax: threeMonthsLater,
                                backgroundColor: "rgba(255,0,0,0.10)", borderWidth: 0,
                                drawTime: "beforeDatasetsDraw",
                            },
                            yellowBand: {
                                type: "box", xMin: threeMonthsLater, xMax: fiveMonthsLater,
                                backgroundColor: "rgba(255,208,0,0.10)", borderWidth: 0,
                                drawTime: "beforeDatasetsDraw",
                            },
                            todayLine: {
                                type: "line", xMin: today, xMax: today,
                                borderColor: "red", borderWidth: 2,
                                label: { enabled: true, content: "Today", position: "start", color: "red" },
                            },
                            threeMonthLine: {
                                type: "line", xMin: threeMonthsLater, xMax: threeMonthsLater,
                                borderColor: "red", borderWidth: 3, borderDash: [],
                                label: { enabled: true, content: "+3 Months", position: "start", color: "red" },
                            },
                            // Jan 1 lines — one per year from this year to absoluteMax year
                            ...Object.fromEntries(
                                Array.from({ length: 3 }, (_, i) => {
                                    const yr = today.getFullYear() + i;
                                    const jan1 = new Date(yr, 0, 1);
                                    return [`jan1_${yr}`, {
                                        type: "line", xMin: jan1, xMax: jan1,
                                        borderColor: "#00c8ff", borderWidth: 1, borderDash: [],
                                        label: { enabled: true, content: `Jan ${yr}`, position: "start", color: "#00c8ff", font: { size: 10 } },
                                    }];
