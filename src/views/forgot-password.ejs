<%- include ('partials/header.ejs') %>

<style>
    body { background-color: #0a0e14; }
    .fp-wrapper {
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
    }
    .fp-card {
        background: #111820; border: 1px solid #1e2d3d; border-radius: 8px;
        padding: 28px; max-width: 440px; width: 100%;
    }
</style>

<div class="fp-wrapper">
    <div class="fp-card">
        <h4 style="color:#e8f4ff;font-family:monospace;">🔑 Forgot Password</h4>

        <% if (error) { %>
            <div class="alert alert-danger" style="font-size:13px;"><%= error %></div>
        <% } %>

        <% if (step === 'email') { %>
            <p style="color:#5a7080;font-size:13px;">
                Enter your account email. If you've set up a security question, you'll
                be asked to answer it next.
            </p>
            <form action="/users/forgot-password/lookup" method="post">
                <div class="form-group mb-3">
                    <input type="email" name="email" class="form-control"
                           placeholder="Email" value="<%= email %>" required>
                </div>
                <button class="btn btn-success btn-block">Continue</button>
            </form>
        <% } else if (step === 'answer') { %>
            <form action="/users/forgot-password/reset" method="post">
                <input type="hidden" name="email" value="<%= email %>">
                <div class="form-group mb-3">
                    <label style="color:#c8d8e8;font-size:13px;"><%= question %></label>
                    <input type="text" name="answer" class="form-control" required autofocus>
                </div>
                <div class="form-group mb-3">
                    <label style="color:#c8d8e8;font-size:13px;">New password</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <div class="form-group mb-3">
                    <label style="color:#c8d8e8;font-size:13px;">Confirm new password</label>
                    <input type="password" name="confirm_password" class="form-control" required>
                </div>
                <button class="btn btn-success btn-block">Reset Password</button>
            </form>
        <% } %>

        <div class="text-center mt-3">
            <a href="/users/signin" style="font-size:13px;color:#aaa;">← Back to sign in</a>
        </div>
    </div>
</div>

<%- include ('partials/footer.ejs') %>
