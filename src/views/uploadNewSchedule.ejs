<%- include ('partials/header.ejs') %>

<div class="_container bg-dark">
    <h2 class="pt-4 m-4">New Schedule
        <small style="font-size:11px;color:#00c8ff;font-family:monospace;">
            — uploads every column exactly as-is, no mapping
        </small>
    </h2>
    <p class="mb-4 m-4">USER: <%= user.name %></p>

    <div class="row m-4">
        <div class="card mb-3">
            <div class="card-body">
                <div class="input-group mb-3">
                    <input type="file" accept=".xlsx,.xls,.csv" name="csvFile"
                           class="form-control" id="csvFile">
                </div>
                <div style="font-size:11px;color:#5a7080;">
                    This replaces the entire New Schedule table with whatever is in the file you choose —
                    every column, exactly as uploaded.
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 mb-4">
            <button id="uploadBtn" class="btn btn-success" type="button" disabled>
                ⬆️ Upload New Schedule
            </button>
            <a href="/notes" class="btn btn-primary">← Back</a>
        </div>

        <div id="statusMsg"
             style="color:#00c8ff;font-family:monospace;margin-bottom:12px;white-space:pre-wrap;"></div>

        <div class="accordion mb-4">
            <div class="accordion-item bg-dark border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapsePreview"
                            style="background:#1a1a1a;color:#fff;">
                        📋 Preview (first 50 rows)
                    </button>
                </h2>
                <div id="collapsePreview" class="accordion-collapse collapse">
                    <div class="accordion-body" style="overflow-x:auto;">
                        <table id="previewTable"
                               class="table table-dark table-striped table-bordered table-sm">
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<script>
let _headers = [];
let _rows = [];

function status(msg) {
    document.getElementById('statusMsg').textContent = msg;
    console.log('[uploadNewSchedule]', msg);
}

function toPlain(v) {
    if (v === null || v === undefined) return '';
    if (v instanceof Date) return isNaN(v) ? '' : v.toISOString().split('T')[0];
    return v;
}

function processRawRows(rawRows) {
    if (!rawRows || rawRows.length < 2) {
        status('❌ File appears empty or has only a header row.');
        return;
    }
    _headers = rawRows[0].map(h => String(h || '').trim());
    const dataRows = rawRows.slice(1).filter(r =>
        Array.isArray(r) && r.some(c => String(c ?? '').trim() !== '')
    );
    _rows = dataRows.map(r => _headers.map((_, i) => toPlain(r[i])));

    status(`✅ Parsed ${_rows.length} rows, ${_headers.length} columns. Ready to upload.`);
    renderPreview();
    document.getElementById('uploadBtn').disabled = false;
}

function renderPreview() {
    const table = document.getElementById('previewTable');
    table.innerHTML = '';
    const trh = document.createElement('tr');
    _headers.forEach(h => {
        const th = document.createElement('th');
        th.textContent = h;
        trh.appendChild(th);
    });
    table.appendChild(trh);
    _rows.slice(0, 50).forEach(row => {
        const tr = document.createElement('tr');
        row.forEach(v => {
            const td = document.createElement('td');
            td.textContent = v === null || v === undefined ? '' : v;
            tr.appendChild(td);
        });
        table.appendChild(tr);
    });
}

document.getElementById('csvFile').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    document.getElementById('uploadBtn').disabled = true;
    _headers = []; _rows = [];
    status('Reading file…');
    const ext = file.name.split('.').pop().toLowerCase();
    if (ext === 'xlsx' || ext === 'xls') {
        const reader = new FileReader();
        reader.onload = function(ev) {
            const wb = XLSX.read(ev.target.result, { type: 'array', cellDates: true });
            const ws = wb.Sheets[wb.SheetNames[0]];
            const raw = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
            processRawRows(raw);
        };
        reader.readAsArrayBuffer(file);
    } else {
        const reader = new FileReader();
        reader.onload = function(ev) {
            const wb = XLSX.read(ev.target.result, { type: 'string' });
            const ws = wb.Sheets[wb.SheetNames[0]];
            const raw = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
            processRawRows(raw);
        };
        reader.readAsText(file);
    }
});

document.getElementById('uploadBtn').addEventListener('click', async function() {
    if (!_rows.length) { alert('No data loaded.'); return; }
    status(`Uploading ${_rows.length} rows…`);
    this.disabled = true;
    try {
        const res = await fetch('/notes/uploadNewSchedule', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ headers: _headers, rows: _rows }),
        });
        const data = await res.json();
        if (res.ok) {
            status(`✅ Uploaded ${data.rows} rows, ${data.columns} columns.`);
            alert('✅ New Schedule uploaded successfully!');
            window.location.href = '/notes';
        } else {
            status('❌ Failed: ' + (data.error || res.statusText));
            alert('❌ Upload failed:\n' + (data.error || res.statusText));
            this.disabled = false;
        }
    } catch (err) {
        status('❌ Error: ' + err.message);
        this.disabled = false;
    }
});
</script>

<%- include ('partials/footer.ejs') %>
