
<%- include ('partials/header.ejs') %>

<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/build/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<script>
    document.title =  'ID<%= note.mtxJobId %> - <%= note.customerJobNumber %>';
</script>


    <div id="navbar" class="p-2">

        <% if (user.name !='Guest' ) { %>

            <% if (user.role=='admin' ) { %>
                <%- include ('partials/navigation_Admin.ejs') %>
            <% } %>

            <% if (user.role=='leader' ) { %>
                <%- include ('partials/navigation_Admin.ejs') %>
            <% } %>

            <% if (user.role=='_user' ) { %>
                <%- include ('partials/navigation_Member.ejs') %>
            <% } %>

            <% if (user.role=='viewer' ) { %>
                <%- include ('partials/navigation_Member.ejs') %>
            <% } %>

        <% } %>
    </div>

    <!-- <pre><%= note.createdAt %></pre> -->


    <div class="col-md-12 mx-auto my-4">

        <div class="col -md-6 mx-auto">

            <div class="card">

                <div class="card-header bg-dark">
                    <h2>Edit</h2>
                </div>

                <div class="_container" id="mainContainer">

                    <div class="row m-2">

                        <form action="/upload/<%= note._id %>" method="POST" enctype="multipart/form-data">

                            <div class="card mb-3" style="background-color: #483D8B;">
                                <div class="card-body">
                                    <p class="card-text">Select a picture for ID: <%= note.mtxJobId %></p>
                                    <div class="input-group _mb-2">
                                        <input 
                                            _style="background-color: black;"
                                            type="file" 
                                            name="image" 
                                            class="form-control mb-2 bg-dark text-white" 
                                            id="inputGroupFile02"
                                        >
                                        <div class="input-group mb-2" hidden>
                                            <span class="input-group-text bg-dark text-white">Image URL</span>
                                            <input 
                                                value="<%= note.path %>" 
                                                readonly
                                                type="text"
                                                id="imageURL"
                                                class="form-control bg-dark text-white" 
                                            >
                                        </div>
                                        <div class="input-group mb-2" hidden>
                                            <span class="input-group-text bg-dark text-white">Image Public ID</span>
                                            <input 
                                                value="<%= note.imageID %>" 
                                                readonly
                                                type="text"
                                                id="imageID"
                                                class="form-control bg-dark text-white" 
                                            >
                                        </div>
                                        <div class="input-group mb-2" hidden>
                                            <span class="input-group-text bg-dark text-white">Note Image ID</span>
                                            <input 
                                                value="<%= note.noteImageID %>" 
                                                readonly
                                                type="text"
                                                id="noteImageID"
                                                class="form-control bg-dark text-white" 
                                            >
                                        </div>
                                        <div class="input-group mb-2" hidden>
                                            <span class="input-group-text bg-dark text-white">Note ID</span>
                                            <input 
                                                value="<%= note._id %>" 
                                                readonly
                                                type="text"
                                                id="noteId" 
                                                name="noteId" 
                                                class="form-control bg-dark text-white"
                                                placeholder="Note ID" 
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>



                            <div class="container text-center">
                                <div class="row row-cols-2">
                                    <button 
                                        class="btn btn-success my-2" 
                                        type="submit" 
                                        id="uploadButton" 
                                        hidden
                                        >Upload
                                    </button>
                                    <a 
                                        href="/image/remove/<%= note._id %>" 
                                        class="btn btn-danger btn-block my-2" 
                                        id="removeButton"
                                        _hidden
                                        >Remove
                                    </a>
                                </div>
                            </div>

                        </form>
                    </div>
                </div>

                <!-- ================= WELLBORE 3D TRAJECTORY (techy theme, scoped) ================= -->
                <style>
                    .wbt-root {
                        --wbt-bg: #0a0e14;
                        --wbt-panel: #111820;
                        --wbt-panel2: #161e28;
                        --wbt-border: #1e2d3d;
                        --wbt-accent: #00c8ff;
                        --wbt-accent2: #ff6b35;
                        --wbt-accent3: #39ff14;
                        --wbt-text: #c8d8e8;
                        --wbt-text-dim: #5a7080;
                        --wbt-text-bright: #e8f4ff;
                        --wbt-red: #ff4060;
                        --wbt-mono: 'Share Tech Mono', monospace;
                        --wbt-sans: 'Barlow', sans-serif;
                        --wbt-cond: 'Barlow Condensed', sans-serif;
                    }
                    .wbt-root{
                        background: var(--wbt-bg);
                        color: var(--wbt-text);
                        font-family: var(--wbt-sans);
                        border-radius: 6px;
                        padding: 14px;
                        margin: 10px 0;
                        position: relative;
                        overflow: hidden;
                        border: 1px solid var(--wbt-border);
                    }
                    .wbt-root::before{
                        content:'';
                        position:absolute; inset:0;
                        background-image: linear-gradient(rgba(0,200,255,.03) 1px, transparent 1px),
                                          linear-gradient(90deg, rgba(0,200,255,.03) 1px, transparent 1px);
                        background-size: 30px 30px;
                        pointer-events:none; z-index:0;
                    }
                    .wbt-root > *{ position:relative; z-index:1; }
                    .wbt-title{
                        font-family: var(--wbt-cond);
                        font-size: 15px; font-weight:700; letter-spacing:1.5px;
                        color: var(--wbt-text-bright); text-transform:uppercase;
                        margin-bottom: 10px; display:flex; align-items:center; gap:8px;
                    }
                    .wbt-title .wbt-dot{
                        width:8px; height:8px; border-radius:50%; background:var(--wbt-accent);
                        box-shadow:0 0 8px var(--wbt-accent);
                    }
                    .wbt-row{ display:flex; flex-wrap:wrap; gap:10px; align-items:flex-end; margin-bottom:10px; }
                    .wbt-field{ display:flex; flex-direction:column; gap:4px; flex:1; min-width:180px; }
                    .wbt-field label{
                        font-family: var(--wbt-cond); font-size:10px; letter-spacing:1px;
                        text-transform:uppercase; color: var(--wbt-text-dim);
                    }
                    .wbt-field input[type=file], .wbt-field input[type=text]{
                        background: var(--wbt-panel2); border:1px solid var(--wbt-border);
                        color: var(--wbt-text); border-radius:3px; padding:6px 8px; font-size:12px;
                        font-family: var(--wbt-mono);
                    }
                    .wbt-btn{
                        font-family: var(--wbt-cond); font-size:11px; font-weight:600; letter-spacing:1.5px;
                        text-transform:uppercase; padding:7px 14px; border-radius:3px; border:1px solid var(--wbt-border);
                        cursor:pointer; transition: all .15s; background: transparent; color: var(--wbt-text-dim);
                    }
                    .wbt-btn:hover{ border-color: var(--wbt-accent); color: var(--wbt-accent); }
                    .wbt-btn-save{
                        background: linear-gradient(135deg, var(--wbt-accent2), #ff8c55);
                        color:#fff; border:none;
                    }
                    .wbt-btn-save:hover{ box-shadow:0 3px 14px rgba(255,107,53,.4); color:#fff; }
                    .wbt-btn-save:disabled{ opacity:.4; cursor:not-allowed; box-shadow:none; }
                    .wbt-btn-del{
                        background: transparent; color: var(--wbt-red); border:1px solid rgba(255,64,96,.3);
                    }
                    .wbt-btn-del:hover{ border-color: var(--wbt-red); box-shadow:0 0 8px rgba(255,64,96,.3); }
                    .wbt-status{ font-family: var(--wbt-mono); font-size:11px; color: var(--wbt-text-dim); margin:6px 0; }

                                        /* ── Viewer layout: sidebar + canvas ── */
                    .wbt-viewer-outer{
                        display:flex; gap:0; border:1px solid var(--wbt-border);
                        border-radius:4px; overflow:hidden; margin-bottom:10px;
                    }
                    .wbt-sidebar{
                        width:220px; min-width:220px; flex-shrink:0;
                        background: rgba(17,24,32,0.97); border-right:1px solid var(--wbt-border);
                        padding:10px; overflow-y:auto; display:flex; flex-direction:column; gap:0; min-height:50vh;
                        font-size:11px; color:var(--wbt-text);
                    }
                    .wbt-sidebar h6{
                        margin:0 0 5px; font-size:10px; color:var(--wbt-text-dim);
                        text-transform:uppercase; letter-spacing:1px;
                        font-family:var(--wbt-cond);
                    }
                    .wbt-sidebar .wbt-section{ margin-bottom:10px; padding-bottom:10px; border-bottom:1px solid var(--wbt-border); }
                    .wbt-sidebar .wbt-section:last-child{ border-bottom:none; margin-bottom:0; padding-bottom:0; }
                    .wbt-sidebar label{ display:flex; align-items:center; gap:7px; margin:7px 0; cursor:pointer; }
                    .wbt-sidebar select, .wbt-sidebar input[type=range]{
                        width:100%; background:var(--wbt-panel2); color:var(--wbt-text);
                        border:1px solid var(--wbt-border); border-radius:3px;
                    }
                    .wbt-viewer-canvas-wrap{ position:relative; flex:1; min-width:0; display:flex; flex-direction:column; }
                    .wbt-viewer-wrap{ display:none; } /* legacy, replaced by wbt-viewer-outer */
                    .wbt-viewer{ width:100%; flex:1; min-height:50vh; display:block; background: var(--wbt-bg); }
                    .wbt-panel{
                        position:absolute; background: rgba(17,24,32,0.92); border:1px solid var(--wbt-border);
                        border-radius:4px; padding:8px 10px; font-size:11px; color: var(--wbt-text);
                        backdrop-filter: blur(4px); max-height:90%; overflow:auto;
                    }
                    .wbt-controls{ display:none; } /* replaced by .wbt-sidebar */
                    .wbt-legend{ top:10px; right:10px; max-height:50vh; }
                    .wbt-panel h6{
                        margin:0 0 6px; font-size:10px; color: var(--wbt-text-dim);
                        text-transform:uppercase; letter-spacing:1px; font-family: var(--wbt-cond);
                    }
                    .wbt-panel label{ display:flex; align-items:center; gap:7px; margin:7px 0; cursor:pointer; }
                    .wbt-panel select, .wbt-panel input[type=range]{ width:100%; background:var(--wbt-panel2); color:var(--wbt-text); border:1px solid var(--wbt-border); border-radius:3px; }
                    .wbt-section{ margin-bottom:8px; padding-bottom:8px; border-bottom:1px solid var(--wbt-border); }
                    .wbt-section:last-child{ border-bottom:none; margin-bottom:0; padding-bottom:0; }
                    .wbt-swatch{ width:10px; height:10px; border-radius:2px; display:inline-block; flex-shrink:0; }
                    .wbt-legend-item{ display:flex; align-items:center; gap:6px; margin:3px 0; }

                    .wbt-list{ font-family: var(--wbt-mono); font-size:11px; }
                    .wbt-list-item{
                        display:flex; align-items:center; justify-content:space-between; gap:8px;
                        background: var(--wbt-panel2); border:1px solid var(--wbt-border); border-radius:3px;
                        padding:6px 10px; margin-bottom:6px;
                    }
                    .wbt-list-item .wbt-name{ display:flex; align-items:center; gap:8px; }

                    .wbt-table-wrap{ max-height:240px; overflow:auto; margin-bottom:10px; border:1px solid var(--wbt-border); border-radius:4px; }
                    .wbt-table{ width:100%; border-collapse:collapse; font-family: var(--wbt-mono); font-size:10.5px; }
                    .wbt-table th, .wbt-table td{ padding:4px 8px; text-align:right; white-space:nowrap; border-bottom:1px solid var(--wbt-border); }
                    .wbt-table th{ position:sticky; top:0; background: var(--wbt-panel2); color: var(--wbt-text-dim); font-weight:600; }
                    .wbt-table td:first-child, .wbt-table th:first-child{ text-align:left; }
                    .wbt-table tr:hover td{ background: rgba(0,200,255,.05); }

                    /* Accordion */
                    .wbt-accordion-item{ border:1px solid var(--wbt-border); border-radius:4px; margin-bottom:8px; overflow:hidden; }
                    .wbt-accordion-header{
                        display:flex; align-items:center; justify-content:space-between; gap:8px;
                        padding:8px 12px; background: var(--wbt-panel2); cursor:pointer;
                        font-family: var(--wbt-cond); font-size:12px; font-weight:700;
                        letter-spacing:1px; text-transform:uppercase; color: var(--wbt-text-bright);
                        transition: background .15s;
                    }
                    .wbt-accordion-header:hover{ background: rgba(0,200,255,.06); }
                    .wbt-accordion-header .wbt-acc-icon{
                        font-family: var(--wbt-mono); color: var(--wbt-accent); transition: transform .2s;
                    }
                    .wbt-accordion-header.collapsed .wbt-acc-icon{ transform: rotate(-90deg); }
                    .wbt-accordion-body{ padding:10px; }
                    .wbt-accordion-body.collapsed{ display:none; }

                    /* Download row */
                    .wbt-actions-row{ display:flex; gap:10px; flex-wrap:wrap; margin:10px 0; }

                    /* Dashboard */
                    .wbt-dash-title{
                        font-family: var(--wbt-cond); font-size: 13px; font-weight:700; letter-spacing:1.5px;
                        color: var(--wbt-text-bright); text-transform:uppercase;
                        margin: 14px 0 8px; display:flex; align-items:center; gap:8px;
                        border-top: 1px solid var(--wbt-border); padding-top: 12px;
                    }
                    .wbt-dash-title .wbt-dot{
                        width:8px; height:8px; border-radius:50%; background:var(--wbt-accent2);
                        box-shadow:0 0 8px var(--wbt-accent2);
                    }
                    .wbt-dash-grid{
                        display:grid; grid-template-columns: repeat(auto-fit, minmax(205px, 1fr));
                        gap:8px;
                    }
                    .wbt-dash-card{
                        background: var(--wbt-panel2); border:1px solid var(--wbt-border); border-radius:4px;
                        padding:8px 10px; overflow:hidden;
                    }
                    .wbt-dash-card-title{
                        display:flex; align-items:center; gap:8px; margin-bottom:6px;
                        font-family: var(--wbt-cond); font-size:12px; font-weight:700; letter-spacing:1px;
                        text-transform:uppercase; color: var(--wbt-text-bright);
                    }
                    .wbt-dash-card-title .wbt-swatch{ width:10px; height:10px; }
                    .wbt-metric-grid{
                        display:grid; grid-template-columns: 1fr 1fr; gap:4px 10px;
                        font-family: var(--wbt-mono); font-size:11px;
                    }
                    .wbt-metric-label{ color: var(--wbt-text-dim); }
                    .wbt-metric-value{ color: var(--wbt-text-bright); text-align:right; font-weight:600; }
                    .wbt-metric-full{ grid-column: 1 / -1; border-top:1px solid var(--wbt-border); margin-top:3px; padding-top:3px; }
                    .wbt-highlight-row{ display:flex; gap:6px; margin-bottom:8px; }
                    .wbt-highlight-box{
                        flex:1; background: rgba(0,200,255,.06); border:1px solid var(--wbt-accent);
                        border-radius:3px; padding:4px 6px; text-align:center;
                    }
                    .wbt-highlight-box:nth-child(2){ border-color: var(--wbt-accent2); background: rgba(255,107,53,.06); }
                    .wbt-highlight-box:nth-child(3){ border-color: var(--wbt-accent3); background: rgba(57,255,20,.06); }
                    .wbt-pad-summary{
                        display:flex; flex-wrap:wrap; gap:6px; padding:8px 0 10px;
                    }
                    .wbt-pad-stat{
                        background: var(--wbt-panel2); border:1px solid var(--wbt-accent);
                        border-radius:3px; padding:4px 12px; text-align:center; min-width:100px;
                    }
                    .wbt-pad-stat-label{
                        font-family: var(--wbt-cond); font-size:9px; letter-spacing:1px;
                        text-transform:uppercase; color: var(--wbt-text-dim);
                    }
                    .wbt-pad-stat-value{
                        font-family: var(--wbt-mono); font-size:14px; font-weight:700;
                        color: var(--wbt-accent);
                    }
                    .wbt-hl-sc   { border-color: #58a6ff !important; background: rgba(88,166,255,.06) !important; }
                    .wbt-hl-icp  { border-color: var(--wbt-accent2) !important; background: rgba(255,107,53,.06) !important; }
                    .wbt-hl-td   { border-color: var(--wbt-accent3) !important; background: rgba(57,255,20,.06) !important; }

                    .wbt-highlight-label{
                        font-family: var(--wbt-cond); font-size:9px; letter-spacing:1px; text-transform:uppercase;
                        color: var(--wbt-text-dim); margin-bottom:1px;
                    }
                    .wbt-highlight-value{
                        font-family: var(--wbt-mono); font-size:14px; font-weight:700; color: var(--wbt-text-bright);
                    }
                    .wbt-highlight-extra{
                        font-family: var(--wbt-mono); font-size:9px; color: var(--wbt-text-dim); margin-top:1px;
                    }


                    /* ── FracPlane Controller ── */
                    .wbt-fp-root{
                        background: var(--wbt-panel2); border:1px solid var(--wbt-border);
                        border-radius:4px; padding:10px 12px; margin:10px 0;
                    }
                    .wbt-fp-title{
                        font-family: var(--wbt-cond); font-size:12px; font-weight:700;
                        letter-spacing:1.5px; text-transform:uppercase;
                        color: var(--wbt-text-bright); margin-bottom:8px;
                        display:flex; align-items:center; gap:8px;
                    }
                    .wbt-fp-title .wbt-dot{ width:7px; height:7px; border-radius:50%; background:#ffd060; box-shadow:0 0 7px #ffd060; }
                    .wbt-fp-row{ display:flex; flex-wrap:wrap; gap:8px; align-items:flex-end; margin-bottom:8px; }
                    .wbt-fp-field{ display:flex; flex-direction:column; gap:3px; }
                    .wbt-fp-field label{
                        font-family: var(--wbt-cond); font-size:9px; letter-spacing:1px;
                        text-transform:uppercase; color: var(--wbt-text-dim);
                    }
                    .wbt-fp-field input, .wbt-fp-field select{
                        background: var(--wbt-bg); border:1px solid var(--wbt-border);
                        color: var(--wbt-text); border-radius:3px; padding:4px 6px;
                        font-size:12px; font-family: var(--wbt-mono); width:100%;
                    }
                    .wbt-fp-field input:focus, .wbt-fp-field select:focus{
                        outline:none; border-color: var(--wbt-accent);
                    }
                    .wbt-fp-field.w60{ width:60px; }
                    .wbt-fp-field.w80{ width:80px; }
                    .wbt-fp-field.w100{ width:100px; }
                    .wbt-fp-field.w160{ width:160px; }
                    .wbt-fp-btns{ display:flex; gap:6px; flex-wrap:wrap; }
                    .wbt-fp-btn{
                        font-family: var(--wbt-cond); font-size:10px; font-weight:700;
                        letter-spacing:1px; text-transform:uppercase; padding:5px 10px;
                        border-radius:3px; border:1px solid var(--wbt-border);
                        cursor:pointer; transition: all .15s; background: transparent;
                        color: var(--wbt-text-dim);
                    }
                    .wbt-fp-btn:hover{ border-color: var(--wbt-accent); color: var(--wbt-accent); }
                    .wbt-fp-btn-add{ border-color: var(--wbt-accent3); color: var(--wbt-accent3); }
                    .wbt-fp-btn-add:hover{ background: rgba(57,255,20,.08); border-color: var(--wbt-accent3); color: var(--wbt-accent3); }
                    .wbt-fp-btn-upd{ border-color: #ffd060; color: #ffd060; }
                    .wbt-fp-btn-upd:hover{ background: rgba(255,208,96,.08); border-color: #ffd060; color: #ffd060; }
                    .wbt-fp-btn-del{ border-color: var(--wbt-red); color: var(--wbt-red); }
                    .wbt-fp-btn-del:hover{ background: rgba(255,64,96,.08); border-color: var(--wbt-red); color: var(--wbt-red); }
                    .wbt-fp-btn:disabled{ opacity:.35; cursor:not-allowed; }
                    .wbt-fp-status{ font-family: var(--wbt-mono); font-size:10px; color: var(--wbt-text-dim); margin-top:6px; }

                    /* FracPlane list (per trajectory) in accordion */
                    .wbt-fp-list{ margin-top:6px; }
                    .wbt-fp-list-item{
                        display:flex; align-items:center; gap:8px;
                        padding:3px 8px; border-radius:3px; cursor:pointer;
                        font-family: var(--wbt-mono); font-size:10px;
                        border:1px solid transparent; transition: border-color .12s;
                    }
                    .wbt-fp-list-item:hover{ border-color: var(--wbt-border); background: rgba(0,200,255,.04); }
                    .wbt-fp-list-item.active{ border-color: #ffd060; background: rgba(255,208,96,.06); }
                    .wbt-fp-list-item .wbt-fp-lbl{ color: var(--wbt-text-bright); flex:1; }
                    .wbt-fp-list-item .wbt-fp-meta{ color: var(--wbt-text-dim); }


                    /* FracPlane accordion wrapper */
                    .wbt-fp-accordion-wrap{ margin:10px 0; }
                    .wbt-fp-acc-header{
                        display:flex; align-items:center; justify-content:space-between;
                        padding:8px 12px; background: var(--wbt-panel2);
                        border:1px solid var(--wbt-border); border-radius:4px;
                        cursor:pointer; font-family:var(--wbt-cond); font-size:12px;
                        font-weight:700; letter-spacing:1px; text-transform:uppercase;
                        color: var(--wbt-text-bright); transition: background .15s;
                    }
                    .wbt-fp-acc-header:hover{ background: rgba(255,208,96,.06); border-color:#ffd060; }
                    .wbt-fp-acc-icon{ font-family:var(--wbt-mono); color:#ffd060; transition:transform .2s; }
                    .wbt-fp-acc-header.collapsed .wbt-fp-acc-icon{ transform:rotate(-90deg); }
                    .wbt-fp-acc-body{ border:1px solid var(--wbt-border); border-top:none; border-radius:0 0 4px 4px; padding:10px; }
                    .wbt-fp-acc-body.collapsed{ display:none; }
                    /* Excel button blue */
                    .wbt-btn-excel{
                        background: linear-gradient(135deg,#1a6fc4,#2196f3);
                        color:#fff !important; border:none !important;
                    }
                    .wbt-btn-excel:hover{ box-shadow:0 3px 14px rgba(33,150,243,.45); color:#fff !important; }

                    /* Formation mesh list in controls panel */
                    .wbt-fm-item{ display:flex; align-items:center; gap:6px; margin:3px 0; cursor:pointer; }
                    .wbt-fm-item label{ display:flex; align-items:center; gap:5px; cursor:pointer; font-family:var(--wbt-mono); font-size:10px; color:var(--wbt-text); }
                    .wbt-fm-dot{ width:8px; height:8px; border-radius:50%; background:#39ff14; flex-shrink:0; }

                </style>

                <div class="wbt-root" id="wbtRoot">
                    <div class="wbt-title"><span class="wbt-dot"></span> Wellbore 3D Trajectory</div>

                    <!-- Existing trajectories list -->
                    <div class="wbt-section">
                        <div class="wbt-field" style="margin-bottom:6px;">
                            <label>Saved Wellbores for this Job</label>
                        </div>
                        <div class="wbt-list" id="wbtSavedList">
                            <% if (wellboreTrajectories && wellboreTrajectories.length) { %>
                                <% wellboreTrajectories.forEach(function(t){ %>
                                    <div class="wbt-list-item" data-id="<%= t._id %>">
                                        <span class="wbt-name">
