

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Torque and Drag Modeler v5</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/plotly.js/2.27.0/plotly.min.js"></script>
  <link
    href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@400;600;700&display=swap"
    rel="stylesheet" />
  <style>
    :root {
      --bg: #0a0e14;
      --panel: #111820;
      --panel2: #161e28;
      --border: #1e2d3d;
      --accent: #00c8ff;
      --accent2: #ff6b35;
      --accent3: #39ff14;
      --text: #c8d8e8;
      --text-dim: #5a7080;
      --text-bright: #e8f4ff;
      --red: #ff4060;
      --yellow: #ffd060;
      --purple: #c084fc;
      --teal: #2dd4bf;
      --mono: 'Share Tech Mono', monospace;
      --sans: 'Barlow', sans-serif;
      --cond: 'Barlow Condensed', sans-serif;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0
    }

    html {
      font-size: 13px
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      overflow-x: hidden
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: linear-gradient(rgba(0, 200, 255, .025) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 200, 255, .025) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
      z-index: 0
    }

    /* HEADER */
    header {
      position: relative;
      z-index: 10;
      background: linear-gradient(180deg, #0d1520, transparent);
      border-bottom: 1px solid var(--border);
      padding: 10px 20px;
      display: flex;
      align-items: center;
      gap: 14px
    }

    .logo-hex {
      width: 34px;
      height: 34px;
      background: var(--accent);
      clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      color: var(--bg);
      font-weight: 700;
      flex-shrink: 0
    }

    .hdr-title {
      flex: 1
    }

    .hdr-title h1 {
      font-family: var(--cond);
      font-size: 19px;
      font-weight: 700;
      color: var(--text-bright);
      letter-spacing: 2px;
      text-transform: uppercase
    }

    .hdr-title p {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--accent);
      letter-spacing: 1px;
      margin-top: 1px
    }

    .hdr-right {
      display: flex;
      align-items: center;
      gap: 8px
    }

    .unit-toggle {
      display: flex;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 3px;
      overflow: hidden
    }

    .unit-btn {
      font-family: var(--mono);
      font-size: 9px;
      padding: 4px 10px;
      border: none;
      background: none;
      color: var(--text-dim);
      cursor: pointer;
      letter-spacing: 1px;
      transition: all .15s
    }

    .unit-btn.active {
      background: var(--accent);
      color: var(--bg);
      font-weight: 700
    }

    .badge {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--accent3);
      border: 1px solid var(--accent3);
      padding: 2px 6px;
      border-radius: 2px;
      letter-spacing: 1px
    }

    /* LAYOUT */
    .app {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 390px 1fr;
      min-height: calc(100vh - 58px)
    }

    .left {
      border-right: 1px solid var(--border);
      overflow-y: auto;
      max-height: calc(100vh - 58px);
      scrollbar-width: thin;
      scrollbar-color: var(--border) transparent
    }

    .right {
      display: flex;
      flex-direction: column;
      overflow: hidden
    }

    /* LEFT SECTIONS */
    .sec {
      border-bottom: 1px solid var(--border)
    }

    .sec-hdr {
      padding: 9px 14px;
      background: var(--panel);
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      user-select: none;
      transition: background .15s
    }

    .sec-hdr:hover {
      background: var(--panel2)
    }

    .sec-num {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--accent);
      background: rgba(0, 200, 255, .1);
      border: 1px solid rgba(0, 200, 255, .3);
      padding: 2px 5px;
      border-radius: 2px;
      flex-shrink: 0
    }

    .sec-ttl {
      font-family: var(--cond);
      font-size: 11px;
      font-weight: 600;
      color: var(--text-bright);
      letter-spacing: 1px;
      text-transform: uppercase;
      flex: 1
    }

    .sec-tog {
      font-size: 8px;
      color: var(--text-dim);
      transition: transform .2s
    }

    .sec-tog.open {
      transform: rotate(180deg)
    }

    .sec-body {
      padding: 11px 14px;
      background: var(--bg);
      display: none
    }

    .sec-body.open {
      display: block
    }

    /* FORMS */
    .fg {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 6px;
      margin-bottom: 6px
    }

    .fg.tri {
      grid-template-columns: 1fr 1fr 1fr
    }

    .fg.one {
      grid-template-columns: 1fr
    }

    label {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--text-dim);
      letter-spacing: 1px;
      text-transform: uppercase;
      display: block;
      margin-bottom: 2px
    }

    input[type=number],
    input[type=text],
    select {
      width: 100%;
      background: var(--panel);
      border: 1px solid var(--border);
      color: var(--text-bright);
      font-family: var(--mono);
      font-size: 11px;
      padding: 5px 6px;
      border-radius: 3px;
      outline: none;
      transition: border-color .15s
    }

    input:focus,
    select:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 2px rgba(0, 200, 255, .1)
    }

    select option {
      background: var(--panel)
    }

    .hint {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--text-dim);
      margin-top: 4px;
      line-height: 1.5
    }

    /* INPUT DATA TABLES */
    .tbl-wrap {
      overflow-x: auto;
      margin-bottom: 6px
    }

    table.dt {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--mono);
      font-size: 9px
    }

    table.dt th {
      background: var(--panel2);
      color: var(--accent);
      font-size: 7px;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 3px 4px;
      text-align: center;
      border: 1px solid var(--border);
      white-space: nowrap
    }

    table.dt td {
      border: 1px solid var(--border);
      padding: 1px
    }

    table.dt td input {
      border: none;
      background: transparent;
      text-align: center;
      padding: 3px;
      font-size: 9px;
      width: 100%;
      min-width: 34px;
      color: var(--text-bright);
      font-family: var(--mono)
    }

    table.dt td input:focus {
      background: rgba(0, 200, 255, .08)
    }

    table.dt tr:hover td {
      background: rgba(255, 255, 255, .015)
    }

    .del {
      background: none;
      border: none;
      color: var(--red);
      cursor: pointer;
      font-size: 10px;
      padding: 2px 4px;
      opacity: .4;
      transition: opacity .15s
    }

    .del:hover {
      opacity: 1
    }

    /* BUTTONS */
    .brow {
      display: flex;
      gap: 6px;
      margin-top: 6px;
      flex-wrap: wrap
    }

    .btn {
      font-family: var(--cond);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 5px 10px;
      border-radius: 3px;
      border: none;
      cursor: pointer;
      transition: all .15s
    }

    .btn-g {
      background: transparent;
      border: 1px solid var(--border);
      color: var(--text-dim)
    }

    .btn-g:hover {
      border-color: var(--accent);
      color: var(--accent)
    }

    .btn-run {
      background: linear-gradient(135deg, var(--accent2), #ff8c55);
      color: #fff;
      font-size: 11px;
      padding: 8px 18px;
      width: 100%;
      margin-top: 2px;
      letter-spacing: 2px
    }

    .btn-run:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 18px rgba(255, 107, 53, .4)
    }

    .btn-run:active {
      transform: none
    }

    .btn-cal {
      background: linear-gradient(135deg, var(--purple), #a855f7);
      color: #fff;
      font-size: 10px;
      padding: 5px 11px
    }

    .btn-cal:hover {
      box-shadow: 0 3px 12px rgba(192, 132, 252, .4)
    }

    /* EDR */
    .edr-box {
      background: rgba(0, 200, 255, .04);
      border: 1px solid rgba(0, 200, 255, .2);
      border-radius: 4px;
      padding: 10px;
      margin-bottom: 8px
    }

    .edr-ttl {
      font-family: var(--cond);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 7px
    }

    .drop {
      border: 2px dashed var(--border);
      border-radius: 4px;
      padding: 16px;
      text-align: center;
      cursor: pointer;
      transition: all .2s;
      position: relative;
      margin-bottom: 6px
    }

    .drop:hover,
    .drop.over {
      border-color: var(--accent);
      background: rgba(0, 200, 255, .05)
    }

    .drop p {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--text-dim);
      line-height: 1.7
    }

    .drop strong {
      color: var(--accent)
    }

    .drop input[type=file] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%
    }

    .edr-st {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--accent3);
      margin-top: 5px;
      display: none
    }

    .col-map {
      display: none;
      grid-template-columns: 1fr 1fr;
      gap: 5px;
      margin-top: 7px
    }

    .col-map label {
      font-size: 7px
    }

    /* CALIBRATION */
    .cal-box {
      background: rgba(192, 132, 252, .06);
      border: 1px solid rgba(192, 132, 252, .25);
      border-radius: 4px;
      padding: 10px;
      margin-bottom: 8px
    }

    .cal-ttl {
      font-family: var(--cond);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 8px
    }

    .srow {
      display: grid;
      grid-template-columns: 1fr auto 56px;
      gap: 7px;
      align-items: center;
      margin-bottom: 7px
    }

    .slbl {
      font-family: var(--mono);
      font-size: 8px;
      color: var(--text-dim);
      letter-spacing: 1px
    }

    input[type=range] {
      width: 100%;
      -webkit-appearance: none;
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      outline: none
    }

    input[type=range]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: var(--purple);
      cursor: pointer;
      box-shadow: 0 0 5px rgba(192, 132, 252, .6)
    }

    .sval {
      font-family: var(--mono);
      font-size: 10px;
      color: var(--purple);
      text-align: right
    }

    .rmse-box {
      font-family: var(--mono);
      font-size: 9px;
      color: var(--text-dim);
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 3px;
      padding: 6px 9px;
      margin-top: 7px;
      line-height: 1.7;
      display: none
    }

    /* RESULTS TOOLBAR */
    .rtbar {
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      padding: 7px 14px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap
    }

    .rtbar h2 {
      font-family: var(--cond);
      font-size: 13px;
      font-weight: 700;
      color: var(--text-bright);
      letter-spacing: 2px;
      text-transform: uppercase;
      white-space: nowrap
    }

    .chips {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-left: auto
    }

    .chip {
      font-family: var(--mono);
      font-size: 8px;
      padding: 3px 7px;
      border-radius: 2px;
      border: 1px solid;
      white-space: nowrap
    }

    .cb {
      color: var(--accent);
      border-color: rgba(0, 200, 255, .3);
      background: rgba(0, 200, 255, .07)
    }

    .co {
      color: var(--accent2);
      border-color: rgba(255, 107, 53, .3);
      background: rgba(255, 107, 53, .07)
    }

    .cg {
      color: var(--accent3);
      border-color: rgba(57, 255, 20, .3);
      background: rgba(57, 255, 20, .07)
    }

    .cr {
      color: var(--red);
      border-color: rgba(255, 64, 96, .3);
      background: rgba(255, 64, 96, .07)
    }

    .cp {
      color: var(--purple);
      border-color: rgba(192, 132, 252, .3);
      background: rgba(192, 132, 252, .07)
    }

    /* CHARTS — stacked panels each with chart left + table right */
    .charts {
      flex: 1;
      overflow-y: auto;
      padding: 14px;
      display: flex;
      flex-direction: column;
      gap: 14px
    }

    /* plot panel */
    .pp {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      position: relative
    }

    .pp::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      z-index: 2
    }

    .pp.c-bl::before {
      background: var(--accent)
    }

    .pp.c-or::before {
      background: var(--accent2)
    }

    .pp.c-te::before {
      background: var(--teal)
    }

    .pp.c-pu::before {
      background: var(--purple)
    }

    .pp.c-gr::before {
      background: var(--accent3)
    }

    .pp.c-wh::before {
      background: #ffffff
    }

    .pp-hdr {
      padding: 7px 12px;
      background: var(--panel2);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center
    }

    .pp-ttl {
      font-family: var(--cond);
      font-size: 9px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-dim)
    }

    /* body: left = chart, right = table */
    .pp-body {
      display: grid;
      grid-template-columns: 60% 40%
    }

    .pp-body.wide3d {
      grid-template-columns: 65% 35%
    }

    /* chart area */
    .pp-chart {
      position: relative;
      border-right: 1px solid var(--border);
      height: 320px
    }

    .pp-chart.tall {
      height: 420px
    }

    .pp-chart.h3d {
      height: 480px
    }

    .pp-chart canvas {
      position: absolute;
      inset: 6px
    }

    /* plotly 3d fills chart area */
    .pp-plotly {
      width: 100%;
      height: 100%
    }

    /* panel result table */
    .pp-tbl {
      overflow: auto;
      height: 320px
    }

    .pp-tbl.tall {
      height: 420px
    }

    .pp-tbl.h3d {
      height: 480px
    }

    table.ptbl {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--mono);
      font-size: 8px
    }

    table.ptbl th {
      background: var(--panel2);
      color: var(--accent);
      font-size: 7px;
      letter-spacing: .5px;
      text-transform: uppercase;
      padding: 3px 5px;
      border-bottom: 1px solid var(--border);
      position: sticky;
      top: 0;
      z-index: 2;
      white-space: nowrap;
      text-align: right
    }

    table.ptbl th:first-child {
      text-align: left
    }

    table.ptbl td {
      border-bottom: 1px solid rgba(30, 45, 61, .6);
      padding: 2px 5px;
      text-align: right;
      color: var(--text)
    }

    table.ptbl td:first-child {
      text-align: left;
      color: var(--text-dim)
    }

    table.ptbl tr:hover td {
      background: rgba(0, 200, 255, .04)
    }

    /* PLACEHOLDER */
    .ph {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80px 40px;
      text-align: center;
      min-height: 400px
    }

    .ph-icon {
      font-size: 48px;
      margin-bottom: 14px;
      opacity: .25
    }

    .ph h3 {
      font-family: var(--cond);
      font-size: 15px;
      font-weight: 600;
      letter-spacing: 2px;
      text-transform: uppercase;
      margin-bottom: 5px;
      opacity: .4
    }

    .ph p {
      font-size: 11px;
      line-height: 1.6;
      max-width: 320px;
      opacity: .35
    }

    /* STATUS BAR */
    .sbar {
      background: var(--panel);
      border-top: 1px solid var(--border);
      padding: 5px 14px;
      font-family: var(--mono);
      font-size: 8px;
      color: var(--text-dim);
      display: flex;
      align-items: center;
      gap: 10px
    }

    .sdot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: var(--text-dim);
      flex-shrink: 0
    }

    .sdot.ok {
      background: var(--accent3);
      box-shadow: 0 0 5px var(--accent3)
    }

    .sdot.err {
      background: var(--red);
      box-shadow: 0 0 5px var(--red)
    }

    .sdot.run {
      background: var(--accent);
      animation: pulse 1s infinite
    }

    @keyframes pulse {

      0%,
      100% {
        opacity: 1
      }

      50% {
        opacity: .3
      }
    }

    .errbox {
      background: rgba(255, 64, 96, .1);
      border: 1px solid rgba(255, 64, 96, .4);
      border-radius: 3px;
      padding: 7px 11px;
      font-family: var(--mono);
      font-size: 9px;
      color: var(--red);
      line-height: 1.6;
      display: none;
      margin: 8px 14px
    }

    ::-webkit-scrollbar {
      width: 4px;
      height: 4px
    }

    ::-webkit-scrollbar-track {
      background: transparent
    }

    ::-webkit-scrollbar-thumb {
      background: var(--border);
      border-radius: 3px
    }
  </style>
</head>

<body>

  <header>
    <div class="logo-hex">+</div>
    <div class="hdr-title">
      <h1>Torque &amp; Drag Modeler</h1>
      <p>SOFT-STRING (JOHANCSIK 1984) · 3D TRAJECTORY · WELLPLAN-STYLE OUTPUT · EDR CALIBRATION</p>
    </div>
    <div class="hdr-right">
      <div class="unit-toggle">
        <button class="unit-btn" id="btnImp" onclick="setUnits('imperial')">IMPERIAL</button>
        <button class="unit-btn active" id="btnMet" onclick="setUnits('metric')">METRIC</button>
      </div>
      <div class="badge">v5.0</div>
    </div>
  </header>

  <div class="app">

    <!-- ===== LEFT INPUT PANEL ===== -->
    <div class="left">

      <!-- 01 GLOBAL -->
      <div class="sec">
        <div class="sec-hdr" onclick="toggleSec(this)">
          <span class="sec-num">01</span><span class="sec-ttl">Global Parameters</span><span
            class="sec-tog open">v</span>
        </div>
        <div class="sec-body open">
          <div class="fg">
            <div><label id="lMW">Mud Weight (kg/m3)</label><input type="number" id="mudWeight" value="1040" step="1" />
            </div>
            <div><label id="lBW">Block Weight (kN)</label><input type="number" id="blockWeight" value="10" step="0.1" />
            </div>
          </div>
          <div class="fg">
            <div><label id="lWOBr">WOB Rotating (kN)</label><input type="number" id="wobRot" value="20" step="0.5" />
            </div>
            <div><label id="lWOBs">WOB Sliding (kN)</label><input type="number" id="wobSlid" value="19" step="0.5" />
            </div>
          </div>
          <div class="fg">
            <div><label id="lTQ">Torque Limit (N.m)</label><input type="number" id="torqueLimit" value="35000"
                step="100" /></div>
            <div><label>Steel Density (kg/m3)</label><input type="number" id="steelDens" value="7850" step="10" /></div>
          </div>
          <div class="fg tri">
            <div><label>mu Casing 1</label><input type="number" id="ff1" value="0.25" step="0.01" min="0.01"
                max="0.8" /></div>
            <div><label>mu Casing 2</label><input type="number" id="ff2" value="0.20" step="0.01" min="0.01"
                max="0.8" /></div>
            <div><label>mu Open Hole</label><input type="number" id="ffOH" value="0.32" step="0.01" min="0.01"
                max="0.8" /></div>
          </div>
          <p class="hint">mu typical: 0.15-0.25 cased / 0.25-0.40 open hole. CNRL defaults loaded.</p>
        </div>
      </div>

      <!-- 02 SURVEY -->
      <div class="sec">
        <div class="sec-hdr" onclick="toggleSec(this)">
