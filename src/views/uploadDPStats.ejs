

<%- include ('partials/header.ejs') %>

    <div class="_container bg-dark">

        <h2 class="pt-4 m-4">Upload DP statistics</h2>

        <p class="mb-4 m-4">USER: <%= user.name %></p>

        <p class="mx-4" style="color:#aaa;">
            Upload the raw "Report" export (.xlsx). DP Version is extracted from
            <b>DP Design/Plan No (All Plans)</b> and DP Days is computed as
            <b>DP Received Date (All Plans) − DP Request Date (All Plans)</b>.
            All other columns are stored as-is for reference.
        </p>

        <div class="row m-4">

            <form action="/notes/uploadDPStats" method="POST" enctype="multipart/form-data" class="mb-4">
                <div class="card mb-3">
                    <div class="card-body">
                        <div class="input-group mb-3">
                            <input
                              type="file"
                              accept=".xlsx,.xls"
                              id="excelFileDPStats"
                              class="form-control"
                            />
                        </div>
                    </div>
                </div>
                <div class="d-grid gap-2">
                    <a href="/notes" class="btn btn-primary btn-block my-2">Back</a>
                </div>
            </form>




            <!-- The data is uploaded to MongoDB with a function (handler) below -->
            <div class="d-grid gap-2 mb-4">
              <button id="uploadDpStatsBtn" class="btn btn-success" type="button">
                ⬆️ Upload DP statistics
              </button>
            </div>



            <div class="accordion mb-4" id="accordionExample">
              <div class="accordion-item bg-dark border-0">
                <h2 class="accordion-header" id="headingOne">
                    <button class="accordion-button" type="button" data-bs-toggle="collapse" style="background-color: #1a1a1a; color: #ffffff;" 
                            data-bs-target="#collapseOne" aria-expanded="false" aria-controls="collapseOne">
                      📋 Table
                    </button>
                </h2>
                <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne">
                    <div class="accordion-body" style="overflow-x:auto;">
                      <table
                        id="dpStatsTable"
                        class="table table-dark table-striped table-bordered table-sm">
                      </table>
                    </div>
                </div>
              </div>
            </div> 

        </div>

    </div>

    <div id="chartContainer" class="m-3"></div>



    
    <!-- Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-zoom@2.0.1/dist/chartjs-plugin-zoom.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-annotation@3.1.0/dist/chartjs-plugin-annotation.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0"></script>
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>


    <script>

        // ── Source column headers (raw "Report" export) — order matters ──
        // Index positions are 0-based, matching the columns in the uploaded file.
        const SRC_COLS = [
            "ETS ID", "BH Location", "Prospect Name", "Explor Core Area", "Field Name",
            "Well Type", "Op / Non-Op", "AFE Timing Year", "Play Type", "Province",
            "DP Proposed # of Wellbores (All Plans)", "DP Proposed Total Drilled Meters (All Plans)",
            "DP Proposed Total Lateral Length (All Plans)", "DP Received Date (All Plans)",
            "DP Request Date (All Plans)", "DP Revised Survey No (All Plans)", "DP Type (All Plans)",
            "DP Company Name (All Plans)", "DP Current Plan (All Plans)", "DP Design/Plan No (All Plans)",
            "DP Drill Approved (All Plans)", "DP Geol Approved (All Plans)", "DP Justification (All Plans)",
            "DP Proposed # of Wellbores", "DP Proposed Total Drilled Meters", "DP Proposed Total Lateral Length"
        ];
        const COL = {
            dpReceivedDate: 13,  // column N (0-indexed)
            dpRequestDate:  14,  // column O
            dpDesignPlanNo: 19,  // column T
        };

        // Final table layout: DP Version, DP Days first (box plot depends on these
        // being columns 0 and 1), then all raw source columns.
        const OUT_HEADERS = ["DP Version", "DP Days", ...SRC_COLS];

        function normalizeP(value) {
            if (value === null || value === undefined || value === "") {
                return "P0";
            }
            const text = String(value).toUpperCase();
            const match = text.match(/P\s*(\d+)/);
            if (!match) {
                return "P0";
            }
            return "P" + Number(match[1]);
        }

        function compareP(a, b) {
            const na = parseInt(a.replace("P", ""), 10);
            const nb = parseInt(b.replace("P", ""), 10);
            return na - nb;
        }

        // Excel serial date -> JS Date (xlsx.js can also give JS Date directly
        // when cellDates:true is used, which we do below)
        function toDateSafe(v) {
            if (v instanceof Date) return v;
            if (typeof v === "number") {
                // Excel serial date fallback
                return new Date(Math.round((v - 25569) * 86400 * 1000));
            }
            if (typeof v === "string" && v.trim() !== "") {
                const d = new Date(v);
                if (!isNaN(d)) return d;
            }
            return null;
        }

        function daysBetween(received, requested) {
            const dRec = toDateSafe(received);
            const dReq = toDateSafe(requested);
            if (!dRec || !dReq) return 0;
            const diffMs = dRec - dReq;
            const days = Math.round(diffMs / 86400000);
            return days < 0 ? 0 : days;
        }

        document.getElementById("excelFileDPStats").addEventListener("change", handleExcelUpload);

        function handleExcelUpload(event) {

            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();

            reader.onload = function (e) {
                const data = new Uint8Array(e.target.result);
                const workbook = XLSX.read(data, { type: "array", cellDates: true });

                // Use "Report" sheet if present, else first sheet
                const sheetName = workbook.SheetNames.includes("Report")
                    ? "Report" : workbook.SheetNames[0];
                const worksheet = workbook.Sheets[sheetName];

                // Convert to array-of-arrays, raw values, header in row 1
                let rawRows = XLSX.utils.sheet_to_json(worksheet, {
                    header: 1,
                    blankrows: false,
                    defval: ""
                });

                if (!rawRows.length) {
                    alert("❌ Excel file is empty");
                    return;
                }

                // Drop header row from source (row 0)
                rawRows.shift();

                // Build output rows: [DP Version, DP Days, ...26 raw columns]
                let outRows = rawRows.map(row => {
                    const dpVersion = normalizeP(row[COL.dpDesignPlanNo]);
                    const dpDays = daysBetween(row[COL.dpReceivedDate], row[COL.dpRequestDate]);

                    // Format dates for display; keep everything else as-is
                    const formatted = row.map((cell, idx) => {
                        if (cell instanceof Date) {
                            return cell.toISOString().slice(0, 10);
                        }
                        return cell;
                    });

                    return [dpVersion, dpDays, ...formatted];
                });

                // Sort by normalized P version
                outRows.sort((a, b) => compareP(a[0], b[0]));

                const finalRows = [OUT_HEADERS, ...outRows];

                renderExcelTable(finalRows);

                console.log("📄 Excel data preview:", finalRows.slice(0, 5));
            };

            reader.readAsArrayBuffer(file);
        }

        function renderExcelTable(data) {
            const table = document.getElementById("dpStatsTable");
            table.innerHTML = "";

            data.forEach((row, rowIndex) => {
                const tr = document.createElement("tr");

                row.forEach(cell => {
                    const el = document.createElement(
                        rowIndex === 0 ? "th" : "td"
                    );
                    el.textContent = cell;
                    tr.appendChild(el);
                });

                table.appendChild(tr);
            });
        }

        </script>


    <script>

        document.getElementById("uploadDpStatsBtn")?.addEventListener("click", async () => {

            const table = document.getElementById("dpStatsTable");

            if (!table) {
                alert("❌ Table not found");
                return;
            }

            const headers = Array.from(
                table.querySelectorAll("th")
            ).map(th => th.textContent.trim());

            if (headers.length === 0) {
                alert("❌ Table headers missing");
                return;
            }

            const rowss = Array.from(table.querySelectorAll("tr")).map(tr =>
                Array.from(tr.querySelectorAll("td")).map(td => td.textContent.trim())
            );

            if (rowss.length === 0) {
                alert("❌ No rows to upload");
                return;
            }


        
            // Combine into one array (header + rows)
            const data = [headers, ...rowss];

            console.log("📦 Ready to upload sample:", data.slice(1, 7));
 

            //////// 🚀 Upload to server
                try {
                  const res = await fetch("/notes/uploadDPStats", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ data }),
                  });

                  if (res.ok) {
                    const msg = await res.text();
                    //console.log("✅ Upload success:", msg);
                    alert("✅ DP Stats uploaded successfully!");
                  } else {
                    const errText = await res.text();
                    //console.error("❌ Upload failed:", errText);
                    alert("❌ Upload failed:\n" + errText);
                  }
                } catch (err) {
                  //console.error("❌ Upload error:", err);
                  alert("❌ Upload error: " + err.message);
                }

        });

    </script>

</main>
</body>
</html>


