    function makeId(str, idx) { const base = String(str ?? '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, ''); return (base || 'item') + '-' + idx; }
    function fmt2(x) { if (x == null || Number.isNaN(x) || !Number.isFinite(x)) return ''; return Number(x).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }); }
    function fmt6(x) { if (x == null || Number.isNaN(x) || !Number.isFinite(x)) return ''; return Number(x).toLocaleString(undefined, { minimumFractionDigits: 6, maximumFractionDigits: 6 }); }
    function fmtPct2(x) { if (x == null || Number.isNaN(x) || !Number.isFinite(x)) return ''; return Number(x).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '%'; }
    function fmtMarker(k, x) { const v = Number(x); if (!Number.isFinite(v)) return ''; return k === 'ddi_excel' ? v.toFixed(1) : v.toFixed(2); }
    function getColumnIndex(hr, names) { const L = hr.map(h => String(h ?? '').trim().toLowerCase()); for (const nm of names) { const i = L.indexOf(nm.toLowerCase()); if (i >= 0) return i; } return -1; }
    function parseNumber(v) { if (v == null) return NaN; const s = String(v).replace(/,/g, '').trim(); const m = s.match(/-?\d+(\.\d+)?/); return m ? parseFloat(m[0]) : NaN; }
    function meanStd(values) { const v = values.filter(Number.isFinite); const n = v.length; if (!n) return { mean: null, std: null }; const mean = v.reduce((a, b) => a + b, 0) / n; const variance = v.reduce((s, x) => s + (x - mean) * (x - mean), 0) / n; return { mean, std: Math.sqrt(variance) }; }
    function accumulateSteeringMD(rows, idxMD, idxDOG, startIdx, endIdx) { if (idxMD < 0 || idxDOG < 0) return null; if (!Array.isArray(rows) || rows.length < 2) return 0; let t = 0; const from = Math.max(1, startIdx), to = Math.min(endIdx, rows.length - 1); if (to < from) return 0; for (let i = from; i <= to; i++) { const dls = parseNumber(rows[i][idxDOG]); if (!(dls > 1)) continue; const md = parseNumber(rows[i][idxMD]); const mdp = parseNumber(rows[i - 1][idxMD]); if (Number.isFinite(md) && Number.isFinite(mdp)) { const d = md - mdp; if (d > 0) t += d; } } return t; }
    function computeSteerEffortFullPath(rows, idxMD, idxDOG) { if (idxMD < 0 || idxDOG < 0 || !Array.isArray(rows) || rows.length < 2) return null; let tot = 0; for (let i = 1; i < rows.length; i++) { const dls = parseNumber(rows[i][idxDOG]); const md = parseNumber(rows[i][idxMD]); const mdp = parseNumber(rows[i - 1][idxMD]); if (!Number.isFinite(dls) || !Number.isFinite(md) || !Number.isFinite(mdp)) continue; const dMD = md - mdp; if (dMD <= 0) continue; const above = Math.max(dls - 1, 0); tot += (above * above) * dMD; } return tot; }
    function computeDDIExcel(rows, idxMD, idxDOG, idxN, idxE, tdIdx) { if (!rows || rows.length < 2) return { ddi: null }; const endRow = Number.isInteger(tdIdx) && tdIdx >= 0 ? tdIdx : rows.length - 1; const TMD = idxMD >= 0 ? parseNumber(rows[endRow][idxMD]) : NaN; let cumA = 0, cumT = 0; for (let i = 1; i < rows.length; i++) { if (idxN >= 0 && idxE >= 0) { const n = parseNumber(rows[i][idxN]), np = parseNumber(rows[i - 1][idxN]); const e = parseNumber(rows[i][idxE]), ep = parseNumber(rows[i - 1][idxE]); if ([n, np, e, ep].every(Number.isFinite)) { const dN = n - np, dE = e - ep; const seg = Math.hypot(dN, dE); if (seg > 0) cumA += seg; } } if (idxMD >= 0 && idxDOG >= 0) { const md = parseNumber(rows[i][idxMD]), mdp = parseNumber(rows[i - 1][idxMD]); if (Number.isFinite(md) && Number.isFinite(mdp)) { const CL = md - mdp; if (CL > 0) { let dls = parseNumber(rows[i][idxDOG]); if (!Number.isFinite(dls) || dls === 0) dls = 0.5; cumT += (CL * dls); } } } } if (Number.isFinite(TMD) && TMD > 0) { const tort = cumT / TMD; const comp = TMD * cumA * tort; const ddi = (Number.isFinite(comp) && comp > 0) ? Math.log10(comp) : null; return { ddi }; } return { ddi: null }; }

    // State
    const dropzone = el('#dropzone'), fileInput = el('#fileInput'), dirInput = el('#dirInput'), errorBox = el('#errorBox'), clearBtn = el('#clearBtn'), hasHeaderCheckbox = el('#hasHeader');
    const fileMeta = el('#fileMeta'), rowCount = el('#rowCount'), colCount = el('#colCount'), fileCount = el('#fileCount'), wellCount = el('#wellCount'), metaRow = el('#metaRow');
    const groupContainer = el('#groupContainer'), markerMetricSelect = el('#markerMetric');
    let __summaryRows = null, __wellTrajectories = null, __leafletMap = null;

    // Events
    ['dragover', 'dragleave', 'drop'].forEach(evt => dropzone.addEventListener(evt, e => {
