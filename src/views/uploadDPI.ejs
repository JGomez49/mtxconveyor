          panel.style.display = 'none';
          panel.innerHTML = '<div class="legend-title">Legend</div><div class="legend-content"></div>';
          // Toggle behavior
          L.DomEvent.on(btn, 'click', (e) => { L.DomEvent.stopPropagation(e); panel.style.display = (panel.style.display === 'none') ? 'block' : 'none'; });
          // Prevent map drag when interacting
          L.DomEvent.disableClickPropagation(container);
