    }

    function computeQuartiles(values) { const v = values.filter(Number.isFinite).slice().sort((a, b) => a - b); const n = v.length; if (!n) return null; const q = p => { const idx = (n - 1) * p; const lo = Math.floor(idx), hi = Math.ceil(idx); if (lo === hi) return v[lo]; const t = idx - lo; return v[lo] * (1 - t) + v[hi] * t; }; return { q25: q(0.25), q50: q(0.50), q75: q(0.75) }; }
    function classForValue(value, qu) { if (!qu || !Number.isFinite(value)) return 'idx-low'; const { q25, q50, q75 } = qu; if (value <= q25) return 'idx-low'; if (value <= q50) return 'idx-med'; if (value <= q75) return 'idx-high'; return 'idx-xhigh'; }
    const METRIC_LABELS = { steer_index: 'Steer Index', curvature_index: 'Curvature Index', reach_index: 'Reach Index', ddi_excel: 'DDI' };

    // === Legend control (bottom-right) with toggle
    function createLegendControl() {
      const Legend = L.Control.extend({
        options: { position: 'bottomright' },
        onAdd: function (map) {
          const container = L.DomUtil.create('div');
