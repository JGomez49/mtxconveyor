        const effort = computeSteerEffortFullPath(rowsW, idxMD, idxDOG); if (Number.isFinite(effort) && Number.isFinite(tot_len) && tot_len > 0) steer_index = effort / tot_len; const ddiRes = computeDDIExcel(rowsW, idxMD, idxDOG, idxN, idxE, tdIdx); ddi_excel = ddiRes.ddi;
