    function sniffDelimiter(text) { const sample = stripBOM(text).split(/\r\n|\n|\r/).filter(l => l.trim() !== '').slice(0, 5).join('\n'); const cand = [',', ';', '\t', '|']; let best = ',', score = -1; cand.forEach(d => { const lines = sample.split('\n'); const counts = lines.map(l => l.split(d).length); const mean = counts.reduce((a, b) => a + b, 0) / counts.length; const stdev = Math.sqrt(counts.reduce((s, c) => s + (c - mean) * (c - mean), 0) / counts.length); const s = mean - stdev; if (s > score) { score = s; best = d; } }); return best; }
    function parseCSV(text, delimiter) { try { text = stripBOM(text); if (!delimiter) delimiter = sniffDelimiter(text); const rows = []; let cur = '', row = [], i = 0, len = text.length, inQ = false; while (i < len) { const ch = text[i]; if (inQ) { if (ch === '\"') { if (i + 1 < len && text[i + 1] === '\"') { cur += '\"'; i += 2; } else { inQ = false; i++; } } else { cur += ch; i++; } } else { if (ch === '\"') { inQ = true; i++; } else if (ch === delimiter) { row.push(cur); cur = ''; i++; } else if (ch === '\r') { if (i + 1 < len && text[i + 1] === '\n') i++; row.push(cur); rows.push(row); row = []; cur = ''; i++; } else if (ch === '\n') { row.push(cur); rows.push(row); row = []; cur = ''; i++; } else { cur += ch; i++; } } } row.push(cur); rows.push(row); if (rows.length && rows[rows.length - 1].length === 1 && rows[rows.length - 1][0].trim() === '') rows.pop(); const maxCols = rows.reduce((m, r) => Math.max(m, r.length), 0); const norm = rows.map(r => r.length === maxCols ? r : r.concat(Array(maxCols - r.length).fill(''))); return { rows: norm, delimiter }; } catch (e) { throw new Error('CSV parse failed: ' + e.message); } }
    function previewCSV(rows, delimiter) { try { const badge = document.getElementById('fileMeta'); if (badge) { const base = badge.getAttribute('data-name') || badge.textContent || ''; const name = (delimiter === '\t') ? 'TAB' : (delimiter === ';' ? 'SEMICOLON' : delimiter); badge.textContent = `${base} • Delim: ${name}`; badge.setAttribute('data-name', base || badge.textContent); } } catch { } }
    const el = s => document.querySelector(s); const show = n => n.style.display = ''; const hide = n => n.style.display = 'none';
    function escapeHtml(str) { return String(str).replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;'); }
