      const basePoints = summaryRows.map(r => ({ well: r.well, lat: r.lat_out, lon: r.lon_out, val: r[metricKey], steer: r.steer_index, curv: r.curvature_index, reach: r.reach_index, ddi: r.ddi_excel })).filter(p => Number.isFinite(p.lat) && Number.isFinite(p.lon));
