        const item = document.createElement('div'); item.className = 'accordion-item'; const headingId = 'heading-' + makeId(wellKey, wIdx), collapseId = 'collapse-' + makeId(wellKey, wIdx); const header = document.createElement('h2'); header.className = 'accordion-header'; header.id = headingId; header.innerHTML = `<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#${collapseId}" aria-expanded="false" aria-controls="${collapseId}"><span class="me-2">Well: <span class="monospace">${escapeHtml(wellKey)}</span></span><span class="badge badge-soft">${rowsW.length.toLocaleString()} row(s)</span></button>`; const collapse = document.createElement('div'); collapse.id = collapseId; collapse.className = 'accordion-collapse collapse'; collapse.setAttribute('aria-labelledby', headingId); collapse.setAttribute('data-bs-parent', '#wellAccordion'); const body = document.createElement('div'); body.className = 'accordion-body';
        const tableContainer = document.createElement('div'); tableContainer.className = 'table-container'; const table = document.createElement('table'); table.className = 'table table-sm table-striped table-hover align-middle sticky-header mb-0'; const thead = document.createElement('thead'); const trHead = document.createElement('tr'); headerRow.forEach(h => { const th = document.createElement('th'); th.setAttribute('scope', 'col'); th.innerHTML = escapeHtml(h); trHead.appendChild(th); }); thead.appendChild(trHead); const tbody = document.createElement('tbody'); for (let rIdx = 0; rIdx < rowsW.length; rIdx++) { const r = rowsW[rIdx]; const tr = document.createElement('tr'); for (let c = 0; c < r.length; c++) { const td = document.createElement('td'); td.innerHTML = escapeHtml(neutralizeExcelFormula(r[c] ?? '')); tr.appendChild(td); } tbody.appendChild(tr); } table.appendChild(thead); table.appendChild(tbody); tableContainer.appendChild(table); body.appendChild(tableContainer); collapse.appendChild(body); item.appendChild(header); item.appendChild(collapse); mainAcc.appendChild(item);
        if (idxLat >= 0 && idxLon >= 0) { const latlngs = []; for (const rr of rowsW) { const la = parseNumber(rr[idxLat]); const lo = parseNumber(rr[idxLon]); if (Number.isFinite(la) && Number.isFinite(lo)) latlngs.push([la, lo]); } if (latlngs.length > 1) trajectories.push({ well: wellKey, latlngs }); }
        summaryRows.push({ well: wellKey, icp_md, icp_tvd, max_build_dls, max_lat_dls, curvature_index, reach_index, td_md, lateral_md, steer_build_md, steer_lat_md, pct_build, pct_lat, steer_index, lat_out, lon_out, ddi_excel });
      });
      const outer = document.createElement('div'); outer.className = 'accordion'; outer.id = 'allWellsAccordion'; const outItem = document.createElement('div'); outItem.className = 'accordion-item'; const outHeadingId = 'heading-allwells', outCollapseId = 'collapse-allwells'; const totalRowsAll = Array.from(byWell.values()).reduce((s, arr) => s + (arr?.length || 0), 0); const outHeader = document.createElement('h2'); outHeader.className = 'accordion-header'; outHeader.id = outHeadingId; outHeader.innerHTML = `<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#${outCollapseId}" aria-expanded="false" aria-controls="${outCollapseId}">All Wells <span class="badge bg-primary ms-2">${wellKeys.length.toLocaleString()} well(s)</span> <span class="badge badge-soft ms-2">${totalRowsAll.toLocaleString()} row(s)</span></button>`; const outCollapse = document.createElement('div'); outCollapse.id = outCollapseId; outCollapse.className = 'accordion-collapse collapse'; outCollapse.setAttribute('aria-labelledby', outHeadingId); const outBody = document.createElement('div'); outBody.className = 'accordion-body p-2'; outBody.appendChild(mainAcc); outCollapse.appendChild(outBody); outItem.appendChild(outHeader); outItem.appendChild(outCollapse); outer.appendChild(outItem); groupContainer.innerHTML = ''; groupContainer.appendChild(outer); wellCount.textContent = `${renderedWells.toLocaleString()} well(s)`; show(metaRow);
      summaryRows.sort((a, b) => new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' }).compare(a.well, b.well)); const sAcc = document.createElement('div'); sAcc.className = 'accordion mt-3-5'; sAcc.id = 'summaryAccordion'; const sItem = document.createElement('div'); sItem.className = 'accordion-item'; const sHeadingId = 'heading-summary', sCollapseId = 'collapse-summary'; const sHeader = document.createElement('h2'); sHeader.className = 'accordion-header'; sHeader.id = sHeadingId; sHeader.innerHTML = `<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#${sCollapseId}" aria-expanded="false" aria-controls="${sCollapseId}">Summary (per well) <span class="badge badge-soft ms-2">${summaryRows.length.toLocaleString()} item(s)</span></button>`; const sCollapse = document.createElement('div'); sCollapse.id = sCollapseId; sCollapse.className = 'accordion-collapse collapse'; sCollapse.setAttribute('aria-labelledby', sHeadingId); const sBody = document.createElement('div'); sBody.className = 'accordion-body p-0'; const sWrap = document.createElement('div'); sWrap.className = 'table-container'; const sTable = document.createElement('table'); sTable.className = 'table table-sm table-striped table-hover align-middle sticky-header mb-0'; const sThead = document.createElement('thead'); sThead.innerHTML = `<tr><th>Well</th><th>ICP MD</th><th>ICP TVD</th><th>Max Build DLS</th><th>Max Lat DLS</th><th>TD MD</th><th>Lateral MD</th><th>Steer Build MD</th><th>Steer Lat MD</th><th>% Build Steer</th><th>% Lat Steer</th><th>Lat</th><th>Long</th><th>Curvature Index</th><th>Reach Index</th><th>Steer Index</th><th>DDI</th></tr>`; const sTbody = document.createElement('tbody'); summaryRows.forEach(r => { const tr = document.createElement('tr'); tr.innerHTML = `<td class="monospace">${escapeHtml(r.well)}</td><td>${fmt2(r.icp_md)}</td><td>${fmt2(r.icp_tvd)}</td><td>${fmt2(r.max_build_dls)}</td><td>${fmt2(r.max_lat_dls)}</td><td>${fmt2(r.td_md)}</td><td>${fmt2(r.lateral_md)}</td><td>${fmt2(r.steer_build_md)}</td><td>${fmt2(r.steer_lat_md)}</td><td>${fmtPct2(r.pct_build)}</td><td>${fmtPct2(r.pct_lat)}</td><td>${fmt6(r.lat_out)}</td><td>${fmt6(r.lon_out)}</td><td>${fmt2(r.curvature_index)}</td><td>${fmt2(r.reach_index)}</td><td>${fmt2(r.steer_index)}</td><td>${fmt2(r.ddi_excel)}</td>`; sTbody.appendChild(tr); }); sTable.appendChild(sThead); sTable.appendChild(sTbody); sWrap.appendChild(sTable); sBody.appendChild(sWrap); sCollapse.appendChild(sBody); sItem.appendChild(sHeader); sItem.appendChild(sCollapse); sAcc.appendChild(sItem); groupContainer.appendChild(sAcc);
