

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>DPI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" sizes="32x64" href="https://res.cloudinary.com/metacortexjohn/image/upload/v1658373747/Icono_Metacortex_ahblhc.png">

  <!-- https://res.cloudinary.com/metacortexjohn/image/upload/v1711167914/Canadian_Natural_logo_ygbbox.png -->
   <!-- https://res.cloudinary.com/metacortexjohn/image/upload/v1658373747/Icono_Metacortex_ahblhc.png -->

  <!-- Bootswatch Slate (Bootstrap 5) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/slate/bootstrap.min.css" />

  <!-- Leaflet (map) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

  <style>
    /* --- Layout & visuals --- */
    body { padding: .75rem; }
    .container-fluid { padding-left: 0; padding-right: 0; }

    .dropzone {
      position: relative;
      border: 2px dashed #6c757d;
      border-radius: .5rem;
      padding: 1.25rem;
      text-align: center;
      color: #adb5bd;
      transition: border-color .2s ease, color .2s ease, background-color .2s ease;
      cursor: pointer;
    }
    .dropzone.dragover { border-color: #0d6efd; color: #e9ecef; background-color: rgba(13,110,253,.1); }
    .invisible-input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }

    .small-muted { font-size: .9rem; color: #adb5bd; }
    .badge-soft { background-color: rgba(108,117,125,.25); color: #ced4da; border: 1px solid rgba(108,117,125,.4); }
    .monospace { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace; }
    .muted { color: #adb5bd; }

    .sticky-header thead th { position: sticky; top: 0; z-index: 2; background-color: #2b2f32; }
    .table-sm>:not(caption)>*>* { padding: .25rem .5rem; }
    .accordion-button { padding: .5rem .75rem; }
    .accordion-body { padding: .5rem .75rem; }
    .table-container { overflow: auto; max-height: 70vh; }

    .wb-heading { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; margin: .5rem .25rem; }
    .wb-heading .title { font-weight: 600; }
    .wb-block { border: 1px solid rgba(108,117,125,.35); border-radius: .25rem; margin-bottom: .5rem; }
    .wb-block .table-container { border-top: 1px solid rgba(108,117,125,.25); }

    .badge-lp { background-color: #ffc107; color: #212529; }
    .badge-td { background-color: #198754; }

    .mt-3-5 { margin-top: 1rem; }

    /* Map height doubled (~2x) */
    #map { height: 860px; border: 1px solid rgba(108,117,125,.35); border-radius: .25rem; }

    /* --- Metric/Index map markers (DivIcon) --- */

    /* .metric-marker { container } */

    .metric-bubble {
      width: 44px; height: 44px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-weight: 800; font-size: 16px; line-height: 1;
      border: 2px solid rgba(0,0,0,.35);
      box-shadow: 0 0 8px rgba(0,0,0,.35);
      text-shadow: 0 1px 2px rgba(0,0,0,.4);
      user-select: none;
    }
    /* Colors (data-driven by quartiles) */
    .idx-low   .metric-bubble { background: #198754; }  /* green   */
    .idx-med   .metric-bubble { background: #fd7e14; }  /* orange  */
    .idx-high  .metric-bubble { background: #dc3545; }  /* red     */
    .idx-xhigh .metric-bubble { background: #6f42c1; }  /* purple  */
  </style>
</head>
<body>
  <div class="container-fluid">
    <header class="mb-3">
      <img src="https://res.cloudinary.com/metacortexjohn/image/upload/v1711167914/Canadian_Natural_logo_ygbbox.png" alt="Girl in a jacket" width="250" height="100">
      <h1 class="h4 mb-1">Directional Planning Index</h1>
      <!-- <p class="small-muted mb-0">
        Grouped by <span class="monospace">well</span> (accordion) and <span class="monospace">wellbore</span> (tables).<br />
        Adds a <strong>Key Point</strong> column marking <span class="monospace">LP</span> (first Incl &gt; 88°) and <span class="monospace">TD</span> (max MD).<br />
        Summary includes ICP/TD metrics, Max DLS, Steering MD &amp; %, <em>Curvature Index</em> (weighted),
        Reach Index, normalized Steer Index, <strong>DDI (Excel macro)</strong>, and a map of <strong>surface</strong> Lat/Long with selectable marker metric.
      </p> -->
    </header>

    <div class="card mb-3">
      <div class="card-body py-2">
        <div class="row g-2 align-items-center">
          <div class="col-12 col-lg">
            <label class="form-label mb-1">Upload CSV</label>
            <div id="dropzone" class="dropzone">
              <strong>Drag &amp; drop</strong> a CSV file here, or <span class="text-info text-decoration-underline">click to browse</span>.
              <input id="fileInput" class="invisible-input" type="file" accept=".csv,text/csv" />
            </div>
            <!-- <div class="form-text mt-1">All parsing happens locally in your browser.</div> -->
          </div>
          <div class="col-6 col-sm-auto">
            <div class="form-check mb-0">
              <input class="form-check-input" type="checkbox" id="hasHeader" checked />
              <label class="form-check-label" for="hasHeader">First row is header</label>
            </div>
          </div>
          <div class="col-6 col-sm-auto">
            <button id="clearBtn" class="btn btn-outline-secondary btn-sm" type="button" disabled>Clear</button>
          </div>
        </div>
      </div>
    </div>

    <div class="d-grid gap-2">
        <a href="/notes" class="btn btn-primary btn-block my-2">Back</a>
    </div>

    <div id="metaRow" class="row gy-2 gx-2 mb-2" style="display:none;">
      <div class="col-12 col-md"><span id="fileMeta" class="badge badge-soft"></span></div>
      <div class="col-auto"><span id="rowCount" class="badge bg-dark"></span></div>
      <div class="col-auto"><span id="colCount" class="badge bg-dark"></span></div>
      <div class="col-auto"><span id="wellCount" class="badge bg-primary"></span></div>
    </div>

    <!-- OUTER ACCORDION (wraps all wells) -->
    <div id="groupContainer"></div>

    <!-- Map controls -->
    <div class="mt-3-5">
      <div class="d-flex align-items-center gap-2 mb-2">
        <label for="markerMetric" class="form-label mb-0">Marker shows</label>
        <select id="markerMetric" class="form-select form-select-sm" style="max-width: 260px;">
          <option value="steer_index" selected>Steer Index</option>
          <option value="curvature_index">Curvature Index</option>
          <option value="reach_index">Reach Index</option>
          <option value="ddi_excel">DDI</option>
        </select>
        <span class="small-muted">Tip: hover a marker to see the wellbore with all indexes; click for details.</span>
      </div>
      <h2 class="h6 mb-2">Surface locations map (toggle Streets / Satellite / Terrain)</h2>
      <div id="map" role="region" aria-label="Map of surface Lat/Long"></div>
    </div>

    <div id="errorBox" class="alert alert-danger mt-3" role="alert" style="display:none;"></div>
  </div>

  <!-- Bootstrap JS (bundle includes Popper) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script>
    /* ================= Hardened CSV parsing + diagnostics ================= */
    function stripBOM(text) {
      if (!text) return text;
      if (text.charCodeAt(0) === 0xFEFF) return text.slice(1);
      return text;
    }
    function sniffDelimiter(text) {
      const sample = stripBOM(text).split(/\r\n|\n|\r/).filter(l => l.trim() !== '').slice(0, 5).join('\n');
      const candidates = [',', ';', '\t', '|'];
      let best = ',', bestScore = -1;
      candidates.forEach(d => {
        const lines = sample.split('\n');
        const counts = lines.map(l => l.split(d).length);
        const mean = counts.reduce((a,b)=>a+b,0)/counts.length;
        const stdev = Math.sqrt(counts.reduce((s,c)=>s+(c-mean)*(c-mean),0)/counts.length);
        const score = mean - stdev;
        if (score > bestScore) { bestScore = score; best = d; }
      });
      return best;
    }
    function parseCSV(text, delimiter) {
      try {
        text = stripBOM(text);
        if (!delimiter) delimiter = sniffDelimiter(text);

        const rows = [];
        let cur = '', row = [];
        let i = 0, len = text.length, inQuotes = false;

        while (i < len) {
          const ch = text[i];
          if (inQuotes) {
            if (ch === '"') {
              if (i + 1 < len && text[i + 1] === '"') { cur += '"'; i += 2; }
              else { inQuotes = false; i++; }
            } else { cur += ch; i++; }
          } else {
            if (ch === '"') { inQuotes = true; i++; }
            else if (ch === delimiter) { row.push(cur); cur = ''; i++; }
            else if (ch === '\r') { if (i + 1 < len && text[i + 1] === '\n') i++; row.push(cur); rows.push(row); row = []; cur = ''; i++; }
            else if (ch === '\n') { row.push(cur); rows.push(row); row = []; cur = ''; i++; }
            else { cur += ch; i++; }
          }
        }
        row.push(cur); rows.push(row);

        // Trim trailing empty last line
        if (rows.length && rows[rows.length - 1].length === 1 && rows[rows.length - 1][0].trim() === '') rows.pop();

        // Normalize width
        const maxCols = rows.reduce((m, r) => Math.max(m, r.length), 0);
        const normalized = rows.map(r => r.length === maxCols ? r : r.concat(Array(maxCols - r.length).fill('')));
        return { rows: normalized, delimiter };
      } catch (e) {
        throw new Error(`CSV parse failed: ${e.message}`);
      }
    }
    function previewCSV(rows, delimiter) {
      try {
        const first = rows.slice(0, Math.min(rows.length, 5));
        console.log('[CSV] Detected delimiter:', JSON.stringify(delimiter));
        console.table(first);
        const badge = document.getElementById('fileMeta');
        if (badge) {
          const delimName = (delimiter === '\t') ? 'TAB' : (delimiter === ';' ? 'SEMICOLON' : delimiter);
          const baseText = badge.getAttribute('data-name') || badge.textContent || '';
          if (!badge.getAttribute('data-name')) badge.setAttribute('data-name', baseText);
          badge.textContent = `${baseText} • Delim: ${delimName}`;
        }
      } catch {}
    }

    /* ================= DOM helpers ================= */
    const el = (sel) => document.querySelector(sel);
    const show = (n) => n.style.display = '';
    const hide = (n) => n.style.display = 'none';
    function escapeHtml(str) {
      return String(str)
        .replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;')
        .replaceAll('"','&quot;').replaceAll("'",'&#39;');
    }
    function makeId(str, idx) {
      const base = String(str ?? '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
      return (base || 'item') + '-' + idx;
    }
    function fmt2(x){ if(x==null||Number.isNaN(x)||!Number.isFinite(x))return''; return Number(x).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}); }
    function fmt6(x){ if(x==null||Number.isNaN(x)||!Number.isFinite(x))return''; return Number(x).toLocaleString(undefined,{minimumFractionDigits:6,maximumFractionDigits:6}); }
    function fmtPct2(x){ if(x==null||Number.isNaN(x)||!Number.isFinite(x))return''; return Number(x).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2})+'%'; }
    function fmtMarker(metricKey, x){
      if (x==null || Number.isNaN(x) || !Number.isFinite(x)) return '';
      if (metricKey === 'ddi_excel') return Number(x).toFixed(1);
      return Number(x).toFixed(2);
    }
    function getColumnIndex(headerRow, nameCandidates) {
      const lowers = headerRow.map(h => String(h ?? '').trim().toLowerCase());
      for (const cand of nameCandidates) {
        const idx = lowers.indexOf(cand.toLowerCase());
        if (idx >= 0) return idx;
      }
      return -1;
    }
    function parseNumber(val) {
      if (val === null || val === undefined) return NaN;
      const s = String(val).replace(/,/g, '').trim();
      const m = s.match(/-?\d+(\.\d+)?/);
      return m ? parseFloat(m[0]) : NaN;
    }

    /* ================= Metrics helpers ================= */
    function meanStd(values) {
      const vals = values.filter(v => Number.isFinite(v));
      const n = vals.length; if (!n) return { mean: null, std: null };
      const sum = vals.reduce((a,b)=>a+b,0);
      const mean = sum / n;
      const variance = vals.reduce((s,x)=> s + (x-mean)*(x-mean), 0) / n;
      return { mean, std: Math.sqrt(variance) };
    }
    function accumulateSteeringMD(rows, idxMD, idxDOG, startIdx, endIdx){
      if (idxMD < 0 || idxDOG < 0) return null;
      if (!Array.isArray(rows) || rows.length < 2) return 0;
      let total = 0;
      const from = Math.max(1, startIdx), to = Math.min(endIdx, rows.length - 1);
      if (to < from) return 0;
      for (let i = from; i <= to; i++) {
        const dls = parseNumber(rows[i][idxDOG]); if (!(dls > 1)) continue;
        const mdCurr = parseNumber(rows[i][idxMD]), mdPrev = parseNumber(rows[i-1][idxMD]);
        if (Number.isFinite(mdCurr) && Number.isFinite(mdPrev)) {
          const d = mdCurr - mdPrev; if (d > 0) total += d;
        }
      }
      return total;
    }
    // Full-path steering effort Σ (max(DLS-1,0)^2 * ΔMD)
    function computeSteerEffortFullPath(rows, idxMD, idxDOG){
      if (idxMD < 0 || idxDOG < 0 || !Array.isArray(rows) || rows.length < 2) return null;
      let totalEffort = 0;
      for (let i = 1; i < rows.length; i++) {
        const dls = parseNumber(rows[i][idxDOG]);
        const mdCurr = parseNumber(rows[i][idxMD]);
        const mdPrev = parseNumber(rows[i-1][idxMD]);
        if (!Number.isFinite(dls) || !Number.isFinite(mdCurr) || !Number.isFinite(mdPrev)) continue;
        const dMD = mdCurr - mdPrev; if (dMD <= 0) continue;
        const above = Math.max(dls - 1, 0);
        totalEffort += (above * above) * dMD;
      }
      return totalEffort;
    }
    // DDI (Excel macro method)
    // DDI = log10( TMD * cum_AHD * tortuosity ), cum_AHD = Σ√(ΔN²+ΔE²),
    // cum_Tor = Σ(ΔMD * DLS'), DLS' = DLS (0 -> 0.5); tortuosity = cum_Tor / TMD
    function computeDDIExcel(rows, idxMD, idxDOG, idxN, idxE, tdIdx){
      if (!rows || rows.length < 2) return { ddi: null, cum_AHD: null, cum_Tor: null, tortuosity: null, TMD: null };
      const endRowIndex = Number.isInteger(tdIdx) && tdIdx >= 0 ? tdIdx : rows.length - 1;
      const TMD = idxMD>=0 ? parseNumber(rows[endRowIndex][idxMD]) : NaN;

      let cum_AHD = 0, cum_Tor = 0;
      for (let i = 1; i < rows.length; i++) {
        if (idxN >= 0 && idxE >= 0) {
          const n = parseNumber(rows[i][idxN]), np = parseNumber(rows[i-1][idxN]);
          const e = parseNumber(rows[i][idxE]), ep = parseNumber(rows[i-1][idxE]);
          if ([n,np,e,ep].every(Number.isFinite)) {
            const dN = n - np, dE = e - ep;
            const seg = Math.hypot(dN, dE);
            if (seg > 0) cum_AHD += seg;
          }
        }
        if (idxMD >= 0 && idxDOG >= 0) {
          const md = parseNumber(rows[i][idxMD]), mdp = parseNumber(rows[i-1][idxMD]);
          if (Number.isFinite(md) && Number.isFinite(mdp)) {
            const CL = md - mdp;
            if (CL > 0) {
              let dls = parseNumber(rows[i][idxDOG]);
              if (!Number.isFinite(dls) || dls === 0) dls = 0.5; // Excel rule
              cum_Tor += (CL * dls); // macro style (no /30)
            }
          }
        }
      }
      if (Number.isFinite(TMD) && TMD > 0) {
        const tortuosity = cum_Tor / TMD;
        const composite = TMD * cum_AHD * tortuosity;
        const ddi = (Number.isFinite(composite) && composite > 0) ? Math.log10(composite) : null;
        return { ddi, cum_AHD, cum_Tor, tortuosity, TMD };
      }
      return { ddi: null };
    }

    /* ================= UI elements / state ================= */
    const dropzone = el('#dropzone');
    const fileInput = el('#fileInput');
    const errorBox = el('#errorBox');
    const clearBtn = el('#clearBtn');
    const hasHeaderCheckbox = el('#hasHeader');
    const fileMeta = el('#fileMeta');
    const rowCount = el('#rowCount');
    const colCount = el('#colCount');
    const wellCount = el('#wellCount');
    const metaRow = el('#metaRow');
    const groupContainer = el('#groupContainer');
    const markerMetricSelect = el('#markerMetric');

    let __summaryRows = null;     // for map re-render on marker metric change
    let __leafletMap = null;      // map instance reference

    /* ================= Events ================= */
    dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('dragover'); });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault(); dropzone.classList.remove('dragover');
      const file = e.dataTransfer.files && e.dataTransfer.files[0];
      if (file) handleFile(file);
    });
    fileInput.addEventListener('change', (e) => {
      const file = e.target.files && e.target.files[0];
      if (file) handleFile(file);
    });
    clearBtn.addEventListener('click', () => {
      groupContainer.innerHTML = '';
      hide(errorBox); hide(metaRow);
      fileInput.value = '';
      clearBtn.disabled = true;
      window.__csvRows = null;
      __summaryRows = null;
      if (__leafletMap) { __leafletMap.remove(); __leafletMap = null; }
    });
    hasHeaderCheckbox.addEventListener('change', () => {
      if (window.__csvRows && window.__csvRows.length) {
        renderWellsAndSummary(window.__csvRows, window.__delimiter, hasHeaderCheckbox.checked);
      }
    });
    markerMetricSelect.addEventListener('change', () => {
      if (__summaryRows) renderMap(__summaryRows, markerMetricSelect.value);
    });

    /* ================= File I/O ================= */
    function handleFile(file){
      hide(errorBox);
      const allowed = ['text/csv','application/vnd.ms-excel','text/plain','application/csv','text/comma-separated-values'];
      const isCsvExt = file.name.toLowerCase().endsWith('.csv');
      if(!isCsvExt && !allowed.includes(file.type)) {
        return showError('Please upload a CSV file (.csv).');
      }

      const reader = new FileReader();
      reader.onload = () => {
        try {
          const text = reader.result;
          const { rows, delimiter } = parseCSV(text);
          if(!rows || !rows.length) return showError('The file appears to be empty.');

          window.__csvRows = rows;
          window.__delimiter = delimiter;

          // small preview (Console) + show delimiter in badge
          previewCSV(rows, delimiter);

          renderWellsAndSummary(rows, delimiter, hasHeaderCheckbox.checked);

          const sizeKB = (file.size / 1024).toFixed(1);
          fileMeta.textContent = `${file.name} • ${sizeKB} KB`;
          fileMeta.setAttribute('data-name', `${file.name} • ${sizeKB} KB`);
          rowCount.textContent = `${rows.length.toLocaleString()} row(s)`;
          colCount.textContent = `${(rows[0] ? rows[0].length : 0).toLocaleString()} column(s)`;
          show(metaRow); clearBtn.disabled = false;
        } catch (err) {
          console.error('[CSV]', err);
          showError(`Could not parse this CSV: ${err.message}. Check delimiter, quotes, and header setting.`);
        }
      };
      reader.onerror = () => showError('Could not read the file. Please try again.');
      reader.readAsText(file);
    }
    function showError(msg) {
      errorBox.textContent = msg; show(errorBox); hide(metaRow); groupContainer.innerHTML = '';
    }

    /* ================= Well parsing ================= */
    function extractWellParts(value) {
      const raw = (value ?? '').toString().trim();
      if (!raw) return { well: '', wellbore: '' };

      // Pattern: last "<digits>_<alnum+>"
      const matches = [...raw.matchAll(/(\d+)_([A-Za-z0-9]+)/g)];
      if (matches.length) {
        const m = matches[matches.length - 1];
        return { well: m[1], wellbore: m[2] };
      }

      // Fallback: split on last underscore
      const usIdx = raw.lastIndexOf('_');
      if (usIdx > 0 && usIdx < raw.length - 1) {
        const left = raw.slice(0, usIdx);
        const right = raw.slice(usIdx + 1);
        const dmatch = left.match(/(\d+)(?!.*\d)/);
        return { well: dmatch ? dmatch[1] : left.trim(), wellbore: right.trim() };
      }

      const onlyDigits = raw.match(/\d+/);
      if (onlyDigits) return { well: onlyDigits[0], wellbore: '' };

      return { well: raw, wellbore: '' };
    }

    /* ================= Render + Summary + Map ================= */
    function renderWellsAndSummary(rows, delimiter, useHeader){
      // Normalize rows width (already normalized in parseCSV, but keep defensive)
      const maxCols = rows.reduce((m, r) => Math.max(m, r.length), 0);
      const normalized = rows.map(r => r.length === maxCols ? r : r.concat(Array(maxCols - r.length).fill('')));

      const headerRow = useHeader ? normalized[0] : Array.from({ length: maxCols }, (_, i) => `Column ${i + 1}`);
      const dataRows   = useHeader ? normalized.slice(1) : normalized;

      // Column indices (headers are case-insensitive)
      const idxWellCol = (() => {
        const lowers = headerRow.map(h => String(h).trim().toLowerCase());
        const i = lowers.indexOf('well'); return i >= 0 ? i : 0; // fallback to first column if not found
      })();
      const idxIncl = getColumnIndex(headerRow, ['incl','inclination']);
      const idxMD   = getColumnIndex(headerRow, ['md']);
      const idxTVD  = getColumnIndex(headerRow, ['tvd']);
      const idxDOG  = getColumnIndex(headerRow, ['dogleg','dls']); // prefer 'dogleg', else 'dls'
      const idxCmt  = getColumnIndex(headerRow, ['comments','comment']);
      const idxN    = getColumnIndex(headerRow, ['local n','local north','northing','n']); // Local N (optional)
      const idxE    = getColumnIndex(headerRow, ['local e','local east','easting','e']);  // Local E (optional)
      const idxLat  = getColumnIndex(headerRow, ['latitude','lat']);                      // Latitude (surface)
      const idxLon  = getColumnIndex(headerRow, ['longitude','long','lon']);              // Longitude (surface)

      // Group rows by base well -> wellbore
      const byWell = new Map();
      for (const r of dataRows) {
        const parts = extractWellParts(r[idxWellCol]);
        const base = (parts.well || '').trim();
        const wb = (parts.wellbore || '').trim();
        if (!base) continue;
        if (!byWell.has(base)) byWell.set(base, new Map());
        const wbMap = byWell.get(base);
        if (!wbMap.has(wb)) wbMap.set(wb, []);
        wbMap.get(wb).push(r);
      }

      // Sorted well keys
      const collator = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
      const wellKeys = Array.from(byWell.keys()).sort((a, b) => collator.compare(a, b));

      // ===== Inner wells accordion =====
      const mainAccordion = document.createElement('div');
      mainAccordion.className = 'accordion';
      mainAccordion.id = 'wellAccordion';

      // Summary collection
      const summaryRows = [];
      let renderedWells = 0;

      // Render each well
      wellKeys.forEach((wellKey, wIdx) => {
        const wbMap = byWell.get(wellKey);
        const wbKeys = Array.from(wbMap.keys()).filter(k => k && k.trim() !== '').sort((a, b) => collator.compare(a, b));
        if (!wbKeys.length) return;
        renderedWells++;

        const item = document.createElement('div'); item.className = 'accordion-item';
        const headingId = 'heading-' + makeId(wellKey, wIdx);
        const collapseId = 'collapse-' + makeId(wellKey, wIdx);

        const totalRows = wbKeys.reduce((s, k) => s + (wbMap.get(k)?.length || 0), 0);

        const header = document.createElement('h2');
        header.className = 'accordion-header'; header.id = headingId;
        header.innerHTML = `
          <button class="accordion-button collapsed" type="button"
                  data-bs-toggle="collapse" data-bs-target="#${collapseId}"
                  aria-expanded="false" aria-controls="${collapseId}">
            <span class="me-2">Well: <span class="monospace">${escapeHtml(wellKey)}</span></span>
            <span class="badge bg-secondary me-2">${wbKeys.length.toLocaleString()} wellbore(s)</span>
            <span class="badge badge-soft">${totalRows.toLocaleString()} row(s)</span>
          </button>`;

        const collapse = document.createElement('div');
        collapse.id = collapseId; collapse.className = 'accordion-collapse collapse';
        collapse.setAttribute('aria-labelledby', headingId);
        collapse.setAttribute('data-bs-parent', '#wellAccordion');

        const body = document.createElement('div'); body.className = 'accordion-body';

        // augmented header for wellbore tables (Key Point column after Comments)
        const insertPos = idxCmt >= 0 ? idxCmt + 1 : headerRow.length;
        const augmentedHeader = headerRow.slice(0, insertPos).concat(['Key Point']).concat(headerRow.slice(insertPos));

        // Render each wellbore under this well
        wbKeys.forEach((wbKey) => {
          const rowsWB = wbMap.get(wbKey) || [];
          if (!rowsWB.length) return;

          // Detect LP (first Incl > 88) and TD (max MD)
          let lpIdx = -1, tdIdx = -1, maxMD = -Infinity;
          if (idxIncl >= 0) {
            for (let i = 0; i < rowsWB.length; i++) {
              const incl = parseNumber(rowsWB[i][idxIncl]);
              if (!Number.isNaN(incl) && incl > 88) { lpIdx = i; break; }
            }
          }
          if (idxMD >= 0) {
            for (let i = 0; i < rowsWB.length; i++) {
              const mdVal = parseNumber(rowsWB[i][idxMD]);
              if (!Number.isNaN(mdVal) && mdVal >= maxMD) { maxMD = mdVal; tdIdx = i; }
            }
          }

          // Core metrics
          let icp_md=null, icp_tvd=null, td_md=null, lateral_md=null;
          let max_build_dls=null, max_lat_dls=null;
          let steer_build_md=null, steer_lat_md=null;
          let pct_build=null, pct_lat=null;
          let dls_mean_build=null, dls_std_build=null, dls_mean_lat=null, dls_std_lat=null;
          let curv_build_index=null, curv_lat_index=null, curvature_index=null;
          let steer_index=null, reach_index=null, ddi_excel=null;

          // Surface Latitude / Longitude (from FIRST row)
          let lat_out=null, lon_out=null;

          const md_surface = (idxMD>=0 && rowsWB.length) ? parseNumber(rowsWB[0][idxMD]) : NaN;
          if (lpIdx>=0 && idxMD>=0) icp_md = parseNumber(rowsWB[lpIdx][idxMD]);
          if (lpIdx>=0 && idxTVD>=0) icp_tvd = parseNumber(rowsWB[lpIdx][idxTVD]);
          if (tdIdx>=0 && idxMD>=0)  td_md  = parseNumber(rowsWB[tdIdx][idxMD]);
          if (Number.isFinite(td_md) && Number.isFinite(icp_md)) lateral_md = td_md - icp_md;

          // Reach Index: TD_MD / LP_TVD
          if (Number.isFinite(td_md) && Number.isFinite(icp_tvd) && icp_tvd > 0) reach_index = td_md / icp_tvd;

          // DLS stats & steering
          if (idxDOG >= 0 && rowsWB.length) {
            if (lpIdx >= 0) {
              let maxB = -Infinity; const valsB = [];
              for (let i = 0; i <= lpIdx && i < rowsWB.length; i++) {
                const v = parseNumber(rowsWB[i][idxDOG]); if (!Number.isNaN(v)) { maxB = Math.max(maxB, v); valsB.push(v); }
              }
              if (maxB !== -Infinity) max_build_dls = maxB;
              const msB = meanStd(valsB); dls_mean_build = msB.mean; dls_std_build = msB.std;
              const totalBuild = accumulateSteeringMD(rowsWB, idxMD, idxDOG, 0, lpIdx);
              if (totalBuild !== null) steer_build_md = totalBuild;
            }
            if (lpIdx >= 0 && tdIdx >= 0 && tdIdx > lpIdx) {
              let maxL = -Infinity; const valsL = [];
              for (let i = lpIdx + 1; i <= tdIdx && i < rowsWB.length; i++) {
                const v = parseNumber(rowsWB[i][idxDOG]); if (!Number.isNaN(v)) { maxL = Math.max(maxL, v); valsL.push(v); }
              }
              if (maxL !== -Infinity) max_lat_dls = maxL;
              const msL = meanStd(valsL); dls_mean_lat = msL.mean; dls_std_lat = msL.std;
              const totalLat = accumulateSteeringMD(rowsWB, idxMD, idxDOG, lpIdx + 1, tdIdx);
              if (totalLat !== null) steer_lat_md = totalLat;
            }
          }

          // Segment lengths
          const build_length = (Number.isFinite(icp_md) && Number.isFinite(md_surface)) ? (icp_md - md_surface) : NaN;
          const lat_length   = (Number.isFinite(td_md)   && Number.isFinite(icp_md))    ? (td_md - icp_md)       : NaN;
          const total_length = (Number.isFinite(td_md)   && Number.isFinite(md_surface))? (td_md - md_surface)    : NaN;

          if (Number.isFinite(steer_build_md) && Number.isFinite(build_length) && build_length > 0)
            pct_build = (steer_build_md / build_length) * 100;
          if (Number.isFinite(steer_lat_md) && Number.isFinite(lat_length) && lat_length > 0)
            pct_lat = (steer_lat_md / lat_length) * 100;

          // Curvature indices
          if ([max_build_dls, dls_mean_build, dls_std_build].every(Number.isFinite))
            curv_build_index = 0.5*max_build_dls + 0.25*dls_mean_build + 0.25*dls_std_build;
          if ([max_lat_dls, dls_mean_lat, dls_std_lat].every(Number.isFinite))
            curv_lat_index   = 0.5*max_lat_dls   + 0.25*dls_mean_lat   + 0.25*dls_std_lat;

          if (Number.isFinite(total_length) && total_length > 0 &&
              Number.isFinite(build_length) && Number.isFinite(lat_length) &&
              Number.isFinite(curv_build_index) && Number.isFinite(curv_lat_index)) {
            const pB = build_length / total_length;
            const pL = lat_length   / total_length;
            curvature_index = pB*curv_build_index + pL*curv_lat_index;
          }

          // Steer_Index: normalized full‑path steering effort per unit length
          const effort = computeSteerEffortFullPath(rowsWB, idxMD, idxDOG);
          if (Number.isFinite(effort) && Number.isFinite(total_length) && total_length > 0)
            steer_index = effort / total_length;

          // DDI (Excel macro)
          const ddiRes = computeDDIExcel(rowsWB, idxMD, idxDOG, idxN, idxE, tdIdx);
          ddi_excel = ddiRes.ddi;

          // Surface Lat/Long (first row)
          const surfaceRowIndex = 0;
          if (idxLat >= 0) lat_out = parseNumber(rowsWB[surfaceRowIndex][idxLat]);
          if (idxLon >= 0) lon_out = parseNumber(rowsWB[surfaceRowIndex][idxLon]);

          /* ---------- Render wellbore table with Key Point column ---------- */
          const block = document.createElement('div'); block.className = 'wb-block';
          const wbHeading = document.createElement('div'); wbHeading.className = 'wb-heading';
          wbHeading.innerHTML = `
            <span class="title">Wellbore: <span class="monospace">${escapeHtml(wbKey)}</span></span>
            <span class="badge bg-secondary">${rowsWB.length.toLocaleString()} row(s)</span>
            <span class="muted">LP: Incl &gt; 88°; TD: max MD</span>`;
          block.appendChild(wbHeading);

          const tableContainer = document.createElement('div'); tableContainer.className = 'table-container';
          const table = document.createElement('table'); table.className = 'table table-sm table-striped table-hover align-middle sticky-header mb-0';

          const thead = document.createElement('thead'); const trHead = document.createElement('tr');
          augmentedHeader.forEach((h) => {
            const th = document.createElement('th'); th.setAttribute('scope','col'); th.innerHTML = escapeHtml(h); trHead.appendChild(th);
          });
          thead.appendChild(trHead);

          const tbody = document.createElement('tbody');
          for (let rIdx = 0; rIdx < rowsWB.length; rIdx++) {
            const r = rowsWB[rIdx];
            const isLP = rIdx === lpIdx, isTD = rIdx === tdIdx;
            let kp = '';
            if (isLP && isTD) kp = `<span class="badge badge-lp me-1">LP</span><span class="badge badge-td">TD</span>`;
            else if (isLP) kp = `<span class="badge badge-lp">LP</span>`;
            else if (isTD) kp = `<span class="badge badge-td">TD</span>`;

            const tr = document.createElement('tr');
            // left segment
            for (let c = 0; c < Math.min(insertPos, headerRow.length); c++) {
              const td = document.createElement('td'); td.innerHTML = escapeHtml(r[c] ?? ''); tr.appendChild(td);
            }
            // Key Point cell
            const tdKP = document.createElement('td'); tdKP.innerHTML = kp; tr.appendChild(tdKP);
            // right segment
            for (let c = insertPos; c < headerRow.length; c++) {
              const td = document.createElement('td'); td.innerHTML = escapeHtml(r[c] ?? ''); tr.appendChild(td);
            }
            // any extra cells beyond header
            for (let c = headerRow.length; c < r.length; c++) {
              const td = document.createElement('td'); td.innerHTML = escapeHtml(r[c] ?? ''); tr.appendChild(td);
            }
            tbody.appendChild(tr);
          }

          table.appendChild(thead); table.appendChild(tbody);
          tableContainer.appendChild(table); block.appendChild(tableContainer);
          body.appendChild(block);

          // Add to Summary (wellbore label)
          const label = `${wellKey}_${wbKey}`;
          summaryRows.push({
            well: label,                 // WELLBORE identifier
            icp_md, icp_tvd,
            max_build_dls, max_lat_dls,
            curvature_index,             // shown at end
            reach_index,                 // shown at end
            td_md, lateral_md,
            steer_build_md, steer_lat_md,
            pct_build, pct_lat,
            steer_index,                 // shown at end
            lat_out, lon_out,
            ddi_excel                    // shown at end
          });
        });

        collapse.appendChild(body);
        item.appendChild(header);
        item.appendChild(collapse);
        mainAccordion.appendChild(item);
      });

      // ===== OUTER accordion that holds all wells accordions =====
      const outerAcc = document.createElement('div');
      outerAcc.className = 'accordion';
      outerAcc.id = 'allWellsAccordion';

      const outItem = document.createElement('div'); outItem.className = 'accordion-item';
      const outHeadingId = 'heading-allwells', outCollapseId = 'collapse-allwells';

      // Count rows across all wells for the badge
      const totalRowsAll = Array.from(byWell.values()).reduce((sum, wbMap) =>
        sum + Array.from(wbMap.values()).reduce((s, arr) => s + (arr?.length || 0), 0), 0);

      const outHeader = document.createElement('h2'); outHeader.className = 'accordion-header'; outHeader.id = outHeadingId;
      outHeader.innerHTML = `
        <button class="accordion-button" type="button"
                data-bs-toggle="collapse" data-bs-target="#${outCollapseId}"
                aria-expanded="true" aria-controls="${outCollapseId}">
          All Wells
          <span class="badge bg-primary ms-2">${wellKeys.length.toLocaleString()} well(s)</span>
          <span class="badge badge-soft ms-2">${totalRowsAll.toLocaleString()} row(s)</span>
        </button>`;

      const outCollapse = document.createElement('div');
      outCollapse.id = outCollapseId; outCollapse.className = 'accordion-collapse collapse _show';
      outCollapse.setAttribute('aria-labelledby', outHeadingId);

      const outBody = document.createElement('div'); outBody.className = 'accordion-body p-2';
      outBody.appendChild(mainAccordion);

      outCollapse.appendChild(outBody);
      outItem.appendChild(outHeader);
      outItem.appendChild(outCollapse);
      outerAcc.appendChild(outItem);

      // Attach OUTER accordion (with inner wells accordion inside)
      groupContainer.innerHTML = '';
      groupContainer.appendChild(outerAcc);

      // Meta badges
      wellCount.textContent = `${renderedWells.toLocaleString()} well(s)`; show(metaRow);

      /* ---------- SUMMARY accordion (last 4 columns: Curvature Index, Reach Index, Steer Index, DDI) ---------- */
      summaryRows.sort((a, b) => {
        const coll = new Intl.Collator(undefined, { numeric: true, sensitivity: 'base' });
        return coll.compare(a.well, b.well);
      });

      const summaryAccordion = document.createElement('div');
      summaryAccordion.className = 'accordion mt-3-5';
      summaryAccordion.id = 'summaryAccordion';

      const sItem = document.createElement('div'); sItem.className = 'accordion-item';
      const sHeadingId = 'heading-summary', sCollapseId = 'collapse-summary';

      const sHeader = document.createElement('h2'); sHeader.className = 'accordion-header'; sHeader.id = sHeadingId;
      sHeader.innerHTML = `
        <button class="accordion-button" type="button"
                data-bs-toggle="collapse" data-bs-target="#${sCollapseId}"
                aria-expanded="true" aria-controls="${sCollapseId}">
          Summary (per wellbore)
          <span class="badge badge-soft ms-2">${summaryRows.length.toLocaleString()} item(s)</span>
        </button>`;

      const sCollapse = document.createElement('div');
      sCollapse.id = sCollapseId; sCollapse.className = 'accordion-collapse collapse _show';
      sCollapse.setAttribute('aria-labelledby', sHeadingId);

      const sBody = document.createElement('div'); sBody.className = 'accordion-body p-0';
      const sWrap = document.createElement('div'); sWrap.className = 'table-container';
      const sTable = document.createElement('table'); sTable.className = 'table table-sm table-striped table-hover align-middle sticky-header mb-0';

      const sThead = document.createElement('thead');
      sThead.innerHTML = `
        <tr>
          <th>Well</th>
          <th>ICP MD</th><th>ICP TVD</th>
          <th>Max Build DLS</th><th>Max Lat DLS</th>
          <th>TD MD</th><th>Lateral MD</th>
          <th>Steer Build MD</th><th>Steer Lat MD</th>
          <th>% Build Steer</th><th>% Lat Steer</th>
          <th>Lat</th><th>Long</th>
          <!-- last four as requested -->
          <th>Curvature Index</th><th>Reach Index</th><th>Steer Index</th><th>DDI</th>
        </tr>`;

      const sTbody = document.createElement('tbody');
      summaryRows.forEach(r => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td class="monospace">${escapeHtml(r.well)}</td>
          <td>${fmt2(r.icp_md)}</td><td>${fmt2(r.icp_tvd)}</td>
          <td>${fmt2(r.max_build_dls)}</td><td>${fmt2(r.max_lat_dls)}</td>
          <td>${fmt2(r.td_md)}</td><td>${fmt2(r.lateral_md)}</td>
          <td>${fmt2(r.steer_build_md)}</td><td>${fmt2(r.steer_lat_md)}</td>
          <td>${fmtPct2(r.pct_build)}</td><td>${fmtPct2(r.pct_lat)}</td>
          <td>${fmt6(r.lat_out)}</td><td>${fmt6(r.lon_out)}</td>
          <td>${fmt2(r.curvature_index)}</td><td>${fmt2(r.reach_index)}</td><td>${fmt2(r.steer_index)}</td><td>${fmt2(r.ddi_excel)}</td>
        `;
        sTbody.appendChild(tr);
      });

      sTable.appendChild(sThead); sTable.appendChild(sTbody);
      sWrap.appendChild(sTable); sBody.appendChild(sWrap);
      sCollapse.appendChild(sBody); sItem.appendChild(sHeader); sItem.appendChild(sCollapse);
      summaryAccordion.appendChild(sItem);

      groupContainer.appendChild(summaryAccordion);

      // Persist for metric re-render on the map
      __summaryRows = summaryRows.slice();

      // Initial map render with current selection
      renderMap(__summaryRows, markerMetricSelect.value);
    }

    /* ================= Overlap Spreading (anti-stack) ================= */
    function spreadOverlapping(points, map) {
      // Group by near-identical coordinates (round 6 dp)
      const keyOf = (lat, lon) => `${lat.toFixed(6)},${lon.toFixed(6)}`;
      const groups = new Map();
      points.forEach((p, idx) => {
        const k = keyOf(p.lat, p.lon);
        if (!groups.has(k)) groups.set(k, []);
        groups.get(k).push({ ...p, __idx: idx });
      });

      const adjusted = points.map(p => ({ ...p, latAdj: p.lat, lonAdj: p.lon })); // default unchanged

      groups.forEach(list => {
        if (list.length === 1) return;
        // Pixel-based ring spread around the shared location
        const centerLatLng = L.latLng(list[0].lat, list[0].lon);
        const centerPx = map.latLngToLayerPoint(centerLatLng);

        const baseRadius = 28;                 // px; tweak if you need more spacing
        const extra = Math.min(20, (list.length - 2) * 4);
        const radiusPx = baseRadius + extra;
        const step = (2 * Math.PI) / list.length;

        list.forEach((item, i) => {
          const angle = i * step;
          const dx = radiusPx * Math.cos(angle);
          const dy = radiusPx * Math.sin(angle);
          const moved = centerPx.add(L.point(dx, dy));
          const latlngMoved = map.layerPointToLatLng(moved);
          adjusted[item.__idx].latAdj = latlngMoved.lat;
          adjusted[item.__idx].lonAdj = latlngMoved.lng;
        });
      });

      return adjusted;
    }

    /* ================= Map (basemap toggle & metric markers, per WELLBORE) ================= */
    function computeQuartiles(values){
      const v = values.filter(Number.isFinite).slice().sort((a,b)=>a-b);
      const n = v.length; if (!n) return null;
      const q = (p) => {
        const idx = (n-1)*p;
        const lo = Math.floor(idx), hi = Math.ceil(idx);
        if (lo === hi) return v[lo];
        const t = idx - lo;
        return v[lo]*(1-t) + v[hi]*t;
      };
      return { q25: q(0.25), q50: q(0.50), q75: q(0.75) };
    }
    function classForValue(value, quartiles){
      if (!quartiles || !Number.isFinite(value)) return 'idx-low';
      const { q25, q50, q75 } = quartiles;
      if (value <= q25) return 'idx-low';
      if (value <= q50) return 'idx-med';
      if (value <= q75) return 'idx-high';
      return 'idx-xhigh';
    }

    const METRIC_LABELS = {
      steer_index: 'Steer Index',
      curvature_index: 'Curvature Index',
      reach_index: 'Reach Index',
      ddi_excel: 'DDI'
    };

    function renderMap(summaryRows, metricKey){
      // points per WELLBORE
      const basePoints = summaryRows
        .map(r => ({
          wellbore: r.well,
          lat: r.lat_out,
          lon: r.lon_out,
          val: r[metricKey],
          steer: r.steer_index,
          curv: r.curvature_index,
          reach: r.reach_index,
          ddi: r.ddi_excel
        }))
        .filter(p => Number.isFinite(p.lat) && Number.isFinite(p.lon));

      // Reset map if exists
      if (__leafletMap) { __leafletMap.remove(); __leafletMap = null; }

      // Base layers
      const streets = L.tileLayer(
        'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        { maxZoom: 19, attribution: '&copy; OpenStreetMap contributors' }
      );
      const satellite = L.tileLayer(
        'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
        { maxZoom: 19, attribution: 'Tiles &copy; Esri — Source: Esri, Maxar, Earthstar Geographics, and the GIS User Community' }
      );
      const terrain = L.tileLayer(
        'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
        { maxZoom: 17, attribution: 'Map data: © OpenStreetMap contributors, SRTM | Map style: © OpenTopoMap (CC‑BY‑SA)' }
      );

      // Init map (default to Streets)
      const map = L.map('map', { layers: [streets] });
      __leafletMap = map;
      L.control.layers(
        { 'Streets': streets, 'Satellite': satellite, 'Terrain': terrain },
        null,
        { collapsed: false }
      ).addTo(map);

      if (!basePoints.length) {
        map.setView([51.0486, -114.0708], 8); // fallback (Calgary-ish)
        return;
      }

      // Give the map a temporary center/zoom BEFORE pixel conversions (prevents errors)
      map.setView([basePoints[0].lat, basePoints[0].lon], 13);

      // Anti-overlap offsets
      const points = spreadOverlapping(basePoints, map);

      // Quartile thresholds for color classes (per selected metric)
      const vals = points.map(p => p.val).filter(Number.isFinite);
      const qu = computeQuartiles(vals);

      const markers = [];
      points.forEach(({ wellbore, lat, lon, latAdj, lonAdj, val, steer, curv, reach, ddi }) => {
        const bubbleText = fmtMarker(metricKey, val);
        const cls = classForValue(val, qu);
        const icon = L.divIcon({
          className: `metric-marker ${cls}`,
          html: `<div class="metric-bubble">${bubbleText}</div>`,
          iconSize: [44, 44],
          iconAnchor: [22, 22]
        });
        const m = L.marker([latAdj ?? lat, lonAdj ?? lon], { icon }).addTo(map);

        const metricLabel = METRIC_LABELS[metricKey] || 'Value';
        const tipHtml = `
          <div>
            <div><strong>${escapeHtml(wellbore)}</strong></div>
            <div>Steer Index: ${fmt2(steer)}</div>
            <div>Curvature Index: ${fmt2(curv)}</div>
            <div>Reach Index: ${fmt2(reach)}</div>
            <div>DDI: ${fmt2(ddi)}</div>
          </div>`.trim();
        m.bindTooltip(tipHtml, { direction: 'top', sticky: true });

        m.bindPopup(
          `<div>
             <div><strong>${escapeHtml(wellbore)}</strong></div>
             <div>${metricLabel}: ${fmt2(val)}</div>
             <div>Steer Index: ${fmt2(steer)} | Curvature Index: ${fmt2(curv)}</div>
             <div>Reach Index: ${fmt2(reach)} | DDI: ${fmt2(ddi)}</div>
             <div>Lat: ${fmt6(lat)} &nbsp; Long: ${fmt6(lon)}</div>
           </div>`
        );
        markers.push(m);
      });

      const group = L.featureGroup(markers);
      map.fitBounds(group.getBounds().pad(0.2));
      setTimeout(() => { map.invalidateSize(); }, 150);
    }
  </script>
</body>
</html>