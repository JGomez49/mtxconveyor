<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <title>DPI</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" sizes="32x64"
    href="https://res.cloudinary.com/metacortexjohn/image/upload/v1658373747/Icono_Metacortex_ahblhc.png">
  <!-- Bootswatch Slate (Bootstrap 5) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/slate/bootstrap.min.css" />
  <!-- Leaflet (map) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <style>
    body {
      padding: .75rem;
    }

    .container-fluid {
      padding-left: 0;
      padding-right: 0;
    }

    .dropzone {
      position: relative;
      border: 2px dashed #6c757d;
      border-radius: .5rem;
      padding: 1.25rem;
      text-align: center;
      color: #adb5bd;
      transition: border-color .2s ease, color .2s ease, background-color .2s ease;
      cursor: pointer;
    }

    .dropzone.dragover {
      border-color: #0d6efd;
      color: #e9ecef;
      background-color: rgba(13, 110, 253, .1);
    }

    .invisible-input {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      width: 100%;
      height: 100%;
    }

    .badge-soft {
      background-color: rgba(108, 117, 125, .25);
      color: #ced4da;
      border: 1px solid rgba(108, 117, 125, .4);
    }

    .monospace {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
    }

    .sticky-header thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background-color: #2b2f32;
    }

    .table-sm>:not(caption)>*>* {
      padding: .25rem .5rem;
    }

    .accordion-button {
      padding: .5rem .75rem;
    }

    .accordion-body {
      padding: .5rem .75rem;
    }

    .table-container {
      overflow: auto;
      max-height: 70vh;
    }

    #map {
      height: 860px;
      border: 1px solid rgba(108, 117, 125, .35);
      border-radius: .25rem;
    }

    /* .metric-marker {} */
    .metric-bubble {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #fff;
      font-weight: 800;
      font-size: 16px;
      line-height: 1;
      border: 2px solid rgba(0, 0, 0, .35);
      box-shadow: 0 0 8px rgba(0, 0, 0, .35);
      text-shadow: 0 1px 2px rgba(0, 0, 0, .4);
      user-select: none;
    }

    .idx-low .metric-bubble {
      background: #198754;
    }

    .idx-med .metric-bubble {
      background: #fd7e14;
    }

    .idx-high .metric-bubble {
      background: #dc3545;
    }

    .idx-xhigh .metric-bubble {
      background: #6f42c1;
    }

    /* Legend control styling */
    .legend-box {
      background: rgba(43, 47, 50, .9);
      color: #e9ecef;
      padding: .5rem .75rem;
      border-radius: .375rem;
      border: 1px solid rgba(255, 255, 255, .1);
      min-width: 220px;
      font-size: .875rem;
    }

    .legend-title {
      font-weight: 600;
      margin-bottom: .25rem;
    }

    .legend-row {
      display: flex;
      align-items: center;
      gap: .5rem;
      margin: .15rem 0;
    }

    .legend-swatch {
      width: 14px;
      height: 14px;
      border-radius: 3px;
      border: 1px solid rgba(255, 255, 255, .3);
    }

    .legend-toggle {
      background: rgba(43, 47, 50, .9);
      color: #e9ecef;
      border: 1px solid rgba(255, 255, 255, .1);
      border-radius: .375rem;
      padding: .25rem .5rem;
      cursor: pointer;
    }

    .legend-toggle:hover {
      background: rgba(60, 65, 68, .95);
    }

    .leaflet-control-container .leaflet-bottom.leaflet-right .legend-toggle {
      margin: 0 .5rem .5rem 0;
    }
  </style>
</head>

<body>
  <div class="container-fluid">
    <header class="mb-3">
      <img src="https://res.cloudinary.com/metacortexjohn/image/upload/v1711167914/Canadian_Natural_logo_ygbbox.png"
        alt="Canadian Natural Resources Logo" width="250" height="100">
      <h1 class="h4 mb-1">Directional Planning Index</h1>
    </header>

    <div class="d-grid gap-2">
      <a href="/notes" class="btn btn-primary btn-block my-2">Back</a>
    </div>

    <div class="card mb-3">
      <div class="card-body py-2">
        <div class="row g-2 align-items-center">
          <div class="col-12 col-lg">
            <label class="form-label mb-1">Upload CSV</label>
            <div id="dropzone" class="dropzone">
              <strong>Drag & drop</strong> CSV file(s) here, or <span class="text-info text-decoration-underline">click
                to browse</span>.
              <input id="fileInput" class="invisible-input" type="file" multiple accept=".csv,text/csv" />
            </div>
            <!-- <div class="form-text mt-1">All parsing happens locally in your browser.</div> -->
            <div class="mt-2">
              <label class="form-label mb-1">Select a folder of CSVs (each file = one well)</label>
              <input id="dirInput" class="form-control form-control-sm" type="file" webkitdirectory multiple
                accept=".csv,text/csv">
              <div class="form-text">You can also drag & drop multiple CSV files.</div>
            </div>
          </div>
          <div class="col-6 col-sm-auto">
            <div class="form-check mb-0">
              <input class="form-check-input" type="checkbox" id="hasHeader" checked />
              <label class="form-check-label" for="hasHeader">First row is header</label>
            </div>
          </div>
          <div class="col-6 col-sm-auto">
            <button id="clearBtn" class="btn btn-outline-secondary btn-sm" type="button" disabled>Clear</button>
          </div>
        </div>
      </div>
    </div>

    <div id="metaRow" class="row gy-2 gx-2 mb-2" style="display:none;">
      <div class="col-12 col-md"><span id="fileMeta" class="badge badge-soft"></span></div>
      <div class="col-auto"><span id="rowCount" class="badge bg-dark"></span></div>
      <div class="col-auto"><span id="colCount" class="badge bg-dark"></span></div>
      <div class="col-auto"><span id="fileCount" class="badge bg-dark"></span></div>
      <div class="col-auto"><span id="wellCount" class="badge bg-primary"></span></div>
    </div>

    <div id="groupContainer"></div>

    <div class="mt-3-5">
      <div class="d-flex align-items-center gap-2 mb-2">
        <label for="markerMetric" class="form-label mb-0">Marker shows</label>
        <select id="markerMetric" class="form-select form-select-sm" style="max-width: 260px;">
          <option value="steer_index" selected>Steer Index</option>
          <option value="curvature_index">Curvature Index</option>
          <option value="reach_index">Reach Index</option>
          <option value="ddi_excel">DDI</option>
        </select>
        <!-- <span class="small-muted">Surface marker at row 0; trajectory polyline uses all rows with Lat/Long.</span> -->
      </div>
      <h2 class="h6 mb-2">Surface locations map (toggle Streets / Satellite / Terrain)</h2>
      <div id="map" role="region" aria-label="Map of surface Lat/Long and trajectories"></div>
    </div>

    <div id="errorBox" class="alert alert-danger mt-3" role="alert" style="display:none;"></div>
  </div>

  <!-- Bootstrap JS (bundle includes Popper) -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <!-- Leaflet JS -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script>
    // === utilities and existing code trimmed for brevity in this snippet ===
