        },
        setContent: function (html) { if (this._panel) { const title = this._panel.querySelector('.legend-title'); const content = this._panel.querySelector('.legend-content'); if (title && content) { title.innerHTML = html.title; content.innerHTML = html.body; } } }
      });
      return new Legend();
    }
    let __legendControl = null;

    function renderLegend(qu, metricKey) {
      if (!__legendControl || !__leafletMap) return;
      const label = METRIC_LABELS[metricKey] || 'Value';
      if (!qu) { __legendControl.setContent({ title: escapeHtml(label) + ' — Quartiles', body: '<div class="legend-row">No data</div>' }); return; }
      const rows = [
        { color: '#198754', text: `≤ ${fmt2(qu.q25)}` },
        { color: '#fd7e14', text: `${fmt2(qu.q25)} – ${fmt2(qu.q50)}` },
        { color: '#dc3545', text: `${fmt2(qu.q50)} – ${fmt2(qu.q75)}` },
        { color: '#6f42c1', text: `≥ ${fmt2(qu.q75)}` }
      ];
