        let icp_md = null, icp_tvd = null, td_md = null, lateral_md = null; let max_build_dls = null, max_lat_dls = null; let steer_build_md = null, steer_lat_md = null; let pct_build = null, pct_lat = null; let dls_mean_build = null, dls_std_build = null, dls_mean_lat = null, dls_std_lat = null; let curv_build_index = null, curv_lat_index = null, curvature_index = null; let steer_index = null, reach_index = null, ddi_excel = null; let lat_out = null, lon_out = null;
        const md_surface = (idxMD >= 0 && rowsW.length) ? parseNumber(rowsW[0][idxMD]) : NaN; if (lpIdx >= 0 && idxMD >= 0) icp_md = parseNumber(rowsW[lpIdx][idxMD]); if (lpIdx >= 0 && idxTVD >= 0) icp_tvd = parseNumber(rowsW[lpIdx][idxTVD]); if (tdIdx >= 0 && idxMD >= 0) td_md = parseNumber(rowsW[tdIdx][idxMD]); if (Number.isFinite(td_md) && Number.isFinite(icp_md)) lateral_md = td_md - icp_md; if (Number.isFinite(td_md) && Number.isFinite(icp_tvd) && icp_tvd > 0) reach_index = td_md / icp_tvd;
        if (idxDOG >= 0 && rowsW.length) { if (lpIdx >= 0) { let maxB = -Infinity; const vb = []; for (let i = 0; i <= lpIdx && i < rowsW.length; i++) { const v = parseNumber(rowsW[i][idxDOG]); if (!Number.isNaN(v)) { maxB = Math.max(maxB, v); vb.push(v); } } if (maxB !== -Infinity) max_build_dls = maxB; const msB = meanStd(vb); dls_mean_build = msB.mean; dls_std_build = msB.std; const totalBuild = accumulateSteeringMD(rowsW, idxMD, idxDOG, 0, lpIdx); if (totalBuild !== null) steer_build_md = totalBuild; } if (lpIdx >= 0 && tdIdx >= 0 && tdIdx > lpIdx) { let maxL = -Infinity; const vl = []; for (let i = lpIdx + 1; i <= tdIdx && i < rowsW.length; i++) { const v = parseNumber(rowsW[i][idxDOG]); if (!Number.isNaN(v)) { maxL = Math.max(maxL, v); vl.push(v); } } if (maxL !== -Infinity) max_lat_dls = maxL; const msL = meanStd(vl); dls_mean_lat = msL.mean; dls_std_lat = msL.std; const totalLat = accumulateSteeringMD(rowsW, idxMD, idxDOG, lpIdx + 1, tdIdx); if (totalLat !== null) steer_lat_md = totalLat; } }
        const build_len = (Number.isFinite(icp_md) && Number.isFinite(md_surface)) ? (icp_md - md_surface) : NaN; const lat_len = (Number.isFinite(td_md) && Number.isFinite(icp_md)) ? (td_md - icp_md) : NaN; const tot_len = (Number.isFinite(td_md) && Number.isFinite(md_surface)) ? (td_md - md_surface) : NaN; if (Number.isFinite(steer_build_md) && Number.isFinite(build_len) && build_len > 0) pct_build = (steer_build_md / build_len) * 100; if (Number.isFinite(steer_lat_md) && Number.isFinite(lat_len) && lat_len > 0) pct_lat = (steer_lat_md / lat_len) * 100;
