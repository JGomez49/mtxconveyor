      __legendControl.setContent({ title: `${escapeHtml(label)} — Quartiles`, body });
    }

    function spreadOverlapping(points, map) { const keyOf = (lat, lon) => `${lat.toFixed(6)},${lon.toFixed(6)}`; const groups = new Map(); points.forEach((p, idx) => { const k = keyOf(p.lat, p.lon); if (!groups.has(k)) groups.set(k, []); groups.get(k).push({ ...p, __idx: idx }); }); const adjusted = points.map(p => ({ ...p, latAdj: p.lat, lonAdj: p.lon })); groups.forEach(list => { if (list.length === 1) return; const center = L.latLng(list[0].lat, list[0].lon); const centerPx = __leafletMap.latLngToLayerPoint(center); const base = 28, extra = Math.min(20, (list.length - 2) * 4); const R = base + extra; const step = (2 * Math.PI) / list.length; list.forEach((it, i) => { const ang = i * step; const dx = R * Math.cos(ang), dy = R * Math.sin(ang); const moved = centerPx.add(L.point(dx, dy)); const ll = __leafletMap.layerPointToLatLng(moved); adjusted[it.__idx].latAdj = ll.lat; adjusted[it.__idx].lonAdj = ll.lng; }); }); return adjusted; }

    function renderMap(summaryRows, metricKey, trajectories) {
      if (__leafletMap) { __leafletMap.remove(); __leafletMap = null; }
