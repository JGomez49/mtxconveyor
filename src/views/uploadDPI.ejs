      if (evt === 'dragleave') { dropzone.classList.remove('dragover'); }
      if (evt === 'drop') { e.preventDefault(); dropzone.classList.remove('dragover'); const files = e.dataTransfer.files; if (files && files.length) handleFiles(files); }
    }));
    fileInput.addEventListener('change', e => { const files = e.target.files; if (files && files.length) handleFiles(files); });
    if (dirInput) { dirInput.addEventListener('change', e => { const files = e.target.files; if (files && files.length) handleFiles(files); }); }
    clearBtn.addEventListener('click', () => { groupContainer.innerHTML = ''; hide(errorBox); hide(metaRow); fileInput.value = ''; if (dirInput) dirInput.value = ''; clearBtn.disabled = true; window.__csvRows = null; __summaryRows = null; __wellTrajectories = null; if (__leafletMap) { __leafletMap.remove(); __leafletMap = null; } });
    hasHeaderCheckbox.addEventListener('change', () => { if (window.__csvRows && window.__csvRows.length) { renderWellsAndSummary(window.__csvRows, window.__delimiter, hasHeaderCheckbox.checked); } });
    markerMetricSelect.addEventListener('change', () => { if (__summaryRows) renderMap(__summaryRows, markerMetricSelect.value, __wellTrajectories); });

    function showError(msg) { errorBox.textContent = msg; show(errorBox); hide(metaRow); groupContainer.innerHTML = ''; }
    async function handleFiles(fileList) { hide(errorBox); const files = Array.from(fileList || []).filter(f => /\.csv$/i.test(f.name)); if (!files.length) return showError('No CSV files found in the selection.'); const parsed = []; for (const f of files) { const text = await f.text(); const { rows, delimiter } = parseCSV(text); if (rows && rows.length) parsed.push({ file: f, rows, delimiter }); } if (!parsed.length) return showError('The files appear to be empty.'); const useHeader = hasHeaderCheckbox.checked; const maxCols = Math.max(...parsed.map(p => p.rows[0].length)); const firstHeader = useHeader ? parsed[0].rows[0] : Array.from({ length: maxCols }, (_, i) => `Column ${i + 1}`); let totalRows = 0, totalCols = firstHeader.length; const combined = [firstHeader.slice()]; for (const p of parsed) { const rows = p.rows; const norm = rows.map(r => r.length === firstHeader.length ? r : r.concat(Array(firstHeader.length - r.length).fill(''))); const data = useHeader ? norm.slice(1) : norm; combined.push(...data); totalRows += data.length; totalCols = Math.max(totalCols, norm[0]?.length || totalCols); } const totalKB = (files.reduce((s, f) => s + f.size, 0) / 1024).toFixed(1); fileMeta.textContent = `${files.length} file(s) • ${totalKB} KB total`; fileMeta.setAttribute('data-name', fileMeta.textContent); rowCount.textContent = `${totalRows.toLocaleString()} row(s)`; colCount.textContent = `${totalCols.toLocaleString()} column(s)`; if (fileCount) fileCount.textContent = `${files.length} file(s)`; show(metaRow); window.__csvRows = combined; window.__delimiter = parsed[0].delimiter; previewCSV(combined, parsed[0].delimiter); renderWellsAndSummary(combined, parsed[0].delimiter, useHeader); clearBtn.disabled = false; }

    function renderWellsAndSummary(rows, delimiter, useHeader) {
      const maxCols = rows.reduce((m, r) => Math.max(m, r.length), 0); const normalized = rows.map(r => r.length === maxCols ? r : r.concat(Array(maxCols - r.length).fill('')));
      const headerRow = useHeader ? normalized[0] : Array.from({ length: maxCols }, (_, i) => `Column ${i + 1}`); const dataRows = useHeader ? normalized.slice(1) : normalized;
      const idxWellCol = (() => { const L = headerRow.map(h => String(h).trim().toLowerCase()); const i = L.indexOf('well'); return i >= 0 ? i : 0; })();
      const idxIncl = getColumnIndex(headerRow, ['incl', 'inclination']); const idxMD = getColumnIndex(headerRow, ['md']); const idxTVD = getColumnIndex(headerRow, ['tvd']); const idxDOG = getColumnIndex(headerRow, ['dogleg', 'dls']); const idxCmt = getColumnIndex(headerRow, ['comments', 'comment']); const idxN = getColumnIndex(headerRow, ['local n', 'local north', 'northing', 'n']); const idxE = getColumnIndex(headerRow, ['local e', 'local east', 'easting', 'e']); const idxLat = getColumnIndex(headerRow, ['latitude', 'lat']); const idxLon = getColumnIndex(headerRow, ['longitude', 'long', 'lon']);
