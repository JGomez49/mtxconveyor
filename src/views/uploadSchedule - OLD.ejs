<%- include ('partials/header.ejs') %>

<div class="_container bg-dark">
    <h2 class="pt-4 m-4">Upload Schedule <small style="font-size:12px;color:#00c8ff;font-family:monospace;">v3 — supports Primary Zone / TVD / Target</small></h2>
    <p class="mb-4 m-4">USER: <%= user.name %></p>

    <div class="row m-4">

        <div class="card mb-3">
            <div class="card-body">
                <div class="input-group mb-3">
                    <input type="file" accept=".xlsx,.csv" name="csvFile"
                           class="form-control" id="csvFile">
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 mb-4">
            <button id="uploadScheduleBtn" class="btn btn-success" type="button" disabled>
                ⬆️ Upload Schedule
            </button>
            <a href="/notes" class="btn btn-primary">← Back</a>
        </div>

        <div id="statusMsg" style="color:#00c8ff;font-family:monospace;margin-bottom:12px;"></div>

        <div class="accordion mb-4">
            <div class="accordion-item bg-dark border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapsePreview"
                            style="background:#1a1a1a;color:#fff;">
                        📋 Preview Table
                    </button>
                </h2>
                <div id="collapsePreview" class="accordion-collapse collapse">
                    <div class="accordion-body" style="overflow-x:auto;">
                        <table id="csvTable"
                               class="table table-dark table-striped table-bordered table-sm">
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<script>
// ── Column indices in the raw XLSX template ────────────────────────────────
// 0=ETS ID, 1=Site Name, 2=Surf Location, 3=BH Location, 4=Prospect Name,
// 5=Field Name, 6=AFE Timing Year, 7=Play Type, 8=Province, 9=Est. Start Date,
// 10=DP Company Name, 11=DP Current Plan, 12=DP Design/Plan No,
// 13=DP Drill Approved, 14=DP Geol Approved, 15=DP Type,
// 16=DP Received Date, 17=DP Request Date, 18=Exploration Mgr,
// 19=Exploration VP, 20=Geol Approval Date, 21=License # / WA,
// 22=Responsible Drilling Supervisor, 23=Responsible Geology,
// 24=Rig, 25=Rig Duration, 26=Scheduled, 27=Expl. Cust. Group 1,
// 28=Primary Zone, 29=TVD (m), 30=Target

const COL = {
    ETS:              0,
    site:             1,
    surfLocation:     2,
    bhLocation:       3,
    prospectName:     4,
    // fieldName:      5,
    afeYear:          6,
    playType:         7,
    province:         8,
    start:            9,
    dpCompany:       10,
    dp:              11,
    version:         12,
    drillok:         13,
    geook:           14,
    type:            15,
    // dpReceivedDate:16,
    dpReq:           17,
    // explorationMgr:18,
    vp:              19,
    geolApprovalDate:20,
    license:         21,
    drillingSuper:   22,
    geo:             23,
    rig:             24,
    duration:        25,
    // scheduled:     26,
    group:           27,
    primaryZone:     28,
    tvd:             29,
    target:          30,
};

// The mapped row order that the server controller expects
// (must match scheduleDocs mapping in notes.controller.js)
const FIELD_ORDER = [
    'rig','drillok','geook','duration','dp','type','vp','start','site','well',
    'dpCompany','ETS','group','dpReq','geo','version',
    'primaryZone','tvd','target','province','playType','afeYear',
    'prospectName','bhLocation','surfLocation','license','drillingSuper','geolApprovalDate'
];

const HEADERS = [
    'Rig','DrillOK','GeoOK','Duration','DP','Type','VP','Start','Site','Well',
    'DP Company','ETS','Group','DpReq','Geo','Version',
    'Primary Zone','TVD','Target','Province','Play Type','AFE Year',
    'Prospect','BH Location','Surf Location','License','Drilling Super','Geol Approval Date'
];

// Stored parsed data — set after file parse, read on upload
let _parsedRows = [];  // array of plain objects, one per data row

function status(msg) {
    document.getElementById('statusMsg').textContent = msg;
    console.log('[uploadSchedule]', msg);
}

function cellStr(v) {
    if (v === null || v === undefined) return '';
    if (v instanceof Date) return isNaN(v) ? '' : v.toISOString().split('T')[0];
    return String(v).trim();
}

function cellNum(v) {
    const n = parseFloat(v);
    return isNaN(n) ? null : n;
}

function cellDate(v) {
    if (!v || v === '') return null;
    const s = cellStr(v);
    if (!s) return null;
    const d = new Date(s);
    return isNaN(d) ? null : s;
}

// Parse one raw row (array) into a plain object
function parseRow(raw) {
    const drillRaw = cellStr(raw[COL.drillok]);
    const geoRaw   = cellStr(raw[COL.geook]);
    return {
        rig:              cellStr(raw[COL.rig]),
        drillok:          drillRaw  ? 'YES-Drill' : 'NO-Drill',
        geook:            geoRaw    ? 'YES-Geo'   : 'NO-Geo',
        duration:         cellNum(raw[COL.duration]) || 0,
        dp:               cellStr(raw[COL.dp]),
        type:             cellStr(raw[COL.type]),
        vp:               cellStr(raw[COL.vp]),
        start:            cellDate(raw[COL.start]),
        site:             cellStr(raw[COL.site]),
        well:             cellStr(raw[COL.bhLocation]),   // BH Location used as "well"
        dpCompany:        cellStr(raw[COL.dpCompany]),
        ETS:              cellStr(raw[COL.ETS]),
        group:            cellStr(raw[COL.group]),
        dpReq:            cellStr(raw[COL.dpReq]),
        geo:              cellStr(raw[COL.geo]),
        version:          cellStr(raw[COL.version]),
        primaryZone:      cellStr(raw[COL.primaryZone]),
        tvd:              cellNum(raw[COL.tvd]),
        target:           cellStr(raw[COL.target]),
        province:         cellStr(raw[COL.province]),
        playType:         cellStr(raw[COL.playType]),
        afeYear:          cellStr(raw[COL.afeYear]),
        prospectName:     cellStr(raw[COL.prospectName]),
        bhLocation:       cellStr(raw[COL.bhLocation]),
        surfLocation:     cellStr(raw[COL.surfLocation]),
        license:          cellStr(raw[COL.license]),
        drillingSuper:    cellStr(raw[COL.drillingSuper]),
        geolApprovalDate: cellDate(raw[COL.geolApprovalDate]),
    };
}

// Convert parsed object to array in FIELD_ORDER for server
function rowToArray(obj) {
    return FIELD_ORDER.map(f => {
        const v = obj[f];
        return (v === null || v === undefined) ? '' : String(v);
    });
}

function processRawData(rawRows) {
    status('Parsing ' + rawRows.length + ' raw rows…');

    // Skip header row, skip empty rows
    const dataRows = rawRows.slice(1).filter(r =>
        Array.isArray(r) && r.some(c => cellStr(c) !== '')
    );

    _parsedRows = dataRows.map(parseRow);

    // Sample check
    if (_parsedRows.length > 0) {
        const s = _parsedRows[0];
        console.log('[uploadSchedule] sample row 0:',
            'rig=', s.rig,
            'primaryZone=', s.primaryZone,
            'tvd=', s.tvd,
            'target=', s.target,
            'start=', s.start
        );
    }

    status('Parsed ' + _parsedRows.length + ' rows. Ready to upload.');
    renderPreviewTable();
    document.getElementById('uploadScheduleBtn').disabled = false;
}

function renderPreviewTable() {
    const table = document.getElementById('csvTable');
    table.innerHTML = '';
    // Header
    const htr = document.createElement('tr');
    HEADERS.forEach(h => {
        const th = document.createElement('th');
        th.textContent = h;
        htr.appendChild(th);
    });
    table.appendChild(htr);
    // Data rows (first 50 for preview)
    _parsedRows.slice(0, 50).forEach(obj => {
        const tr = document.createElement('tr');
        FIELD_ORDER.forEach(f => {
            const td = document.createElement('td');
            const v = obj[f];
            td.textContent = (v === null || v === undefined) ? '' : v;
            tr.appendChild(td);
        });
        table.appendChild(tr);
    });
}

// ── File input handler ────────────────────────────────────────────────────
document.getElementById('csvFile').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    document.getElementById('uploadScheduleBtn').disabled = true;
    _parsedRows = [];
    status('Reading file…');

    const ext = file.name.split('.').pop().toLowerCase();

    if (ext === 'xlsx' || ext === 'xls') {
        const reader = new FileReader();
        reader.onload = function(ev) {
            const wb = XLSX.read(ev.target.result, { type: 'array', cellDates: true });
            const ws = wb.Sheets[wb.SheetNames[0]];
            const raw = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
            processRawData(raw);
        };
        reader.readAsArrayBuffer(file);
    } else {
        Papa.parse(file, {
            complete: function(results) {
                processRawData(results.data);
            }
        });
    }
});

// ── Upload button ─────────────────────────────────────────────────────────
document.getElementById('uploadScheduleBtn').addEventListener('click', async function() {
    if (!_parsedRows.length) {
        alert('No data loaded. Please select a file first.');
        return;
    }

    status('Uploading ' + _parsedRows.length + ' rows to server…');
    this.disabled = true;

    // Build [headers, ...arrayRows] payload
    const payload = {
        data: [HEADERS, ..._parsedRows.map(rowToArray)]
    };

    console.log('[uploadSchedule] sending', payload.data.length, 'rows');
    console.log('[uploadSchedule] row[1]:', JSON.stringify(payload.data[1]));
    console.log('[uploadSchedule] primaryZone[1]=', payload.data[1]?.[16],
                'tvd[1]=', payload.data[1]?.[17], 'target[1]=', payload.data[1]?.[18]);

    try {
        const res = await fetch('/notes/uploadSchedule', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        if (res.ok) {
            status('✅ Upload successful!');
            alert('✅ Schedule uploaded successfully!');
            window.location.href = '/notes';
        } else {
            const txt = await res.text();
            status('❌ Upload failed: ' + txt);
            alert('❌ Upload failed:\n' + txt);
            this.disabled = false;
        }
    } catch (err) {
        status('❌ Error: ' + err.message);
        alert('❌ Error: ' + err.message);
        this.disabled = false;
    }
});
</script>

<%- include ('partials/footer.ejs') %>
