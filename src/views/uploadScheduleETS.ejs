<%- include ('partials/header.ejs') %>

<div class="_container bg-dark">
    <h2 class="pt-4 m-4">Upload Schedule
        <small style="font-size:11px;color:#00c8ff;font-family:monospace;">
            v5 — header-driven mapping (format-change safe)
        </small>
    </h2>
    <p class="mb-4 m-4">USER: <%= user.name %></p>

    <div class="row m-4">
        <div class="card mb-3">
            <div class="card-body">
                <div class="input-group mb-3">
                    <input type="file" accept=".xlsx,.csv" name="csvFile"
                           class="form-control" id="csvFile">
                </div>
            </div>
        </div>

        <div class="d-grid gap-2 mb-4">
            <button id="uploadScheduleBtn" class="btn btn-success" type="button" disabled>
                ⬆️ Upload Schedule
            </button>
            <a href="/notes" class="btn btn-primary">← Back</a>
        </div>

        <div id="statusMsg"
             style="color:#00c8ff;font-family:monospace;margin-bottom:12px;white-space:pre-wrap;"></div>

        <div class="accordion mb-4">
            <div class="accordion-item bg-dark border-0">
                <h2 class="accordion-header">
                    <button class="accordion-button collapsed" type="button"
                            data-bs-toggle="collapse" data-bs-target="#collapsePreview"
                            style="background:#1a1a1a;color:#fff;">
                        📋 Preview Table (first 50 rows)
                    </button>
                </h2>
                <div id="collapsePreview" class="accordion-collapse collapse">
                    <div class="accordion-body" style="overflow-x:auto;">
                        <table id="csvTable"
                               class="table table-dark table-striped table-bordered table-sm">
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

<script>
// ═══════════════════════════════════════════════════════════════════════════
//  HEADER → FIELD mapping
//  Key  : substring that must appear in the column header (case-insensitive)
//  Value: field name stored in MongoDB / sent to server
//
//  Adding a new column to the template = add one line here. Nothing else.
// ═══════════════════════════════════════════════════════════════════════════
const HEADER_MAP = [
    // [ headerSubstring,              fieldName,          type   ]
    [ 'ETS ID',                        'ETS',              'str'  ],
    [ 'Site Name',                     'site',             'str'  ],
    [ 'BH Location',                   'well',             'str'  ],  // BH used as "well"
    [ 'Surf Location',                 'surfLocation',     'str'  ],
    [ 'Prospect Name',                 'prospectName',     'str'  ],
    [ 'AFE Timing Year',               'afeYear',          'str'  ],
    [ 'Play Type',                     'playType',         'str'  ],
    [ 'Province',                      'province',         'str'  ],
    [ 'Est. Start Date',               'start',            'date' ],
    [ 'DP Company Name',               'dpCompany',        'str'  ],
    [ 'DP Current Plan',               'dp',               'str'  ],
    [ 'DP Design',                     'version',          'str'  ],  // DP Design/Plan No
    [ 'DP Drill Approved',             'drillok',          'bool' ],
    [ 'DP Geol Approved',              'geook',            'bool' ],
    [ 'DP Type',                       'type',             'str'  ],
    [ 'DP Received Date',              'dpReceivedDate',   'date' ],
    [ 'DP Request Date',               'dpReq',            'date' ],
    [ 'Exploration VP',                'vp',               'str'  ],
    [ 'Geol Approval Date',            'geolApprovalDate', 'date' ],
    [ 'License',                       'license',          'str'  ],
    [ 'Responsible Drilling',          'drillingSuper',    'str'  ],
    [ 'Responsible Geology',           'geo',              'str'  ],
    [ 'Rig',                           'rig',              'str'  ],  // exact match priority
    [ 'Rig Duration',                  'duration',         'num'  ],
    [ 'Expl. Cust. Group',             'group',            'str'  ],
    [ 'Primary Zone',                  'primaryZone',      'str'  ],
    [ 'TVD',                           'tvd',              'num'  ],
    [ 'Target',                        'target',           'str'  ],
    [ 'Surface Lat',                   'surfaceLat',       'num'  ],
    [ 'Surface Long',                  'surfaceLon',       'num'  ],
];

// Fields sent to server in this order (must match controller mapping)
const FIELD_ORDER = [
    'rig','drillok','geook','duration','dp','type','vp','start','site','well',
    'dpCompany','ETS','group','dpReq','geo','version',
    'dpReceivedDate','primaryZone','tvd','target','province','playType','afeYear',
    'prospectName','surfLocation','license','drillingSuper','geolApprovalDate',
    'surfaceLat','surfaceLon'
];

const HEADERS_OUT = [
    'Rig','DrillOK','GeoOK','Duration','DP','Type','VP','Start','Site','Well',
    'DP Company','ETS','Group','DpReq','Geo','Version',
    'DP Received Date','Primary Zone','TVD','Target','Province','Play Type','AFE Year',
    'Prospect','Surf Location','License','Drilling Super','Geol Approval Date',
    'Surface Lat','Surface Lon'
];

// ── Type converters ────────────────────────────────────────────────────────
function toStr(v) {
    if (v === null || v === undefined || v === '') return '';
    if (v instanceof Date) return isNaN(v) ? '' : v.toISOString().split('T')[0];
    return String(v).trim();
}
function toNum(v) {
    if (v === null || v === undefined || v === '') return null;
    const n = parseFloat(v);
    return isNaN(n) ? null : n;
}
function toDate(v) {
    if (v === null || v === undefined || v === '') return null;
    if (v instanceof Date) return isNaN(v) ? null : v.toISOString().split('T')[0];
    const s = String(v).trim();
    if (!s) return null;
    const d = new Date(s);
    return isNaN(d) ? null : s;
}
function toBool(v) {
    // DrillOK/GeoOK: non-empty = approved = YES
    const s = toStr(v);
    return s ? 'YES' : 'NO';  // controller adds -Drill / -Geo suffix
}

// ── Build column-index lookup from header row ──────────────────────────────
function buildColMap(headerRow) {
    const colMap = {};   // fieldName → colIndex
    const found  = {};   // fieldName → matched header text (for logging)

    headerRow.forEach((h, i) => {
        const hStr = String(h || '').trim();
        if (!hStr) return;

        for (const [substr, field] of HEADER_MAP) {
            if (colMap[field] !== undefined) continue;  // already mapped
            // Case-insensitive substring match
            if (hStr.toLowerCase().includes(substr.toLowerCase())) {
                // Extra check for 'Rig' to avoid matching 'Rig Duration'
                if (field === 'rig' && hStr.toLowerCase().includes('duration')) continue;
                colMap[field] = i;
                found[field]  = `[${i}] "${hStr}"`;
            }
        }
    });

    return { colMap, found };
}

// ── Convert one raw row to a plain object ──────────────────────────────────
function parseRow(raw, colMap) {
    function get(field, type) {
        const idx = colMap[field];
        if (idx === undefined || idx === null) return type === 'num' ? null : '';
        const v = raw[idx];
        switch(type) {
            case 'str':  return toStr(v);
            case 'num':  return toNum(v);
            case 'date': return toDate(v);
            case 'bool': return toBool(v);
            default:     return toStr(v);
        }
    }

    const typeOf = Object.fromEntries(HEADER_MAP.map(([,f,t]) => [f,t]));

    const obj = {};
    HEADER_MAP.forEach(([, field, type]) => {
        obj[field] = get(field, type);
    });

    // Standardise DrillOK / GeoOK
    obj.drillok = obj.drillok === 'YES' ? 'YES-Drill' : 'NO-Drill';
    obj.geook   = obj.geook   === 'YES' ? 'YES-Geo'   : 'NO-Geo';

    return obj;
}

function rowToArray(obj) {
    return FIELD_ORDER.map(f => {
        const v = obj[f];
        return (v === null || v === undefined) ? '' : String(v);
    });
}

// ── State ──────────────────────────────────────────────────────────────────
let _parsedRows = [];
let _colMap     = {};

function status(msg) {
    document.getElementById('statusMsg').textContent = msg;
    console.log('[uploadSchedule]', msg);
}

function processRawData(rawRows) {
    if (!rawRows || rawRows.length < 2) {
        status('❌ File appears empty or has only a header row.');
        return;
    }

    // Build column map from the actual header row in the file
    const { colMap, found } = buildColMap(rawRows[0]);
    _colMap = colMap;

    // Log what was found / not found
    const mappedFields   = Object.keys(found);
    const unmappedFields = HEADER_MAP.map(([,f]) => f).filter(f => colMap[f] === undefined);
    console.log('[uploadSchedule] Mapped fields:', found);
    if (unmappedFields.length)
        console.warn('[uploadSchedule] Unmapped fields:', unmappedFields);

    status(
        `Parsed header — mapped ${mappedFields.length}/${HEADER_MAP.length} fields.\n` +
        (unmappedFields.length
            ? `⚠ Not found in file: ${unmappedFields.join(', ')}\n`
            : '✅ All fields found.\n') +
        `Reading data rows…`
    );

    // Skip empty rows
    const dataRows = rawRows.slice(1).filter(r =>
        Array.isArray(r) && r.some(c => toStr(c) !== '')
    );

    _parsedRows = dataRows.map(r => parseRow(r, colMap));

    // Sample check
    if (_parsedRows.length > 0) {
        const s = _parsedRows[0];
        console.log('[uploadSchedule] row[0]:', {
            rig: s.rig, site: s.site, primaryZone: s.primaryZone,
            tvd: s.tvd, surfaceLat: s.surfaceLat, surfaceLon: s.surfaceLon,
        });
    }

    status(
        `✅ Parsed ${_parsedRows.length} rows.\n` +
        `Sample: rig="${_parsedRows[0]?.rig}", ` +
        `lat=${_parsedRows[0]?.surfaceLat}, lon=${_parsedRows[0]?.surfaceLon}\n` +
        `Ready to upload.`
    );
    renderPreviewTable();
    document.getElementById('uploadScheduleBtn').disabled = false;
}

function renderPreviewTable() {
    const table = document.getElementById('csvTable');
    table.innerHTML = '';
    const htr = document.createElement('tr');
    HEADERS_OUT.forEach(h => {
        const th = document.createElement('th');
        th.textContent = h;
        htr.appendChild(th);
    });
    table.appendChild(htr);
    _parsedRows.slice(0, 50).forEach(obj => {
        const tr = document.createElement('tr');
        FIELD_ORDER.forEach(f => {
            const td = document.createElement('td');
            const v = obj[f];
            td.textContent = (v === null || v === undefined) ? '' : v;
            tr.appendChild(td);
        });
        table.appendChild(tr);
    });
}

// ── File input ─────────────────────────────────────────────────────────────
document.getElementById('csvFile').addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (!file) return;
    document.getElementById('uploadScheduleBtn').disabled = true;
    _parsedRows = [];
    status('Reading file…');
    const ext = file.name.split('.').pop().toLowerCase();
    if (ext === 'xlsx' || ext === 'xls') {
        const reader = new FileReader();
        reader.onload = function(ev) {
            const wb  = XLSX.read(ev.target.result, { type: 'array', cellDates: true });
            const ws  = wb.Sheets[wb.SheetNames[0]];
            const raw = XLSX.utils.sheet_to_json(ws, { header: 1, defval: '' });
            processRawData(raw);
        };
        reader.readAsArrayBuffer(file);
    } else {
        Papa.parse(file, {
            complete: function(results) { processRawData(results.data); }
        });
    }
});

// ── Upload ─────────────────────────────────────────────────────────────────
document.getElementById('uploadScheduleBtn').addEventListener('click', async function() {
    if (!_parsedRows.length) { alert('No data loaded.'); return; }
    status(`Uploading ${_parsedRows.length} rows to server…`);
    this.disabled = true;

    const arrays  = _parsedRows.map(rowToArray);
    const payload = { data: [HEADERS_OUT, ...arrays] };

    console.log('[uploadSchedule] rows:', payload.data.length);
    console.log('[uploadSchedule] row[1]:', JSON.stringify(payload.data[1]));
    // lat is at FIELD_ORDER index 28, lon at 29
    const latIdx = FIELD_ORDER.indexOf('surfaceLat');
    const lonIdx = FIELD_ORDER.indexOf('surfaceLon');
    console.log(`[uploadSchedule] lat[${latIdx}]=${payload.data[1]?.[latIdx]}, lon[${lonIdx}]=${payload.data[1]?.[lonIdx]}`);

    try {
        const res = await fetch('/notes/uploadSchedule', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify(payload),
        });
        if (res.ok) {
            status('✅ Upload successful!');
            alert('✅ Schedule uploaded successfully!');
            window.location.href = '/notes';
        } else {
            const txt = await res.text();
            status('❌ Failed: ' + txt);
            alert('❌ Upload failed:\n' + txt);
            this.disabled = false;
        }
    } catch (err) {
        status('❌ Error: ' + err.message);
        this.disabled = false;
    }
});
</script>

<%- include ('partials/footer.ejs') %>
