        %>
        <% if (user.role == 'admin') { %>
            <%- include('partials/navigation_Admin.ejs', { jobNavBtns }) %>
        <% } else if (user.role == 'leader' || user.role == 'user') { %>
            <%- include('partials/navigation_Leader.ejs', { jobNavBtns }) %>
        <% } else { %>
            <%- include('partials/navigation_Member.ejs', { jobNavBtns }) %>
        <% } %>
    <% } %>
</div>

<!-- ── Theme toggle JS (reads/writes same localStorage key as all-notes.ejs) ── -->
<script>
(function(){
    const LS_KEY = 'mtxThemePreference';
    const sw = document.getElementById('anThemeSwitch');
    function applyTheme(light){
        document.body.classList.toggle('light-mode', light);
        if(sw) sw.checked = light;
    }
    applyTheme(localStorage.getItem(LS_KEY) === 'light');
    if(sw) sw.addEventListener('change', function(){
        localStorage.setItem(LS_KEY, sw.checked ? 'light' : 'dark');
        applyTheme(sw.checked);
    });
})();
</script>

