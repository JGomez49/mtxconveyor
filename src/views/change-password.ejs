<%- include ('partials/header.ejs') %>

<% if (user.role == 'admin') { %>
    <%- include('partials/navigation_Admin.ejs') %>
<% } else if (user.role == 'leader' || user.role == 'user') { %>
    <%- include('partials/navigation_Leader.ejs') %>
<% } else { %>
    <%- include('partials/navigation_Member.ejs') %>
<% } %>

<style>
    .cp-card {
        background: #111820; border: 1px solid #1e2d3d; border-radius: 8px;
        padding: 28px; max-width: 480px; margin: 40px auto;
    }
</style>

<div class="cp-card">
    <h4 style="color:#e8f4ff;font-family:monospace;">🔐 Change Password / Security Question</h4>
    <p style="color:#5a7080;font-size:13px;">
        Signed in as <strong><%= user.email %></strong>.
        Update either or both — fields you leave blank are unchanged.
    </p>

    <% if (error) { %>
        <div class="alert alert-danger" style="font-size:13px;"><%= error %></div>
    <% } %>
    <% if (success) { %>
        <div class="alert alert-success" style="font-size:13px;"><%= success %></div>
    <% } %>

    <form action="/users/change-password" method="post">
        <div class="form-group mb-3">
            <label style="color:#c8d8e8;font-size:13px;">Current password</label>
            <input type="password" name="current_password" class="form-control" required>
            <div style="font-size:11px;color:#5a7080;margin-top:4px;">
                Required to confirm any change below.
            </div>
        </div>

        <hr style="border-color:#1e2d3d;">

        <h6 style="color:#aaa;font-size:12px;">New Password (optional)</h6>
        <div class="form-group mb-2">
            <input type="password" name="password" class="form-control" placeholder="New password">
        </div>
        <div class="form-group mb-3">
            <input type="password" name="confirm_password" class="form-control" placeholder="Confirm new password">
        </div>

        <hr style="border-color:#1e2d3d;">

        <h6 style="color:#aaa;font-size:12px;">
            Security Question <% if (user.securityQuestion) { %>(currently set)<% } else { %>(not set)<% } %>
        </h6>
        <div class="form-group mb-2">
            <input type="text" name="question" class="form-control"
                   placeholder="<%= user.securityQuestion || 'Write a question (e.g. first pet name?)' %>">
        </div>
        <div class="form-group mb-3">
            <input type="text" name="answer" class="form-control" placeholder="Answer (only required if changing the question)">
        </div>

        <button class="btn btn-success btn-block">Save Changes</button>
    </form>
</div>

<%- include ('partials/footer.ejs') %>
