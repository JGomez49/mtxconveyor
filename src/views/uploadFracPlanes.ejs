<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Frac Planes Evaluation</title>
  <link rel="icon" type="image/png" sizes="32x64"
    href="https://res.cloudinary.com/metacortexjohn/image/upload/v1658373747/Icono_Metacortex_ahblhc.png">
  <script src="https://cdn.plot.ly/plotly-2.30.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow+Condensed:wght@300;500;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --bg:        #0d1117;
      --surface:   #161b22;
      --border:    #21262d;
      --accent:    #00e5ff;
      --warn:      #ffc107;
      --danger:    #ff4d4d;
      --ok:        #39d353;
      --text:      #c9d1d9;
      --muted:     #6e7681;
      --font-mono: 'Share Tech Mono', monospace;
      --font-ui:   'Barlow Condensed', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-ui);
      font-size: 13px;
      height: 100vh;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    /* ── NAV ── */
    nav {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 6px 12px;
      display: flex;
      align-items: center;
      gap: 16px;
      flex-shrink: 0;
    }
    nav .brand {
      font-family: var(--font-mono);
      color: var(--accent);
      font-size: 14px;
      letter-spacing: 2px;
      white-space: nowrap;
    }
    nav .brand span { color: var(--muted); }

    .nav-item { display: flex; align-items: center; gap: 6px; }
    .nav-label { color: var(--muted); font-size: 11px; letter-spacing: 1px; text-transform: uppercase; }

    /* folder button */
    #folderBtn {
      background: var(--accent);
      color: #000;
      border: none;
      padding: 4px 12px;
      font-family: var(--font-mono);
      font-size: 12px;
      cursor: pointer;
      letter-spacing: 1px;
      transition: opacity .15s;
    }
    #folderBtn:hover { opacity: .8; }
    #folderInput { display: none; }

    .pill {
      background: var(--border);
      color: var(--accent);
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 2px 8px;
      border-radius: 2px;
    }

    /* toggle switch */
    .sw { display: flex; align-items: center; gap: 5px; cursor: pointer; }
    .sw input { display: none; }
    .sw-track {
      width: 30px; height: 14px;
      background: var(--border);
      border-radius: 7px;
      position: relative;
      transition: background .2s;
    }
    .sw-track::after {
      content: '';
      position: absolute;
      left: 2px; top: 2px;
      width: 10px; height: 10px;
      border-radius: 50%;
      background: var(--muted);
      transition: transform .2s, background .2s;
    }
    .sw input:checked + .sw-track { background: var(--accent)33; }
    .sw input:checked + .sw-track::after { transform: translateX(16px); background: var(--accent); }
    .sw-label { color: var(--muted); font-size: 11px; letter-spacing: .5px; }

    /* ── CONTROL STRIP ── */
    #controls {
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      padding: 5px 12px;
      display: flex;
      flex-wrap: wrap;
      align-items: flex-end;
      gap: 8px;
      flex-shrink: 0;
    }
    .ctrl-group { display: flex; flex-direction: column; gap: 2px; }
    .ctrl-group label { font-size: 10px; color: var(--muted); letter-spacing: .5px; text-transform: uppercase; }

    select, input[type=number], input[type=text] {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 11px;
      padding: 3px 6px;
      outline: none;
      width: 100%;
    }
    select:focus, input:focus { border-color: var(--accent); }

    .btn {
      border: none;
      padding: 4px 10px;
      font-family: var(--font-mono);
      font-size: 11px;
      cursor: pointer;
      letter-spacing: .5px;
      transition: opacity .15s;
    }
    .btn:hover { opacity: .8; }
    .btn-add    { background: var(--ok);     color: #000; }
    .btn-upd    { background: var(--warn);   color: #000; }
    .btn-del    { background: var(--danger); color: #fff; }
    .btn-exp    { background: transparent;   color: var(--accent); border: 1px solid var(--accent); }
    .btn-scan   { background: var(--accent); color: #000; font-weight: 700; }

    /* ── MAIN LAYOUT ── */
    #main {
      flex: 1;
      display: grid;
      grid-template-columns: 220px 1fr;
      grid-template-rows: 1fr;
      overflow: hidden;
    }

    /* ── INFO PANEL ── */
    #info-panel {
      background: var(--bg);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .panel-tabs {
      display: flex;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }
    .tab-btn {
      flex: 1;
      background: none;
      border: none;
      color: var(--muted);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 1px;
      padding: 6px;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      transition: color .15s;
    }
    .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

    .tab-pane { display: none; flex: 1; overflow-y: auto; }
    .tab-pane.active { display: block; }

    #log {
      font-family: var(--font-mono);
      font-size: 10px;
      padding: 8px;
      white-space: pre-wrap;
      color: var(--muted);
      line-height: 1.6;
    }
    #log .val { color: var(--text); }
    #log .hi  { color: var(--accent); }
    #log .warn{ color: var(--warn); }
    #log .bad { color: var(--danger); }
    #log .ok  { color: var(--ok); }

    /* Wells list */
    #wellsList { padding: 6px; }
    .well-chip {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 4px 6px;
      margin-bottom: 3px;
      background: var(--surface);
      border: 1px solid var(--border);
      font-family: var(--font-mono);
      font-size: 10px;
    }
    .well-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .well-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .well-pts { color: var(--muted); }

    /* ── PLOTS AREA ── */
    #plots-area {
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    #plot3d { flex: 1; min-height: 0; }

    .mini-controls {
      padding: 3px 10px;
      display: flex;
      align-items: center;
      gap: 8px;
      background: var(--surface);
      border-top: 1px solid var(--border);
      flex-shrink: 0;
    }
    .mini-label { font-size: 10px; color: var(--muted); letter-spacing: .5px; }
    .mini-input {
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
      font-family: var(--font-mono);
      font-size: 10px;
      padding: 2px 5px;
      width: 70px;
      outline: none;
    }
    .mini-input:focus { border-color: var(--accent); }
    .mini-btn {
      background: none;
      border: 1px solid var(--muted);
      color: var(--muted);
      font-family: var(--font-mono);
      font-size: 10px;
      padding: 2px 8px;
      cursor: pointer;
    }
    .mini-btn:hover { border-color: var(--accent); color: var(--accent); }

    #c2cPlot, #sfPlot { height: 130px; flex-shrink: 0; }

    /* ── MATRIX TAB ── */
    #matrixWrap {
      padding: 6px;
      overflow: auto;
      font-family: var(--font-mono);
      font-size: 9px;
    }
    .matrix-table { border-collapse: collapse; width: 100%; }
    .matrix-table th, .matrix-table td {
      border: 1px solid var(--border);
      padding: 3px 5px;
      text-align: center;
      white-space: nowrap;
    }
    .matrix-table th { background: var(--surface); color: var(--muted); }
    .cell-ok   { background: #39d35322; color: var(--ok); }
    .cell-warn { background: #ffc10722; color: var(--warn); }
    .cell-bad  { background: #ff4d4d22; color: var(--danger); }
    .cell-na   { background: var(--surface); color: var(--border); }

    /* scrollbars */
    ::-webkit-scrollbar { width: 4px; height: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); }
  </style>
</head>
<body>

<!-- NAV -->
<nav>
