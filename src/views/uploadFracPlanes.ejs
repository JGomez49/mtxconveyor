</div>

<script>
/* ═══════════════════════════════════════════════════
   CONSTANTS & STATE
═══════════════════════════════════════════════════ */
const rad = d => d * Math.PI / 180;
const K95 = 2.447; // 95% confidence factor

let wells = [];
let boxes = [];
let traces = [];
let uirev = 0;
let exportRows = [];
let darkTheme = true;
let showEllipsoids = true;
let showLegend = true;
let allPairsResults = [];

const WELL_COLORS = [
  "#00e5ff","#39d353","#ffc107","#ff6b6b","#c56cf0",
  "#ff9f43","#48dbfb","#ff9ff3","#54a0ff","#5f27cd",
  "#ee5a24","#009432","#0652DD","#833471","#EA2027"
];

/* ═══════════════════════════════════════════════════
   ISCWSA REV-5 ERROR MODEL (planning-grade)
   Sources: SPE-90408, ISCWSA MWD Rev5 coefficient table
   Error terms: ABXY-TI1, ABXY-TI2, ASXY-TI1H, ASXY-TI2H,
                SAG, AMIL-G, ABZE, DECR, DBHG, MDI
═══════════════════════════════════════════════════ */
function rev5_3D(md, incDeg, aziDeg) {
  const inc = rad(incDeg);
  const azi = rad(aziDeg);
  const sI = Math.sin(inc), cI = Math.cos(inc);
  const sA = Math.sin(azi), cA = Math.cos(azi);

  // ── Propagated 1-sigma error terms (Rev-5 MWD + HRGM) ──
  // Inclination bias (ABXY-TI1): 0.10 deg
  const sigABXY_inc = rad(0.10) * md;
  // Azimuth bias (ABXY-TI2): 0.30 deg (increased from Rev4)
  const sigABXY_azi = rad(0.30) * md;
  // Azimuth scale (ASXY-TI1H): 0.001 * MD
  const sigASXY     = 0.001 * md;
  // Sag correction error: 0.02 deg * MD * sin(inc)
  const sigSAG      = rad(0.02) * md * sI;
  // Depth measurement error: 0.0005 * MD (Rev-5 tighter)
  const sigmaMD     = 0.0005 * md;
  // Declination reference error: 0.36 deg * MD * sin(inc)
  const sigDECR     = rad(0.36) * md * sI;
  // Magnetic interference (DBHG): 70 nT → ~0.12 deg * MD * sin(inc)
  const sigDBHG     = rad(0.12) * md * sI;

  // ── Horizontal variance (Northing / Easting plane) ──
  // Each term's contribution in the horizontal plane
  const varH =
    Math.pow(sigABXY_inc * sI, 2) +       // incl bias → horizontal
    Math.pow(sigABXY_azi * sI, 2) +       // azi bias  → horizontal
    Math.pow(sigASXY     * sI, 2) +       // azi scale → horizontal
    Math.pow(sigSAG      * sI, 2) +       // sag       → horizontal
    Math.pow(sigDECR,           2) +       // decl ref  → horizontal
    Math.pow(sigDBHG,           2);        // mag inter → horizontal

  // ── Vertical variance (Sub-Sea depth) ──
  const varZ =
    Math.pow(sigABXY_inc * cI, 2) +       // incl bias → vertical
    Math.pow(sigSAG      * cI, 2) +       // sag       → vertical
    Math.pow(sigmaMD,           2);        // depth err → vertical

  // Return 3-axis diagonal covariance (isotropic horizontal)
  return {
    xx: varH / 2,   // Easting variance
    yy: varH / 2,   // Northing variance
    zz: varZ        // Sub-Sea variance
  };
}

/* ═══════════════════════════════════════════════════
   3D SEPARATION FACTOR (SPE-90408 / ISCWSA)
   Uses full 3D covariance along the 3D separation vector
═══════════════════════════════════════════════════ */
function separationFactor3D(refPt, cRef, offPt, cOff) {
  const dx = refPt.x - offPt.x;
  const dy = refPt.y - offPt.y;
  const dz = refPt.z - offPt.z;
  const D  = Math.sqrt(dx*dx + dy*dy + dz*dz);

  if (D < 1e-9) return { separation: 0, sigma: Infinity, SF: 0 };

  // Unit vector along separation
  const ux = dx / D, uy = dy / D, uz = dz / D;

  // Combined covariance (diagonal 3D)
  const Cxx = cRef.xx + cOff.xx;
  const Cyy = cRef.yy + cOff.yy;
  const Czz = cRef.zz + cOff.zz;

  // Variance of separation = uᵀ C u  (diagonal matrix)
  const varSep = ux*ux*Cxx + uy*uy*Cyy + uz*uz*Czz;
  const sigmaSep = Math.sqrt(Math.max(varSep, 0));

  return {
    separation: D,
    sigma: sigmaSep,
    SF: sigmaSep > 1e-9 ? D / (K95 * sigmaSep) : Infinity
  };
}

/* ═══════════════════════════════════════════════════
   SURVEY INTERPOLATION
═══════════════════════════════════════════════════ */
function interpSurvey(s, md) {
  for (let i = 0; i < s.length - 1; i++) {
    if (md >= s[i].md && md <= s[i+1].md) {
      const f = (md - s[i].md) / (s[i+1].md - s[i].md);
      return {
        md,
        x:   s[i].x   + f*(s[i+1].x   - s[i].x),
        y:   s[i].y   + f*(s[i+1].y   - s[i].y),
        z:   s[i].z   + f*(s[i+1].z   - s[i].z),
        inc: s[i].inc + f*(s[i+1].inc - s[i].inc),
        azi: s[i].azi + f*(s[i+1].azi - s[i].azi)
      };
    }
  }
  return null;
}

function closestPointOnSegment(P, A, B) {
  const AB = { x:B.x-A.x, y:B.y-A.y, z:B.z-A.z };
  const AP = { x:P.x-A.x, y:P.y-A.y, z:P.z-A.z };
  const ab2 = AB.x**2 + AB.y**2 + AB.z**2;
  let t = ab2===0 ? 0 : (AP.x*AB.x + AP.y*AB.y + AP.z*AB.z) / ab2;
  t = Math.max(0, Math.min(1, t));
  return {
    point: { x:A.x+t*AB.x, y:A.y+t*AB.y, z:A.z+t*AB.z },
    t
  };
}

function closestPointToTrajectory(P, survey) {
  let minDist = Infinity, closest = null;
  for (let i = 0; i < survey.length-1; i++) {
    const res = closestPointOnSegment(P, survey[i], survey[i+1]);
    const dx=P.x-res.point.x, dy=P.y-res.point.y, dz=P.z-res.point.z;
    const d = Math.sqrt(dx*dx+dy*dy+dz*dz);
    if (d < minDist) { minDist=d; closest={...res.point}; }
  }
  return { minDist, closest };
}

function interpolateClosestWithSurvey(P, survey) {
  let minDist = Infinity, best = null;
  for (let i = 0; i < survey.length-1; i++) {
    const A=survey[i], B=survey[i+1];
    const res = closestPointOnSegment(P, A, B);
    const dx=P.x-res.point.x, dy=P.y-res.point.y, dz=P.z-res.point.z;
    const d = Math.sqrt(dx*dx+dy*dy+dz*dz);
    if (d < minDist) {
      minDist = d;
      const f = res.t;
      best = {
        x: res.point.x, y: res.point.y, z: res.point.z,
        md:  A.md  + f*(B.md  - A.md),
        inc: A.inc + f*(B.inc - A.inc),
        azi: A.azi + f*(B.azi - A.azi)
      };
    }
  }
  return best;
}

function sampleMDs(survey, step=30) {
  const out = [];
  const mdMin = survey[0].md, mdMax = survey[survey.length-1].md;
  for (let md=mdMin; md<=mdMax; md+=step) out.push(md);
  return out;
}

/* ═══════════════════════════════════════════════════
   PROFILE: SF & C2C vs MD  (Rev-5 3D)
═══════════════════════════════════════════════════ */
function computeProfile(refWell, offWell, step=30) {
  const mds=[], sfs=[], dists=[];
  const mdMin=refWell.s[0].md, mdMax=refWell.s[refWell.s.length-1].md;
  for (let md=mdMin; md<=mdMax; md+=step) {
    const refPt = interpSurvey(refWell.s, md);
    if (!refPt) continue;
    const offPt = interpolateClosestWithSurvey(refPt, offWell.s);
    if (!offPt) continue;
    const cRef = rev5_3D(refPt.md, refPt.inc, refPt.azi);
    const cOff = rev5_3D(offPt.md, offPt.inc, offPt.azi);
    const sf   = separationFactor3D(refPt, cRef, offPt, cOff);
    const dx=refPt.x-offPt.x, dy=refPt.y-offPt.y, dz=refPt.z-offPt.z;
    mds.push(md);
    sfs.push(sf.SF);
    dists.push(Math.sqrt(dx*dx+dy*dy+dz*dz));
  }
  return { mds, sfs, dists };
}

/* ═══════════════════════════════════════════════════
   ALL-PAIRS SCAN
═══════════════════════════════════════════════════ */
function runAllPairsScan() {
  if (wells.length < 2) { alert("Load at least 2 wells first."); return; }
  allPairsResults = [];

  for (let r=0; r<wells.length; r++) {
    for (let o=r+1; o<wells.length; o++) {
      const rw=wells[r], ow=wells[o];
      const step=30;
      let minSF=Infinity, minC2C=Infinity, minSF_md=null, minC2C_md=null;
      const mdMin=rw.s[0].md, mdMax=rw.s[rw.s.length-1].md;
      for (let md=mdMin; md<=mdMax; md+=step) {
        const refPt=interpSurvey(rw.s, md); if (!refPt) continue;
        const offPt=interpolateClosestWithSurvey(refPt, ow.s); if (!offPt) continue;
        const cRef=rev5_3D(refPt.md,refPt.inc,refPt.azi);
        const cOff=rev5_3D(offPt.md,offPt.inc,offPt.azi);
        const sf=separationFactor3D(refPt,cRef,offPt,cOff);
        const dx=refPt.x-offPt.x, dy=refPt.y-offPt.y, dz=refPt.z-offPt.z;
        const dist=Math.sqrt(dx*dx+dy*dy+dz*dz);
        if (sf.SF < minSF)   { minSF=sf.SF; minSF_md=md; }
        if (dist < minC2C)   { minC2C=dist; minC2C_md=md; }
      }
      allPairsResults.push({ r, o,
        refName: rw.name, offName: ow.name,
        minSF: isFinite(minSF)?minSF:999,
        minC2C: isFinite(minC2C)?minC2C:9999,
        minSF_md, minC2C_md
      });
    }
  }
  renderMatrix();
  switchTab('matrix');
  // also log summary
  let txt = '⚡ ALL-PAIRS SCAN RESULTS\n';
  txt += '━'.repeat(28)+'\n';
  allPairsResults.forEach(r=>{
    const sfStr = r.minSF.toFixed(2);
    const cls = r.minSF<1?'bad':r.minSF<1.5?'warn':'ok';
    txt += `\n<span class="${cls}">${r.refName.replace(/\.csv$/i,'')} ↔ ${r.offName.replace(/\.csv$/i,'')}</span>\n`;
    txt += ` Min SF (3D,95%): <span class="${cls} val">${sfStr}</span>  @ MD ${r.minSF_md?.toFixed(0)} m\n`;
    txt += ` Min C2C:         <span class="val">${r.minC2C.toFixed(1)} m</span>  @ MD ${r.minC2C_md?.toFixed(0)} m\n`;
  });
  document.getElementById('log').innerHTML = txt;
  switchTab('log');
}

function renderMatrix() {
  if (!wells.length) return;
  const names = wells.map(w=>w.name.replace(/\.csv$/i,''));
  const n = wells.length;

  // Build lookup
  const lookup = {};
  allPairsResults.forEach(r=>{ lookup[`${r.r}-${r.o}`]=r; lookup[`${r.o}-${r.r}`]=r; });

  let html = '<table class="matrix-table"><thead><tr><th></th>';
  names.forEach(n=>{ html+=`<th title="${n}">${n.length>8?n.slice(0,8)+'…':n}</th>`; });
  html += '</tr></thead><tbody>';

  for (let i=0; i<n; i++) {
    html += `<tr><th title="${names[i]}">${names[i].length>8?names[i].slice(0,8)+'…':names[i]}</th>`;
    for (let j=0; j<n; j++) {
      if (i===j) { html+=`<td class="cell-na">—</td>`; continue; }
      const key=`${Math.min(i,j)}-${Math.max(i,j)}`;
      const res=lookup[key];
      if (!res) { html+=`<td class="cell-na">?</td>`; continue; }
      const sf=res.minSF;
      const cls=sf<1?'cell-bad':sf<1.5?'cell-warn':'cell-ok';
      html+=`<td class="${cls}" title="Min SF=${sf.toFixed(2)}, Min C2C=${res.minC2C.toFixed(1)}m">${sf.toFixed(2)}</td>`;
    }
    html += '</tr>';
  }
  html += '</tbody></table>';
  html += '<p style="color:var(--muted);font-size:9px;padding:4px">SF colour: <span style="color:var(--ok)">≥1.5 safe</span> · <span style="color:var(--warn)">1.0–1.5 caution</span> · <span style="color:var(--danger)">&lt;1.0 collision risk</span></p>';
  document.getElementById('matrixWrap').innerHTML = html;
}

/* ═══════════════════════════════════════════════════
   GEOMETRY HELPERS
═══════════════════════════════════════════════════ */
function rotate(p, a) {
  let {x,y,z}=p;
  let cx=Math.cos(rad(a.ax)),sx=Math.sin(rad(a.ax));[y,z]=[y*cx-z*sx,y*sx+z*cx];
  let cy=Math.cos(rad(a.ay)),sy=Math.sin(rad(a.ay));[x,z]=[x*cy+z*sy,-x*sy+z*cy];
  let cz=Math.cos(rad(a.az)),sz=Math.sin(rad(a.az));[x,y]=[x*cz-y*sz,x*sz+y*cz];
  return {x,y,z};
}
function invRotate(p, a) {
  let {x,y,z}=p;
  let cz=Math.cos(-rad(a.az)),sz=Math.sin(-rad(a.az));[x,y]=[x*cz-y*sz,x*sz+y*cz];
  let cy=Math.cos(-rad(a.ay)),sy=Math.sin(-rad(a.ay));[x,z]=[x*cy+z*sy,-x*sy+z*cy];
  let cx=Math.cos(-rad(a.ax)),sx=Math.sin(-rad(a.ax));[y,z]=[y*cx-z*sx,y*sx+z*cx];
  return {x,y,z};
}

function firstEntry(offsetSurvey, box, a) {
  for (let i=0; i<offsetSurvey.length-1; i++) {
    const A=invRotate({x:offsetSurvey[i].x-box.c.x,y:offsetSurvey[i].y-box.c.y,z:offsetSurvey[i].z-box.c.z},a);
    const B=invRotate({x:offsetSurvey[i+1].x-box.c.x,y:offsetSurvey[i+1].y-box.c.y,z:offsetSurvey[i+1].z-box.c.z},a);
    let t0=0,t1=1;
    for (const ax of ['x','y','z']) {
      const d=B[ax]-A[ax],min=-box.h[ax],max=box.h[ax];
      if (Math.abs(d)<1e-9){if(A[ax]<min||A[ax]>max){t0=1;t1=0;break;}}
      else{let tmin=(min-A[ax])/d,tmax=(max-A[ax])/d;if(tmin>tmax)[tmin,tmax]=[tmax,tmin];t0=Math.max(t0,tmin);t1=Math.min(t1,tmax);}
    }
    if (t0<=t1&&t0>=0&&t0<=1) {
      const eps=t0+1e-6;
      const Pin={x:A.x+eps*(B.x-A.x),y:A.y+eps*(B.y-A.y),z:A.z+eps*(B.z-A.z)};
      if (Math.abs(Pin.x)<box.h.x&&Math.abs(Pin.y)<box.h.y&&Math.abs(Pin.z)<box.h.z)
        return { md:offsetSurvey[i].md+t0*(offsetSurvey[i+1].md-offsetSurvey[i].md), local:{x:A.x+t0*(B.x-A.x),y:A.y+t0*(B.y-A.y),z:A.z+t0*(B.z-A.z)}, seg:[offsetSurvey[i],offsetSurvey[i+1]] };
    }
  }
}

/* ═══════════════════════════════════════════════════
   PLOTLY TRACES
═══════════════════════════════════════════════════ */
function markerTrace(p, name, color) {
  return { type:'scatter3d',mode:'markers',name, x:[p.x],y:[p.y],z:[p.z], marker:{size:6,color} };
}

function boxMesh(c,h,a) {
  const raw=[[-h.x,-h.y,-h.z],[h.x,-h.y,-h.z],[h.x,h.y,-h.z],[-h.x,h.y,-h.z],
             [-h.x,-h.y,h.z],[h.x,-h.y,h.z],[h.x,h.y,h.z],[-h.x,h.y,h.z]].map(p=>{const r=rotate({x:p[0],y:p[1],z:p[2]},a);return{x:r.x+c.x,y:r.y+c.y,z:r.z+c.z};});
  return { type:'mesh3d',opacity:0.25,color:'#00e5ff',
    x:raw.map(p=>p.x),y:raw.map(p=>p.y),z:raw.map(p=>p.z),
    i:[0,0,4,4,0,1,2,3],j:[1,2,5,6,3,5,6,7],k:[2,3,6,7,4,6,7,4] };
}

function boxWireframe(c,h,a) {
  const edges=[[0,1],[1,2],[2,3],[3,0],[4,5],[5,6],[6,7],[7,4],[0,4],[1,5],[2,6],[3,7]];
  const raw=[[-h.x,-h.y,-h.z],[h.x,-h.y,-h.z],[h.x,h.y,-h.z],[-h.x,h.y,-h.z],
             [-h.x,-h.y,h.z],[h.x,-h.y,h.z],[h.x,h.y,h.z],[-h.x,h.y,h.z]].map(p=>{const r=rotate({x:p[0],y:p[1],z:p[2]},a);return{x:r.x+c.x,y:r.y+c.y,z:r.z+c.z};});
  let x=[],y=[],z=[];
  edges.forEach(e=>{x.push(raw[e[0]].x,raw[e[1]].x,null);y.push(raw[e[0]].y,raw[e[1]].y,null);z.push(raw[e[0]].z,raw[e[1]].z,null);});
  return { type:'scatter3d',mode:'lines',x,y,z, line:{color:'#00e5ff',width:2}, name:'Box',hoverinfo:'skip' };
}

function ellipsoidTrace(center, cov3, scale, name, color) {
  const Nu=10, Nv=10;
  const a=Math.sqrt(cov3.xx)*scale, b=Math.sqrt(cov3.yy)*scale, c=Math.sqrt(cov3.zz)*scale;
  const x=[],y=[],z=[];
  for(let i=0;i<=Nu;i++){const u=Math.PI*i/Nu;for(let j=0;j<=Nv;j++){const v=2*Math.PI*j/Nv;x.push(center.x+a*Math.sin(u)*Math.cos(v));y.push(center.y+b*Math.sin(u)*Math.sin(v));z.push(center.z+c*Math.cos(u));}}
  return { type:'mesh3d',x,y,z,opacity:0.12,color,name };
}

function dashedLine(a,b,color,name) {
  return { type:'scatter3d',mode:'lines',x:[a.x,b.x],y:[a.y,b.y],z:[a.z,b.z],
    line:{color,width:2,dash:'dot'},name,hoverinfo:'text',text:name };
}

function faceProjections(local,h) {
  return [
    {face:'+X',p:{x: h.x,y:local.y,z:local.z},color:'#ff4d4d'},
    {face:'-X',p:{x:-h.x,y:local.y,z:local.z},color:'#ff4d4d'},
    {face:'+Y',p:{x:local.x,y: h.y,z:local.z},color:'#39d353'},
    {face:'-Y',p:{x:local.x,y:-h.y,z:local.z},color:'#39d353'},
    {face:'+Z',p:{x:local.x,y:local.y,z: h.z},color:'#54a0ff'},
    {face:'-Z',p:{x:local.x,y:local.y,z:-h.z},color:'#54a0ff'},
  ];
}

/* ═══════════════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════════════ */
function getLayout3D() {
  const dark = darkTheme;
  const bg   = dark ? '#0d1117' : '#f6f8fa';
  const grid = dark ? '#21262d' : '#e0e0e0';
  const font = dark ? '#c9d1d9' : '#24292f';
  return {
    paper_bgcolor: bg, plot_bgcolor: bg, font:{color:font,family:"'Share Tech Mono', monospace",size:10},
    margin:{l:0,r:0,t:0,b:0},
    scene:{
      xaxis:{title:'Eastings (E)',backgroundcolor:bg,gridcolor:grid,zerolinecolor:grid},
      yaxis:{title:'Northings (N)',backgroundcolor:bg,gridcolor:grid,zerolinecolor:grid},
      zaxis:{title:'Sub-Sea (Z)',backgroundcolor:bg,gridcolor:grid,zerolinecolor:grid,autorange:true},
      aspectmode:'data'
    }
  };
}

function getLayout2D(xTitle,yTitle) {
  const bg=darkTheme?'#0d1117':'#f6f8fa', font=darkTheme?'#c9d1d9':'#24292f', grid=darkTheme?'#21262d':'#e0e0e0';
  return {
    paper_bgcolor:bg,plot_bgcolor:bg,font:{color:font,family:"'Share Tech Mono', monospace",size:9},
    margin:{l:45,r:10,t:4,b:32},
    xaxis:{title:xTitle,gridcolor:grid,zerolinecolor:grid},
    yaxis:{title:yTitle,gridcolor:grid,zerolinecolor:grid}
  };
}

/* ═══════════════════════════════════════════════════
   REBUILD
═══════════════════════════════════════════════════ */
function rebuild() {
  exportRows = [];
  traces = [];
  let logHtml = '';

  // Draw well trajectories
  wells.forEach((w,i) => {
    traces.push({
      type:'scatter3d', mode:'lines', name:w.name,
      x:w.s.map(p=>p.x), y:w.s.map(p=>p.y), z:w.s.map(p=>p.z),
      line:{color:WELL_COLORS[i%WELL_COLORS.length],width:4}
    });
  });

  // Ellipsoids for selected ref/off wells
  if (showEllipsoids && boxes.length > 0) {
    const b0=boxes[0];
    [{ wi:b0.ref,color:'#00e5ff' },{ wi:b0.off,color:'#ffc107' }].forEach(({wi,color}) => {
      const w=wells[wi]; if(!w) return;
      sampleMDs(w.s,60).forEach(md=>{
        const p=interpSurvey(w.s,md); if(!p) return;
        const cov=rev5_3D(p.md,p.inc,p.azi);
        traces.push(ellipsoidTrace(p,cov,K95,`Ell@${md}`,color));
      });
    });
  }

  // Process boxes
  boxes.forEach((b,i) => {
    const rw=wells[b.ref], ow=wells[b.off];
    if (!rw||!ow) return;

    const center = interpSurvey(rw.s, b.md);
    if (!center) return;

    const offPt = interpolateClosestWithSurvey(center, ow.s);
    if (!offPt) return;

    const cRef = rev5_3D(center.md,center.inc,center.azi);
    const cOff = rev5_3D(offPt.md,offPt.inc,offPt.azi);
    const sf   = separationFactor3D(center,cRef,offPt,cOff);

    const closest3D = closestPointToTrajectory(center, ow.s);

    const box = { c:center, h:{x:b.dx,y:b.dy,z:b.dz} };
    const hit = firstEntry(ow.s, box, b);

    const row = {
      Box_ID: i+1,
      Reference_Well: rw.name,
      Offset_Well: ow.name,
      Ref_MD: b.md,
      Model: 'ISCWSA-Rev5-3D',
      Separation_m: sf.separation.toFixed(2),
      Combined_Sigma_95_m: (K95*sf.sigma).toFixed(2),
      SF_3D_95: sf.SF.toFixed(3),
      Min_C2C_3D_m: closest3D.minDist.toFixed(3),
      Offset_In_Box: hit?'TRUE':'FALSE',
      Offset_Entry_MD: hit?hit.md.toFixed(2):''
    };
    if (hit) {
      row.Clr_PosX=( box.h.x - hit.local.x ).toFixed(2); 
      row.Clr_NegX=( box.h.x + hit.local.x ).toFixed(2);
      row.Clr_PosY=( box.h.y - hit.local.y ).toFixed(2); 
      row.Clr_NegY=( box.h.y + hit.local.y ).toFixed(2);
      row.Clr_PosZ=( box.h.z - hit.local.z ).toFixed(2); 
      row.Clr_NegZ=( box.h.z + hit.local.z ).toFixed(2);
      row.Dist_X=( hit.local.x ).toFixed(2);
      row.Dist_Y=( hit.local.y ).toFixed(2);
      row.Dist_Z=( hit.local.z ).toFixed(2);
    }
    exportRows.push(row);

    // Visuals
    traces.push(markerTrace(center,`Ref MD ${b.md}`,'#ffc107'));
    traces.push(boxMesh(center,box.h,b));
    traces.push(boxWireframe(center,box.h,b));

    if (hit) {
      const rotWorld = rotate(hit.local,b);
      const entryWorld = {x:rotWorld.x+center.x,y:rotWorld.y+center.y,z:rotWorld.z+center.z};
      traces.push(markerTrace(entryWorld,`Entry Box${i+1}`,'#00e5ff'));
      faceProjections(hit.local,box.h).forEach(fp=>{
        const rp=rotate(fp.p,b);
        traces.push(dashedLine(entryWorld,{x:rp.x+center.x,y:rp.y+center.y,z:rp.z+center.z},fp.color,`Clr ${fp.face} Box${i+1}`));
      });
    }

    if (closest3D.closest) {
      traces.push(markerTrace(closest3D.closest,`Closest Off Box${i+1}`,'#ff4d4d'));
      traces.push(dashedLine(center,closest3D.closest,'#ff4d4d',`Min C2C Box${i+1}`));
    }

    // Log
    const sfCls=sf.SF<1?'bad':sf.SF<1.5?'warn':'ok';
    logHtml+=`<span class="hi">BOX ${i+1}</span>  Ref: ${rw.name.replace(/\.csv$/i,'')} @ MD ${b.md} m\n`;
    logHtml+=` Off: ${ow.name.replace(/\.csv$/i,'')}\n`;
    logHtml+=` Model: <span class="val">ISCWSA Rev-5 · 3D SF</span>\n`;
    logHtml+=` Sep 3D: <span class="val">${sf.separation.toFixed(2)} m</span>\n`;
    logHtml+=` σ (95%): <span class="val">${(K95*sf.sigma).toFixed(2)} m</span>\n`;
    logHtml+=` SF: <span class="${sfCls}">${sf.SF.toFixed(3)}</span>${sf.SF<1?' ⚠️ COLLISION RISK':sf.SF<1.5?' ⚠️ CAUTION':' ✓'}\n`;
    logHtml+=` Min C2C: <span class="val">${closest3D.minDist.toFixed(2)} m</span>\n`;
    logHtml+=` In Box: <span class="${hit?'bad':'ok'}">${hit?'YES at MD ' + hit.md.toFixed(2)+' m':'NO'}</span>\n`;
    if (hit) {
      logHtml+=' Distances entry point to box (m):\n';
      logHtml+=' +X: ' + Math.abs(( box.h.x - hit.local.x).toFixed(2))+';\n'; 
      logHtml+=' -X: ' + Math.abs((box.h.x + hit.local.x).toFixed(2))+';\n';
      logHtml+=' +Y: ' + Math.abs(( box.h.y - hit.local.y).toFixed(2))+';\n'; 
      logHtml+=' -Y: ' + Math.abs((box.h.y + hit.local.y).toFixed(2))+';\n';
      logHtml+=' +Z: ' + Math.abs(( box.h.z - hit.local.z).toFixed(2))+';\n'; 
      logHtml+=' -Z: ' + Math.abs((box.h.z + hit.local.z).toFixed(2))+';\n';
      logHtml+=' Distances between points (m):\n';
      logHtml+=' X: ' + Math.abs(( hit.local.x ).toFixed(2))+';\n';
      logHtml+=' Y: ' + Math.abs(( hit.local.y ).toFixed(2))+';\n';
      logHtml+=' Z: ' + Math.abs(( hit.local.z ).toFixed(2))+';\n';
      logHtml+=' 3D: ' + Math.sqrt(hit.local.x**2 + hit.local.y**2 + hit.local.z**2).toFixed(2)+';\n';
    }
    logHtml+='─'.repeat(24)+'\n\n';
  });

  if (!logHtml) logHtml='<span style="color:var(--muted)">Add boxes to see anti-collision results.</span>';
  document.getElementById('log').innerHTML = logHtml;

  // Box selector
  document.getElementById('boxSelect').innerHTML='';
  boxes.forEach((b,i)=>{
    document.getElementById('boxSelect').add(new Option(`Box ${i+1} @ MD ${b.md}`,i));
  });

  // Mini profiles
  if (boxes.length>0) {
    const b=boxes[0], rw=wells[b.ref], ow=wells[b.off];
    if (rw&&ow) {
      const prof=computeProfile(rw,ow,30);
      const sfTrace={type:'scatter',mode:'lines',x:prof.mds,y:prof.sfs,line:{color:'#ffc107',width:2},name:'SF (3D,95%)'};
      const sfLayout=Object.assign(getLayout2D('MD (m)','SF (3D 95%)'),{
        shapes:[
          {type:'line',x0:prof.mds[0],x1:prof.mds.at(-1),y0:1.0,y1:1.0,line:{dash:'dot',color:'#ff4d4d'}},
          {type:'line',x0:prof.mds[0],x1:prof.mds.at(-1),y0:1.5,y1:1.5,line:{dash:'dot',color:'#ffc107'}},
          {type:'line',x0:prof.mds[0],x1:prof.mds.at(-1),y0:2.0,y1:2.0,line:{dash:'dot',color:'#39d353'}}
        ]
      });
      Plotly.react('sfPlot',[sfTrace],sfLayout,{responsive:true});
      document.getElementById('sfPlot').on?.('plotly_click',ev=>{
        document.getElementById('refMD').value=ev.points[0].x.toFixed(2); rebuild();
      });

      const distTrace={type:'scatter',mode:'lines',x:prof.mds,y:prof.dists,line:{color:'#00e5ff',width:2},name:'C2C 3D'};
      Plotly.react('c2cPlot',[distTrace],getLayout2D('MD (m)','C2C 3D (m)'),{responsive:true});
    }
  }

  // 3D plot
  const lay3D=Object.assign(getLayout3D(),{showlegend:showLegend,uirevision:++uirev});
  Plotly.react('plot3d',traces,lay3D,{scrollZoom:true,responsive:true});
}

/* ═══════════════════════════════════════════════════
   FOLDER LOAD
═══════════════════════════════════════════════════ */
document.getElementById('folderBtn').addEventListener('click',()=>{
  document.getElementById('folderInput').click();
});

document.getElementById('folderInput').addEventListener('change', e => {
  const files = Array.from(e.target.files).filter(f=>f.name.toLowerCase().endsWith('.csv'));
  if (!files.length) { alert('No CSV files found in the selected folder.'); return; }

  wells = [];
  let loaded = 0;

  files.forEach(file => {
    Papa.parse(file, {
      header: true,
      skipEmptyLines: true,
      complete: r => {
        const survey = r.data.map(d=>({
          md:  +d.MD, inc: +d.Incl, azi: +d.Azim,
          x:   +d.Eastings, y: +d.Northings, z: +d['Sub-Sea']
        })).filter(p=>
          Number.isFinite(p.md)&&Number.isFinite(p.inc)&&Number.isFinite(p.azi)&&
          Number.isFinite(p.x)&&Number.isFinite(p.y)&&Number.isFinite(p.z)
        );
        if (survey.length > 1) {
          wells.push({ name: file.name, s: survey });
        }
        loaded++;
        if (loaded===files.length) {
          // Sort alphabetically
          wells.sort((a,b)=>a.name.localeCompare(b.name));
          document.getElementById('wellCount').textContent=`${wells.length} wells`;
          updateSelectors();
          renderWellsList();
          allPairsResults=[];
          document.getElementById('matrixWrap').innerHTML='<em style="color:var(--muted);font-size:10px;padding:6px;display:block">Run ⚡ SCAN ALL PAIRS to populate.</em>';
          rebuild();
        }
      }
    });
  });
});

function renderWellsList() {
  const div=document.getElementById('wellsList');
  div.innerHTML='';
  wells.forEach((w,i)=>{
    div.innerHTML+=`<div class="well-chip">
      <span class="well-dot" style="background:${WELL_COLORS[i%WELL_COLORS.length]}"></span>
      <span class="well-name" title="${w.name}">${w.name.replace(/\.csv$/i,'')}</span>
      <span class="well-pts">${w.s.length}pts</span>
    </div>`;
  });
}

function updateSelectors() {
  const rw=document.getElementById('refWell'), ow=document.getElementById('offWell');
  rw.innerHTML=''; ow.innerHTML='';
  wells.forEach((w,i)=>{ rw.add(new Option(w.name,i)); ow.add(new Option(w.name,i)); });
  if (wells.length>1) ow.selectedIndex=1;
}

/* ═══════════════════════════════════════════════════
   BOX CRUD
═══════════════════════════════════════════════════ */
function readBoxInputs(){
  return {
    ref:+document.getElementById('refWell').value,
    off:+document.getElementById('offWell').value,
    md: +document.getElementById('refMD').value,
    dx: +document.getElementById('dx').value,
    dy: +document.getElementById('dy').value,
    dz: +document.getElementById('dz').value,
    ax: +document.getElementById('ax').value,
    ay: +document.getElementById('ay').value,
    az: +document.getElementById('az').value
  };
}
function addBox()    { boxes.push(readBoxInputs()); rebuild(); }
function updateBox() { const s=document.getElementById('boxSelect'); if(s.value!=='') { boxes[s.value]=readBoxInputs(); rebuild(); } }
function deleteBox() { const s=document.getElementById('boxSelect'); if(s.value!=='') { boxes.splice(s.value,1); rebuild(); } }
function loadBox()   {
  const b=boxes[document.getElementById('boxSelect').value]; if(!b) return;
  document.getElementById('refWell').value=b.ref; document.getElementById('offWell').value=b.off;
  document.getElementById('refMD').value=b.md;
  document.getElementById('dx').value=b.dx; document.getElementById('dy').value=b.dy; document.getElementById('dz').value=b.dz;
  document.getElementById('ax').value=b.ax; document.getElementById('ay').value=b.ay; document.getElementById('az').value=b.az;
}

/* ═══════════════════════════════════════════════════
   EXPORT
═══════════════════════════════════════════════════ */
function exportCSV() {
  if (!exportRows.length) { alert('No results to export.'); return; }
  const headers=Object.keys(exportRows[0]);
  const csv=[headers.join(','),...exportRows.map(row=>headers.map(h=>`"${row[h]??''}"`).join(','))].join('\n');
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);
  const ts=new Date().toISOString().slice(0,16).replace(/[:T]/g,'-');
  const a=document.createElement('a'); a.href=url; a.download=`ac_rev5_${ts}.csv`; a.style.display='none';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);

  // Also export all-pairs
  if (allPairsResults.length) {
    const h2=['Ref','Offset','Min_SF_3D_95','Min_SF_MD_m','Min_C2C_3D_m','Min_C2C_MD_m'];
    const csv2=[h2.join(','),...allPairsResults.map(r=>`
      "${r.refName}",
      "${r.offName}",
      ${r.minSF.toFixed(3)},
      ${r.minSF_md??''},
      ${r.minC2C.toFixed(2)},
      ${r.minC2C_md??''}`)].join('\n');
    const blob2=new Blob([csv2],{type:'text/csv;charset=utf-8;'});
    const url2=URL.createObjectURL(blob2);
    const a2=document.createElement('a'); a2.href=url2; a2.download=`ac_allpairs_${ts}.csv`; a2.style.display='none';
    document.body.appendChild(a2); a2.click(); document.body.removeChild(a2);
  }
}

/* ═══════════════════════════════════════════════════
   AXIS APPLY BUTTONS
═══════════════════════════════════════════════════ */
document.getElementById('applyDist').addEventListener('click',()=>{
  const xr=(document.getElementById('distXmin').value||document.getElementById('distXmax').value)?[+document.getElementById('distXmin').value,+document.getElementById('distXmax').value]:null;
  const yr=[+document.getElementById('distYmin').value,+document.getElementById('distYmax').value];
  Plotly.relayout('c2cPlot',{'xaxis.range':xr,'yaxis.range':yr});
});
document.getElementById('applySF').addEventListener('click',()=>{
  const xr=(document.getElementById('sfXmin').value||document.getElementById('sfXmax').value)?[+document.getElementById('sfXmin').value,+document.getElementById('sfXmax').value]:null;
  const yr=[+document.getElementById('sfYmin').value,+document.getElementById('sfYmax').value];
  Plotly.relayout('sfPlot',{'xaxis.range':xr,'yaxis.range':yr});
});

/* ═══════════════════════════════════════════════════
   TOGGLES
═══════════════════════════════════════════════════ */
document.getElementById('themeToggle').addEventListener('change',e=>{
  darkTheme=e.target.checked;
  e.target.closest('.sw').querySelector('.sw-label').textContent=darkTheme?'DARK':'LIGHT';
  rebuild();
});
document.getElementById('ellipsoidToggle').addEventListener('change',e=>{ showEllipsoids=e.target.checked; rebuild(); });
document.getElementById('legendToggle').addEventListener('change',e=>{ showLegend=e.target.checked; rebuild(); });

/* ═══════════════════════════════════════════════════
   TABS
═══════════════════════════════════════════════════ */
function switchTab(id) {
  document.querySelectorAll('.tab-btn').forEach((b,i)=>{
    const ids=['log','wells','matrix'];
    b.classList.toggle('active',ids[i]===id);
  });
  document.querySelectorAll('.tab-pane').forEach(p=>p.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
}

/* ── INIT ── */
rebuild();
</script>
